<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="text-sm font-bold text-subtle">Admin Console</p>
      <h1 class="mt-1 text-3xl font-black text-ink">管理ダッシュボード</h1>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "新規イベント", new_event_path, class: "ui-btn ui-btn-primary" %>
      <%= link_to "試合一覧", matches_path, class: "ui-btn ui-btn-secondary" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]">
    <div class="min-w-0 space-y-5">
      <section class="ui-card p-5"
               data-controller="<%= @active_rotation ? 'rotation-subscriber' : nil %>"
               data-rotation-subscriber-rotation-id-value="<%= @active_rotation&.id %>">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm font-black text-subtle">本日のイベント</p>
            <% if @today_event %>
              <h2 class="mt-1 text-2xl font-black text-ink"><%= @today_event.name %></h2>
              <p class="mt-1 text-sm font-bold text-muted"><%= @today_event.held_on.strftime("%Y/%m/%d") %></p>
            <% else %>
              <h2 class="mt-1 text-2xl font-black text-ink">本日はイベントがありません</h2>
            <% end %>
          </div>
          <% if @active_rotation %>
            <span class="inline-flex items-center gap-2 rounded-full bg-neg px-3 py-1 text-xs font-black text-on-accent">
              <span class="h-2 w-2 rounded-full bg-on-accent animate-pulse"></span>
              リアルタイム更新中
            </span>
          <% end %>
        </div>

        <% if @today_event && @active_rotation %>
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            <%= render Ui::StatComponent.new(label: "ローテーション", value: @active_rotation.display_name, tone: :neutral) %>
            <%= render Ui::StatComponent.new(label: "進捗", value: @active_rotation.current_match_index + 1, unit: "/ #{@rotation_matches.count} 試合", tone: :accent) %>
            <%= render Ui::StatComponent.new(label: "次の管理", value: "記録", tone: :neutral, meta: "現在の試合を確認") %>
          </div>

          <% if @current_rotation_match %>
            <div class="mt-5 rounded-lg bg-bg p-4 shadow-inner-soft">
              <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
                <h3 class="text-base font-black text-ink">第<%= @active_rotation.current_match_index + 1 %>試合</h3>
                <span class="ui-chip">現在の試合</span>
              </div>
              <div class="grid gap-3 md:grid-cols-[1fr_3rem_1fr] md:items-center">
                <div class="rounded-lg bg-surface p-3 shadow-inner-soft">
                  <p class="text-xs font-black text-subtle">チーム1</p>
                  <p class="mt-2 font-black text-neg"><%= @current_rotation_match.team1_player1.nickname %> <span class="text-xs text-muted">配信台</span></p>
                  <p class="mt-1 font-bold text-ink"><%= @current_rotation_match.team1_player2.nickname %></p>
                </div>
                <div class="text-center text-xs font-black text-subtle">VS</div>
                <div class="rounded-lg bg-surface p-3 shadow-inner-soft">
                  <p class="text-xs font-black text-subtle">チーム2</p>
                  <p class="mt-2 font-black text-ink"><%= @current_rotation_match.team2_player1.nickname %></p>
                  <p class="mt-1 font-bold text-ink"><%= @current_rotation_match.team2_player2.nickname %></p>
                </div>
              </div>
            </div>
          <% end %>

          <% if @upcoming_rotation_matches.any? %>
            <div class="mt-5">
              <h3 class="mb-3 text-sm font-black text-ink">次の試合</h3>
              <div class="space-y-2">
                <% @upcoming_rotation_matches.each do |rm| %>
                  <div class="rounded-lg bg-bg px-4 py-3 shadow-inner-soft">
                    <div class="flex flex-wrap items-center justify-between gap-2 text-sm">
                      <span class="font-black text-subtle">第<%= rm.match_index + 1 %>試合</span>
                      <span class="font-bold text-ink">
                        <span class="text-neg"><%= rm.team1_player1.nickname %></span>
                        &amp; <%= rm.team1_player2.nickname %>
                        <span class="mx-2 text-subtle">VS</span>
                        <%= rm.team2_player1.nickname %> &amp; <%= rm.team2_player2.nickname %>
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="mt-5">
            <%= link_to "ローテーション管理", rotation_path(@active_rotation), class: "ui-btn ui-btn-primary w-full justify-center" %>
          </div>
        <% elsif @today_event %>
          <div class="mt-5 rounded-lg bg-bg p-5 text-center shadow-inner-soft">
            <p class="text-sm font-bold text-muted">アクティブなローテーションがありません</p>
            <%= link_to "ローテーション作成", new_event_rotation_path(@today_event), class: "ui-btn ui-btn-primary mt-4" %>
          </div>
        <% else %>
          <div class="mt-5 rounded-lg bg-bg p-5 text-center shadow-inner-soft">
            <p class="text-sm font-bold text-muted">今日のイベントを作成すると、ここに運営状況が表示されます。</p>
            <%= link_to "新しいイベントを作成", new_event_path, class: "ui-btn ui-btn-primary mt-4" %>
          </div>
        <% end %>
      </section>

      <section class="ui-card p-5">
        <h2 class="text-lg font-black text-ink">クイックアクション</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 md:grid-cols-3">
          <% [
            [ "イベント", events_path, :events ],
            [ "ローテーション", rotations_path, :rotations ],
            [ "対戦履歴", matches_path, :matches ],
            [ "統計", statistics_path, :stats ],
            [ "機体一覧", mobile_suits_path, :suits ],
            [ "ユーザー管理", admin_users_path, :users ],
          ].each do |label, path, icon| %>
            <%= link_to path, class: "flex flex-col items-center gap-2 rounded-lg bg-bg p-4 text-center text-sm font-black text-ink shadow-inner-soft transition hover:text-accent hover:shadow-card" do %>
              <%= nav_icon_svg(icon, css_class: "h-6 w-6") %>
              <span><%= label %></span>
            <% end %>
          <% end %>
        </div>
      </section>

      <section class="ui-card p-0">
        <div class="px-5 py-4">
          <h2 class="text-lg font-black text-ink">最近の試合</h2>
        </div>
        <% if @recent_matches.any? %>
          <div class="space-y-3 px-4 pb-5 sm:px-5">
            <% @recent_matches.each do |match| %>
              <%
                all_mp = match.match_players.sort_by { |mp| [ mp.team_number, mp.position ] }
                team1 = all_mp.select { |mp| mp.team_number == 1 }
                team2 = all_mp.select { |mp| mp.team_number == 2 }
              %>
              <article class="rounded-lg bg-bg p-4 shadow-inner-soft transition hover:shadow-card"
                       data-controller="card-link"
                       data-card-link-url-value="<%= match_path(match) %>"
                       data-action="click->card-link#navigate">
                <div class="mb-3 flex min-w-0 flex-wrap items-center gap-2">
                  <%= link_to match.played_at.strftime("%Y年%m月%d日"), match_path(match), class: "text-sm font-bold text-subtle hover:text-accent", data: { turbo_frame: "_top" } %>
                  <span class="ui-chip w-full truncate sm:w-auto"><%= match.event.name %></span>
                </div>
                <%= render "matches/match_teams",
                      left_players: team1,
                      right_players: team2,
                      left_wins: match.winning_team == 1,
                      left_label: "チーム1",
                      right_label: "チーム2",
                      compact: true %>
              </article>
            <% end %>
          </div>
          <div class="px-5 pb-5">
            <%= link_to "すべて見る", matches_path, class: "ui-btn ui-btn-secondary w-full justify-center" %>
          </div>
        <% else %>
          <p class="px-5 pb-5 text-sm font-bold text-muted">まだ試合記録がありません</p>
        <% end %>
      </section>
    </div>

    <aside class="min-w-0 space-y-5">
      <section class="ui-card p-5">
        <h2 class="text-lg font-black text-ink">システム統計</h2>
        <div class="mt-4 grid gap-3">
          <%= render Ui::StatComponent.new(label: "総イベント数", value: @total_events, tone: :accent) %>
          <%= render Ui::StatComponent.new(label: "総試合数", value: @total_matches, tone: :neutral) %>
          <%= render Ui::StatComponent.new(label: "登録ユーザー数", value: @total_users, tone: :neutral) %>
        </div>
      </section>

      <section class="ui-card p-0">
        <div class="px-5 py-4">
          <h2 class="text-lg font-black text-ink">今後のイベント</h2>
        </div>
        <div class="space-y-2 px-5 pb-5">
          <% if @upcoming_events.any? %>
            <% @upcoming_events.each do |event| %>
              <%= link_to event_path(event), class: "block rounded-lg bg-bg px-4 py-3 shadow-inner-soft transition hover:shadow-card" do %>
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="font-black text-ink"><%= event.name %></p>
                    <p class="mt-1 text-xs font-bold text-subtle"><%= event.held_on.strftime("%Y年%m月%d日") %></p>
                  </div>
                  <% if event.held_on == Time.zone.today %>
                    <span class="ui-chip ui-chip-active">本日</span>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-sm font-bold text-muted">予定されているイベントはありません</p>
          <% end %>
        </div>
      </section>

      <section class="ui-card p-0">
        <div class="px-5 py-4">
          <h2 class="text-lg font-black text-ink">人気の機体 TOP5</h2>
        </div>
        <div class="space-y-2 px-5 pb-5">
          <% if @popular_mobile_suits.any? %>
            <% @popular_mobile_suits.each_with_index do |suit, index| %>
              <%= link_to mobile_suit_path(suit), class: "flex items-center gap-3 rounded-lg bg-bg px-4 py-3 shadow-inner-soft transition hover:shadow-card" do %>
                <span class="<%= index.zero? ? 'text-accent' : 'text-subtle' %> text-lg font-black tabular-nums">#<%= index + 1 %></span>
                <div class="min-w-0 flex-1">
                  <p class="truncate font-black text-ink"><%= suit.name %></p>
                  <p class="text-xs font-bold text-subtle"><%= suit.series %></p>
                </div>
                <span class="text-sm font-black text-accent tabular-nums"><%= suit.usage_count %>回</span>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-sm font-bold text-muted">データがありません</p>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
