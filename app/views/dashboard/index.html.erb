<%# ダッシュボード（プレイヤー視点）。mock: tmp/ui-mocks/dashboard.html %>
<div class="m-head">
  <div>
    <h1><%= viewing_as_user.nickname %> さん</h1>
    <div class="m-who">ようこそ、<%= viewing_as_user.nickname %>さん</div>
  </div>
  <% if @today_event %>
    <div class="m-ctx">本日のイベント <b><%= @today_event.name %></b> <span class="m-num"><%= @today_event.held_on.strftime("%Y/%m/%d") %></span></div>
  <% end %>
</div>

<% if viewing_as_user.is_guest %>
  <div class="m-panel m-pbody" style="margin-bottom:18px">
    <p class="text-sm font-bold text-cost-2500">ゲストアカウントでログイン中です。個人戦績などの機能を利用するには、管理者にアカウント発行を依頼してください。</p>
  </div>
<% elsif @user_total_matches.to_i.zero? %>
  <div class="m-panel m-pbody" style="margin-bottom:18px">
    <p class="text-sm font-bold text-muted">対戦会でイベントが作成されたら、ローテーション表から試合に参加しましょう。試合結果を記録すると、ここに統計情報が表示されます。</p>
  </div>
<% end %>

<%# ===== メトリクス帯 ===== %>
<% unless viewing_as_user.is_guest || @user_total_matches.to_i.zero? %>
  <% recent = (@recent_10_results || []).to_a %>
  <div class="m-wrcard">
    <div class="m-wrcard-main">
      <div class="m-ring <%= "lo" if @user_win_rate.to_f < 50 %>" style="--p: <%= @user_win_rate %>">
        <div class="m-ring-c">
          <div class="pct"><%= @user_win_rate %>%</div>
          <div class="lbl">勝率</div>
        </div>
      </div>
      <div class="m-wrcard-rec"><span class="m-num"><%= @user_total_matches %></span><span class="u">戦</span><span class="m-num"><%= @user_wins %></span><span class="u">勝</span><span class="m-num"><%= @user_total_matches.to_i - @user_wins.to_i %></span><span class="u">敗</span></div>
    </div>
    <div class="m-wrcard-form">
      <% if recent.any? %>
        <div class="cap"><h3>直近10試合の戦績</h3></div>
        <div class="m-streak-cap"><span>OLDER</span><span class="m-now-lab">LATEST</span></div>
        <div class="m-form-row" style="grid-template-columns:repeat(<%= recent.size %>,minmax(0,1fr))">
          <% recent.reverse.each_with_index do |result, index| %>
            <span class="m-sq <%= result ? "m-w" : "m-l" %> <%= "m-now" if index == recent.size - 1 %>"><%= result ? "W" : "L" %></span>
          <% end %>
        </div>
        <div class="m-form-meta">
          <b class="m-num"><%= recent.size %>戦 <%= recent.count(true) %>勝<%= recent.count(false) %>敗</b>
          <% if @current_streak.to_i >= 2 %> ・ <b><%= @current_streak %><%= @streak_type == "win" ? "連勝中" : "連敗中" %></b><% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== ライブ進行パネル ===== %>
<% if @active_rotation %>
  <div class="m-livepanel"
       data-controller="rotation-subscriber"
       data-rotation-subscriber-rotation-id-value="<%= @active_rotation.id %>">
    <div class="m-live-head">
      <span class="m-live"><span class="m-dot"></span>進行中</span>
      <div>
        <div class="m-ev"><%= @active_rotation.display_name %></div>
        <div class="m-sub">本日のイベント <%= @today_event&.name %></div>
      </div>
      <div class="m-spacer"></div>
      <div class="m-turn">
        <% if @user_next_rotation_match %>
          あなたの次の出番<br><b>第<%= @user_next_rotation_match.match_index + 1 %>試合<%= @matches_until_user_turn.to_i.zero? ? "・現在の試合" : "・あと#{@matches_until_user_turn}試合" %></b>
        <% else %>
          <b>このローテーションでの出番は終了</b>
        <% end %>
      </div>
      <div class="m-cta">
        <%= link_to "ローテーション表 →", rotation_path(@active_rotation), class: "m-btn m-btn-primary" %>
      </div>
    </div>
    <div class="m-live-body">
      <div class="m-tl-head">
        <span class="m-eyebrow">ローテーション進行</span>
        <span class="m-tl-count"><%= @rotation_current_match_index.to_i + 1 %> / <%= @rotation_total_matches %> 試合</span>
      </div>
      <% pct = @rotation_total_matches.to_i.positive? ? ((@rotation_current_match_index.to_i + 1).to_f / @rotation_total_matches * 100).round : 0 %>
      <div class="m-track2">
        <div class="m-track2-fill" style="width:<%= pct %>%"></div>
        <div class="m-track2-pin" style="left:<%= pct %>%"><span class="m-num"><%= @rotation_current_match_index.to_i + 1 %></span></div>
      </div>
      <div class="m-track2-ends"><span class="m-num">1</span><span class="m-num"><%= @rotation_total_matches %></span></div>

      <% if @current_rotation_match %>
        <div class="m-nowmatch">
          <span class="m-lab">現在 ・ 第<%= @rotation_current_match_index.to_i + 1 %>試合</span>
          <div class="m-nm-team">
            <span class="m-nm-p"><%= @current_rotation_match.team1_player1.nickname %><span class="m-stream"><svg viewBox="0 0 24 24"><path d="M23 7l-7 5 7 5V7zM1 5h15v14H1z"/></svg>配信台</span></span>
            <span class="m-nm-p m-sub"><%= @current_rotation_match.team1_player2.nickname %></span>
          </div>
          <span class="m-vs">VS</span>
          <div class="m-nm-team">
            <span class="m-nm-p"><%= @current_rotation_match.team2_player1.nickname %></span>
            <span class="m-nm-p m-sub"><%= @current_rotation_match.team2_player2.nickname %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% elsif @today_event %>
  <div class="m-livepanel">
    <div class="m-live-head">
      <div>
        <div class="m-ev"><%= @today_event.name %></div>
        <div class="m-sub">アクティブなローテーションはまだありません</div>
      </div>
      <div class="m-spacer"></div>
      <% if current_user.is_admin? %>
        <div class="m-cta"><%= link_to "ローテーション作成", new_event_rotation_path(@today_event), class: "m-btn m-btn-primary" %></div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== 2カラム ===== %>
<div class="m-grid">
  <div class="m-col">
    <%# 最近の対戦 %>
    <div class="m-panel">
      <div class="m-phead">
        <h2>最近の対戦</h2>
        <%= link_to "すべて見る →", matches_path, class: "m-link" %>
      </div>
      <% if !viewing_as_user.is_guest && @recent_matches.any? %>
        <% @recent_matches.each do |match| %>
          <%
            all_mp = match.match_players.sort_by { |mp| [ mp.team_number, mp.position ] }
            team1 = all_mp.select { |mp| mp.team_number == 1 }
            team2 = all_mp.select { |mp| mp.team_number == 2 }
            my_player = all_mp.find { |mp| mp.user_id == viewing_as_user.id }
            if my_player
              my_team = my_player.team_number
              left_players = my_team == 1 ? team1 : team2
              right_players = my_team == 1 ? team2 : team1
              left_wins = match.winning_team == my_team
              left_label = "自チーム"; right_label = "相手チーム"
            else
              left_players = team1; right_players = team2
              left_wins = match.winning_team == 1
              left_label = "チーム1"; right_label = "チーム2"
            end
          %>
          <%= render "matches/mcard", match: match, left_players: left_players, right_players: right_players,
                left_wins: left_wins, left_label: left_label, right_label: right_label %>
        <% end %>
      <% else %>
        <div class="m-pbody"><p class="text-sm font-bold text-muted">まだ試合記録がありません</p></div>
      <% end %>
    </div>
  </div>

  <div class="m-col">
    <%# 通知 %>
    <% if !viewing_as_user.is_guest && @notifications.any? %>
      <div class="m-panel">
        <div class="m-phead"><h2>通知</h2></div>
        <div class="m-pbody" style="display:flex;flex-direction:column;gap:8px">
          <% @notifications.each do |notif| %>
            <p class="text-sm font-bold <%= notif[:type] == "warning" ? "text-neg" : "text-accent" %>"><%= notif[:message] %></p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# お気に入り機体 %>
    <% unless viewing_as_user.is_guest %>
      <div class="m-panel">
        <div class="m-phead"><h2>お気に入り機体</h2><span class="m-eyebrow">機体別戦績</span></div>
        <% if @user_favorite_suits.any? %>
          <% @user_favorite_suits.each do |suit| %>
            <%= link_to mobile_suit_path(suit), class: "m-fav", data: { turbo_frame: "_top" } do %>
              <%= render "shared/m_suit", suit: suit %>
              <div class="m-meta">
                <div class="m-nm"><%= suit.name %></div>
                <div class="m-sub m-num"><%= suit.usage_count %>戦 <%= (suit.usage_count.to_i * suit.win_rate.to_f / 100).round %>勝</div>
                <div class="m-bar2"><div class="m-f" style="width:<%= suit.win_rate %>%"></div></div>
              </div>
              <div class="m-wr"><%= suit.win_rate %>%</div>
            <% end %>
          <% end %>
        <% else %>
          <div class="m-pbody"><p class="text-sm font-bold text-muted">試合に参加すると、よく使う機体が表示されます</p></div>
        <% end %>
      </div>
    <% end %>

    <%# ベストパートナー %>
    <% unless viewing_as_user.is_guest %>
      <div class="m-panel">
        <div class="m-phead"><h2>ベストパートナー</h2></div>
        <% if @best_partners.any? %>
          <% @best_partners.each_with_index do |partner, index| %>
            <div class="m-rank">
              <div class="m-l">
                <span class="m-no <%= index.zero? ? "m-top" : "" %>"><%= index + 1 %></span>
                <div>
                  <div class="m-nm"><%= partner[:user].nickname %></div>
                  <div class="m-sub m-num"><%= partner[:wins] %>勝 <%= partner[:total] - partner[:wins] %>敗</div>
                </div>
              </div>
              <span class="m-wr"><%= partner[:win_rate] %>%</span>
            </div>
          <% end %>
        <% else %>
          <div class="m-pbody"><p class="text-sm font-bold text-muted">同じパートナーと3試合以上プレイすると表示されます</p></div>
        <% end %>
      </div>
    <% end %>

    <%# パフォーマンス（上部帯と重複しない戦闘指標＋コミュニティ平均比較）%>
    <% if !viewing_as_user.is_guest && @performance_snapshot %>
      <div class="m-panel">
        <div class="m-phead">
          <h2>パフォーマンス</h2>
          <%= link_to "詳細を見る →", statistics_path(tab: "performance"), class: "m-link" %>
        </div>
        <%= render "dashboard/perf_row", label: "平均与ダメージ", value: @performance_snapshot[:avg_damage], community: @community_snapshot&.dig(:avg_damage) %>
        <%= render "dashboard/perf_row", label: "平均被ダメージ", value: @user_avg_damage_received, community: @community_snapshot&.dig(:avg_damage_received), invert: true %>
        <%= render "dashboard/perf_row", label: "平均 EX ダメージ", value: @performance_snapshot[:avg_exburst_damage], community: @community_snapshot&.dig(:avg_exburst_damage) %>
        <% if @exburst_summary %>
          <%= render "dashboard/perf_row", label: "EX 発動回数", value: @exburst_summary[:avg_count], community: @exburst_summary[:community_avg_count] %>
        <% end %>
      </div>
    <% end %>

    <%# 今後のイベント %>
    <div class="m-panel">
      <div class="m-phead"><h2>今後のイベント</h2></div>
      <% if @upcoming_events.any? %>
        <% @upcoming_events.each do |event| %>
          <%= link_to event_path(event), class: "m-rank", data: { turbo_frame: "_top" } do %>
            <div class="m-l"><div><div class="m-nm"><%= event.name %></div><div class="m-sub m-num"><%= event.held_on.strftime("%Y/%m/%d") %></div></div></div>
            <span class="m-link">→</span>
          <% end %>
        <% end %>
      <% else %>
        <div class="m-pbody"><p class="text-sm font-bold text-muted">予定されているイベントはありません</p></div>
      <% end %>
    </div>
  </div>
</div>
