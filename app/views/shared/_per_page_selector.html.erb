<%# locals: (per_page:, url_builder:) %>
<div class="flex items-center gap-2 text-sm font-bold text-muted">
  <span>表示件数:</span>
  <% [10, 20, 50].each do |n| %>
    <% if n == per_page %>
      <span class="ui-chip ui-chip-active tabular-nums"><%= n %></span>
    <% else %>
      <%= link_to n, url_builder.call(n), class: "ui-chip tabular-nums" %>
    <% end %>
  <% end %>
</div>
