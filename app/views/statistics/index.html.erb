  <% elsif @active_tab == "overview" %>
    <%
      line_chart = ->(data) {
        n = data.size
        next %(<div class="m-pbody"><p class="text-sm font-bold text-muted">データがありません</p></div>).html_safe if n.zero?
        xpos = ->(i) { n == 1 ? 50.0 : (i.to_f / (n - 1) * 100) }
        poly = data.each_with_index.map { |(_, rate), i| "#{xpos.call(i).round(2)},#{(100 - rate.to_f).round(2)}" }.join(" ")
        dots = data.each_with_index.map { |(label, rate, sub), i|
          x = xpos.call(i).round(2); r = rate.to_f
          sub_html = sub ? %(<span style="display:block;opacity:.75;font-size:9px">#{sub}</span>) : ""
          %(<span class="st-lp" style="left:#{x}%;bottom:#{r}%"></span>) +
          %(<span class="st-lv" style="left:#{x}%;bottom:calc(#{r}% + 9px)">#{rate}%</span>) +
          %(<span class="st-lx" style="left:#{x}%">#{label}#{sub_html}</span>)
        }.join
        chart = %(<div class="st-linechart"><div class="st-lplot">) +
          %(<svg viewBox="0 0 100 100" preserveAspectRatio="none"><line class="st-l50" x1="0" y1="50" x2="100" y2="50"/><polyline class="st-lpoly" points="#{poly}"/></svg>) +
          %(#{dots}<span class="st-l50lbl" style="top:50%">50%</span></div></div>)
        chart.html_safe
      }
      dmg_delta = ->(mine, comm, lower_better) {
        next %(<div class="m-d">全期間</div>).html_safe if mine.nil? || comm.nil? || comm.zero?
        diff = mine - comm
        good = lower_better ? diff <= 0 : diff >= 0
        sign = diff >= 0 ? "+" : ""
        %(<div class="m-d #{good ? "m-up" : "m-down"}">全体比 #{sign}#{number_with_delimiter(diff)}</div>).html_safe
      }
      compat_label = { "good" => "得意", "mid" => "普通", "bad" => "苦手" }
      # ダメージゲージ（コミュニティ平均を中央=50%の基準にしたバー）
      gauge = ->(label, value, community, klass, lower_better) {
        if value.nil?
          next %(<div class="m-gauge"><div class="m-gauge-top"><span class="lbl">#{label}</span><span class="val">-</span></div><div class="m-gauge-track"></div></div>).html_safe
        end
        comm = community.to_i
        fill = comm.positive? ? [ 100, (value.to_f / comm * 50).round ].min : 50
        diff = value - comm
        good = lower_better ? diff <= 0 : diff >= 0
        sub = comm.positive? ? %(全体平均 <b>#{number_with_delimiter(comm)}</b> <span class="#{good ? "up" : "down"}">#{diff >= 0 ? "+" : ""}#{number_with_delimiter(diff)}</span>) : ""
        html = %(<div class="m-gauge">) +
          %(<div class="m-gauge-top"><span class="lbl">#{label}</span><span class="val">#{number_with_delimiter(value)}</span></div>) +
          %(<div class="m-gauge-track"><div class="m-gauge-fill #{klass}" style="width:#{fill}%"></div><div class="m-gauge-ref" style="left:50%"></div></div>) +
          %(<div class="m-gauge-sub">#{sub}</div></div>)
        html.html_safe
      }
    %>

