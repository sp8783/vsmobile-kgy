      <div class="m-pbody"><%= line_chart.call((@event_win_rates || []).map { |r| [r[:event].held_on.strftime("%-m/%-d"), r[:win_rate], "#{r[:total]}戦"] }) %></div>
    </div>

    <div class="m-panel" style="margin-bottom:18px">
      <div class="m-phead"><h2>ローテーション別 勝率</h2><span class="m-eyebrow">全イベントの同じローテーションを合算 ・ 下段＝試合数</span></div>
      <div class="m-pbody"><%= line_chart.call((@rotation_round_stats || []).map { |r| ["R#{r[:round_number]}", r[:win_rate], "#{r[:total]}戦"] }) %></div>
    </div>

  <% elsif @active_tab == "performance" %>
    <%
      pct = ->(num, den) { den.to_i.positive? ? (num.to_f / den * 100).round(1) : nil }
      fmt = ->(x) { x.nil? ? "-" : (x % 1 == 0 ? number_with_delimiter(x.to_i) : number_with_delimiter(x)) }
      has_self = @user_overall_avg.present?
      has_same = @user_same_cost_avg.present?
      # 自己比較バーの動的レンジ（自分の値と比較対象を中心に左右へ余白）
      self_range = ->(uv, rv) {
        uv = uv.to_f; rv = rv.to_f
        lo = [uv, rv].min; hi = [uv, rv].max; span = hi - lo
        pad = span >= 0.001 ? span * 0.5 : [uv.abs * 0.1, 0.5].max
        [[[lo - pad, 0].max, lo].min.round(2), [hi + pad, hi].max.round(2)]
      }
      num_fmt = fmt
      # 生存時間は cs（センチ秒）→ M:SS 表示。差分も同じフォーマッタで整形
      surv_fmt = ->(cs) { cs.nil? ? "-" : format_survival_cs(cs.round) }
      # 比較セルの内側：参照値＋ミニバー（●=自分 / │=比較対象）＋差分バッジ
      cmp_inner = ->(uv, rv, lo, hi, higher, suffix, dist, vf) {
        next %(<span class="st-cna">-</span>) if rv.nil?
        u = uv&.to_f; r = rv.to_f; lo = lo.to_f; hi = hi.to_f
        html = %(<div class="st-cval">#{vf.call(rv)}#{suffix}</div>)
        if u && hi > lo
          rng = hi - lo
          upos = [[(u - lo) / rng * 100, 0].max, 100].min.round(1)
          rpos = [[(r - lo) / rng * 100, 0].max, 100].min.round(1)
          good = higher ? u >= r : u <= r
          html += %(<div class="st-cbar#{dist ? " dist" : ""}"><div class="ref" style="left:#{rpos}%"></div><div class="dot #{good ? "good" : "bad"}" style="left:#{upos}%"></div></div>)
          html += %(<div class="st-cbar-lbl"><span>#{vf.call(lo)}#{suffix}</span><span>#{vf.call(hi)}#{suffix}</span></div>)
        end
        if u
          diff = (u - r).round(2)
          unless diff.abs < 0.005
            good = higher ? diff >= 0 : diff <= 0
            html += %(<span class="st-cdiff #{good ? "good" : "bad"}">#{diff >= 0 ? "+" : "-"}#{vf.call(diff.abs)}#{suffix}</span>)
          end
        end
        html
      }
      # 比較セル3種（community / self-overall / same-cost）を data-perf-col で出し分け
      cmp_variants = ->(klass, uv, c_avg, c_min, c_max, so_v, sc_v, higher, suffix, na) {
        comm = if na && (c_avg.nil? || uv.nil?) then %(<span class="st-cna">N/A</span>)
        elsif c_avg.nil? then %(<span class="st-cna">-</span>)
        else cmp_inner.call(uv, c_avg, c_min, c_max, higher, suffix, true, num_fmt) end
        out = %(<#{klass} data-perf-col="community" class="st-ccell">#{comm}</#{klass}>)
        if has_self
          so = if uv.nil? || so_v.nil? then %(<span class="st-cna">-</span>)
          else lo, hi = self_range.call(uv, so_v); cmp_inner.call(uv, so_v, lo, hi, higher, suffix, false, num_fmt) end
          out += %(<#{klass} data-perf-col="self-overall" class="st-ccell hidden">#{so}</#{klass}>)
        end
        if has_same
          sc = if uv.nil? || sc_v.nil? then %(<span class="st-cna">-</span>)
          else lo, hi = self_range.call(uv, sc_v); cmp_inner.call(uv, sc_v, lo, hi, higher, suffix, false, num_fmt) end
          out += %(<#{klass} data-perf-col="same-cost" class="st-ccell hidden">#{sc}</#{klass}>)
        end
        out
      }
      # 生存時間の比較セル。community は分布、self/same は自分の全体・同コスト帯の生存時間が基準
      surv_self = ->(uv, ref) {
        next %(<span class="st-cna">-</span>) if uv.nil? || ref.nil?
        lo, hi = self_range.call(uv, ref)
        cmp_inner.call(uv, ref, lo, hi, true, "", false, surv_fmt)
      }
      surv_variants = ->(died, life_index) {
        uv = died && died[:user_avg_cs]
        comm = if died.nil? || died[:community_avg_cs].nil? then %(<span class="st-cna">-</span>)
        else cmp_inner.call(uv, died[:community_avg_cs], died[:community_min_cs], died[:community_max_cs], true, "", true, surv_fmt) end
        out = %(<td data-perf-col="community" class="st-ccell">#{comm}</td>)
        out += %(<td data-perf-col="self-overall" class="st-ccell hidden">#{surv_self.call(uv, @survival_user_overall&.[](life_index))}</td>) if has_self
        out += %(<td data-perf-col="same-cost" class="st-ccell hidden">#{surv_self.call(uv, @survival_user_same_cost&.[](life_index))}</td>) if has_same
        out
      }
      # EX/OL カード：横長分布ゲージ1本（参照値ラベル＋差分バッジ＋min/max）
      wide_gauge = ->(you, ref, lo, hi, higher, ref_label) {
        next %(<div class="st-wg"><span class="st-cna">比較データなし</span></div>) if ref.nil?
        u = you&.to_f; r = ref.to_f; lo = lo.to_f; hi = hi.to_f
        top = %(<div class="st-wg-top"><span class="rl">#{ref_label} <b>#{fmt.call(ref)}%</b></span>)
        if u
          diff = (u - r).round(2)
          unless diff.abs < 0.005
            good = higher ? diff >= 0 : diff <= 0
            top += %(<span class="st-cdiff #{good ? "good" : "bad"}">#{diff >= 0 ? "+" : "-"}#{fmt.call(diff.abs)}%</span>)
          end
        end
        top += %(</div>)
        bar = ""
        if u && hi > lo
          rng = hi - lo
          upos = [[(u - lo) / rng * 100, 0].max, 100].min.round(1)
          rpos = [[(r - lo) / rng * 100, 0].max, 100].min.round(1)
          good = higher ? u >= r : u <= r
          dist = ref_label.include?("コミュニティ")
          bar = %(<div class="st-wg-track#{dist ? " dist" : ""}"><div class="st-wg-ref" style="left:#{rpos}%"></div><div class="st-wg-dot #{good ? "good" : "bad"}" style="left:#{upos}%"></div></div>)
          bar += %(<div class="st-wg-ends"><span>#{fmt.call(lo)}%</span><span>#{fmt.call(hi)}%</span></div>)
        end
        %(<div class="st-wg">#{top}#{bar}</div>)
      }
      # 比較対象スイッチに連動した3種のゲージ
      wide_variants = ->(you, c_avg, c_min, c_max, so_v, sc_v, higher) {
        out = %(<div data-perf-col="community">#{wide_gauge.call(you, c_avg, c_min, c_max, higher, "コミュニティ平均")}</div>)
        if has_self
          lo, hi = (you && so_v) ? self_range.call(you, so_v) : [nil, nil]
          out += %(<div data-perf-col="self-overall" class="hidden">#{wide_gauge.call(you, so_v, lo, hi, higher, "自分の全体平均")}</div>)
        end
        if has_same
          lo, hi = (you && sc_v) ? self_range.call(you, sc_v) : [nil, nil]
          out += %(<div data-perf-col="same-cost" class="hidden">#{wide_gauge.call(you, sc_v, lo, hi, higher, @same_cost_label)}</div>)
        end
        out
      }
      # EX/OL の1メトリクス（ヒーロー数値＋ゲージ）。tag: "up"/"down"/nil（指標の良い方向）、sub: 内訳行
      ex_metric = ->(label, tag, num, den, c_avg, c_min, c_max, so_v, sc_v, higher, sub) {
        you = den.to_i.positive? ? (num.to_f / den * 100).round(1) : nil
        tag_html = case tag
        when "up" then %(<span class="st-extag up"><span class="ar">↑</span>高いほど良い</span>)
        when "down" then %(<span class="st-extag down"><span class="ar">↓</span>低いほど良い</span>)
        else "" end
        prefix = sub ? "└ " : ""
        lead = %(<div class="st-exlead"><span class="st-exlabel">#{tag_html}#{prefix}#{label}</span>) +
          %(<span class="st-exbig">#{you || 0}<span class="pct">%</span><span class="frac">#{num || 0}/#{den}回</span></span></div>)
        %(<div class="st-exmetric#{sub ? " sub" : ""}">#{lead}<div class="st-exgcol">#{wide_variants.call(you, c_avg, c_min, c_max, so_v, sc_v, higher)}</div></div>)
      }
    %>

    <% st_total = @stats_total.to_i; st_wins = @stats_wins.to_i; st_losses = @stats_losses.to_i %>
    <% win_pct = pct.call(st_wins, st_total) || 0 %>
    <%
      # 全体平均からの乖離で「強み」「課題」を自動抽出（基本戦績は対象外）
      digest_metrics = [
        { key: :damage_dealt, label: "与ダメージ", suffix: "", higher: true },
        { key: :damage_received, label: "被ダメージ", suffix: "", higher: false },
        { key: :exburst_damage, label: "EXバーストダメージ", suffix: "", higher: true },
        { key: :exburst_count, label: "EXバースト発動回数", suffix: " 回", higher: true },
        { key: :exburst_death_rate, label: "EXバースト中被撃墜率", suffix: "%", higher: false }
      ]
      scored = digest_metrics.filter_map do |m|
        u = @performance_overall&.dig(m[:key]); avg = @community_avg&.dig(m[:key])
        mn = @community_min&.dig(m[:key]); mx = @community_max&.dig(m[:key])
        next if u.nil? || avg.nil? || mn.nil? || mx.nil? || mx.to_f <= mn.to_f
        norm = (u.to_f - avg.to_f) / (mx.to_f - mn.to_f)
        delta = (u.to_f - avg.to_f)
        m.merge(delta: delta, signed: m[:higher] ? norm : -norm)
      end
      strength = scored.max_by { |m| m[:signed] }
      weakness = scored.min_by { |m| m[:signed] }
      weakness = nil if weakness && strength && weakness[:key] == strength[:key]
      dg_delta = ->(m) {
        good = m[:higher] ? (m[:delta] >= 0) : (m[:delta] <= 0)
        rounded = m[:suffix] == "%" ? m[:delta].abs.round(1) : m[:delta].abs.round(0).to_i
        %(<div class="d #{good ? "up" : "down"}">全体比 #{m[:delta] >= 0 ? "+" : "-"}#{number_with_delimiter(rounded)}#{m[:suffix]} #{good ? "↑" : "↓"}</div>)
      }
      # 上段：強み / 課題（自動抽出）
      hl_cells = []
      { "強み" => strength, "課題" => weakness }.each do |tag, m|
        next unless m
        good = m[:higher] ? (m[:delta] >= 0) : (m[:delta] <= 0)
        hl_cells << %(<div class="st-dg-cell #{good ? "good" : "bad"}"><span class="k">#{tag}</span><div class="v">#{m[:label]}</div>#{dg_delta.call(m)}</div>)
      end
      # 下段：EX・オーバーリミットの固定指標
      dg_stat_cell = ->(label, user, comm, higher) {
        next nil if user.nil?
        d_html = ""
        if comm
          d = (user - comm).round(1)
          unless d.abs < 0.05
            good = higher ? d >= 0 : d <= 0
            d_html = %(<div class="d #{good ? "up" : "down"}">全体比 #{d >= 0 ? "+" : ""}#{d}% #{good ? "↑" : "↓"}</div>)
          end
        end
        %(<div class="st-dg-cell"><span class="ke">#{label}</span><div class="num">#{user}%</div>#{d_html}</div>)
      }
      ex_user = pct.call(@ex_remaining_on_loss.to_i, st_losses)
      ol_user = pct.call(@opponent_no_ol_wins.to_i, @total_wins_all.to_i)
      exol_cells = [
        dg_stat_cell.call("EXバースト残し敗北", ex_user, @community_ex_remaining_rate, false),
        dg_stat_cell.call("相手OL未発動で勝利", ol_user, @community_opp_no_ol_win_rate, true)
      ].compact
    %>
    <div class="st-cmpintro" style="margin-bottom:10px">
      <h2>サマリー</h2>
      <span class="m-eyebrow">勝率と、全体平均から見たあなたの特徴</span>
    </div>
    <div class="m-wrcard">
      <div class="m-wrcard-main">
        <div class="m-ring <%= "lo" if win_pct < 50 %>" style="--p: <%= win_pct %>">
          <div class="m-ring-c"><div class="pct"><%= win_pct %>%</div><div class="lbl">勝率</div></div>
        </div>
        <div class="m-wrcard-rec-wrap">
          <div class="m-wrcard-rec"><span class="m-num"><%= st_total %></span><span class="u">戦</span><span class="m-num"><%= st_wins %></span><span class="u">勝</span><span class="m-num"><%= st_losses %></span><span class="u">敗</span></div>
          <div class="m-wrcard-note">統計あり試合のみ</div>
        </div>
      </div>
      <div class="m-wrcard-form st-psum-form">
        <% if strength %>
          <div class="st-digest">
            <div>
              <div class="st-dg-seclabel">全体平均との比較</div>
              <div class="st-dg-grp"><%= raw hl_cells.join %></div>
            </div>
            <% if exol_cells.any? %>
              <div class="st-dg-sec">
                <div class="st-dg-seclabel">EXバースト・EXオーバーリミット</div>
                <div class="st-dg-grp"><%= raw exol_cells.join %></div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="cap"><h3>勝敗の内訳（統計あり試合）</h3></div>
          <div class="st-psum-bar">
            <div class="win" style="width:<%= win_pct %>%"></div>
            <div class="loss" style="width:<%= (st_total.positive? ? (100 - win_pct) : 0) %>%"></div>
          </div>
          <div class="st-psum-legend">
            <span class="w"><i></i>勝 <b><%= st_wins %></b></span>
            <span class="l"><i></i>敗 <b><%= st_losses %></b></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="st-cmpctl">
      <div class="cg">
        <span class="cl">比較対象</span>
        <div class="ui-segment">
          <% if has_self %>
            <button type="button" id="perf-btn-community" class="ui-segment-item ui-segment-item-active" onclick="setPerfCmpMode('community')">コミュニティ全体</button>
            <button type="button" id="perf-btn-self" class="ui-segment-item" onclick="setPerfCmpMode('self-overall')">自分</button>
          <% else %>
            <button type="button" class="ui-segment-item ui-segment-item-active">コミュニティ全体</button>
            <button type="button" class="ui-segment-item is-disabled" disabled>自分</button>
          <% end %>
        </div>
      </div>
      <% if has_same %>
        <div class="cg" id="perf-cost-range" style="display:none">
          <span class="cl sub">コスト範囲</span>
          <div class="ui-segment">
            <button type="button" id="perf-btn-allcost" class="ui-segment-item ui-segment-item-active" onclick="setPerfCmpMode('self-overall')">全コスト</button>
            <button type="button" id="perf-btn-samecost" class="ui-segment-item" onclick="setPerfCmpMode('same-cost')"><%= @same_cost_label %></button>
          </div>
        </div>
      <% end %>
      <% if has_self %>
        <span class="st-cmphint">「自分」＝絞り込みに関係ない自分の全試合平均</span>
      <% else %>
        <span class="st-cmphint-cta">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V18h6v-1.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg>
          <span><b>コスト・機体で絞り込む</b>と「自分」ボタンが押せるようになり、自分の平均とも比較できます</span>
        </span>
      <% end %>
    </div>
    <% if has_self %>
      <script>
        function setPerfCmpMode(mode) {
          var sec = document.getElementById('perf-cmp-table');
          if (sec) {
            ['community', 'self-overall', 'same-cost'].forEach(function (col) {
              sec.querySelectorAll("[data-perf-col='" + col + "']").forEach(function (el) { el.classList.toggle('hidden', mode !== col); });
            });
          }
          var isSelf = mode !== 'community';
          var A = 'ui-segment-item ui-segment-item-active', I = 'ui-segment-item';
          var c = document.getElementById('perf-btn-community'), s = document.getElementById('perf-btn-self');
          if (c) c.className = isSelf ? I : A;
          if (s) s.className = isSelf ? A : I;
          var row = document.getElementById('perf-cost-range');
          if (row) row.style.display = isSelf ? 'flex' : 'none';
          var ac = document.getElementById('perf-btn-allcost'), sm = document.getElementById('perf-btn-samecost');
          if (ac) ac.className = mode === 'self-overall' ? A : I;
          if (sm) sm.className = mode === 'same-cost' ? A : I;
        }
      </script>
    <% end %>

    <div id="perf-cmp-table">
      <% if @stats_losses.to_i.positive? || @has_ol_data %>
        <div class="st-cmpintro">
          <h2>EXシステム分析</h2>
          <span class="m-eyebrow">EXバースト・EXオーバーリミットの活用状況</span>
        </div>
      <% end %>

      <%# ===== EXバースト活用分析（敗北時）===== %>
      <% if @stats_losses.to_i.positive? %>
        <% ex_den = @stats_losses.to_i %>
        <div class="m-panel" style="margin-bottom:18px">
          <div class="m-phead"><h2>EXバースト分析</h2><span class="m-eyebrow">敗北 <%= ex_den %>戦のうち ・ EXを残さず使い切れたか（低いほど良い）</span></div>
          <%= raw ex_metric.call("EXバースト残し敗北", nil, @ex_remaining_on_loss, ex_den, @community_ex_remaining_rate, @community_ex_remaining_min, @community_ex_remaining_max, @user_overall_ex_remaining_rate, @user_same_cost_ex_remaining_rate, false, false) %>
          <%= raw ex_metric.call("自機が被撃墜", nil, @last_death_ex_on_loss, ex_den, @community_last_death_ex_rate, @community_last_death_ex_min, @community_last_death_ex_max, @user_overall_last_death_ex_rate, @user_same_cost_last_death_ex_rate, false, true) %>
          <%= raw ex_metric.call("パートナー機が被撃墜", nil, @survive_loss_ex_on_loss, ex_den, @community_survive_ex_rate, @community_survive_ex_min, @community_survive_ex_max, @user_overall_survive_ex_rate, @user_same_cost_survive_ex_rate, false, true) %>
        </div>
      <% end %>

      <%# ===== EXオーバーリミット分析（全試合）===== %>
      <% if @has_ol_data %>
        <div class="m-panel" style="margin-bottom:18px">
          <div class="m-phead"><h2>EXオーバーリミット分析</h2><span class="m-eyebrow">全試合のEXオーバーリミット発動状況</span></div>
          <% if @total_wins_all.to_i.positive? %>
            <%= raw ex_metric.call("相手OL未発動で勝利", "up", @opponent_no_ol_wins, @total_wins_all.to_i, @community_opp_no_ol_win_rate, @community_opp_no_ol_win_min, @community_opp_no_ol_win_max, @user_overall_opp_no_ol_win_rate, @user_same_cost_opp_no_ol_win_rate, true, false) %>
          <% end %>
          <% if @total_losses.to_i.positive? %>
            <%= raw ex_metric.call("自チームOL未発動で敗北", "down", @my_team_no_ol_losses, @total_losses.to_i, @community_no_ol_loss_rate, @community_no_ol_loss_min, @community_no_ol_loss_max, @user_overall_no_ol_loss_rate, @user_same_cost_no_ol_loss_rate, false, false) %>
          <% end %>
        </div>
      <% end %>

      <%# ===== パフォーマンス比較（カテゴリ別カード）===== %>
      <%
        perf_columns = [
          { perf: @performance_overall, n: @stats_total, label: "全体", c_avg: @community_avg, c_min: @community_min, c_max: @community_max, so: @user_overall_avg, sc: @user_same_cost_avg },
          { perf: @performance_wins, n: @stats_wins, label: "勝利時", c_avg: @community_wins_avg, c_min: @community_wins_min, c_max: @community_wins_max, so: @user_overall_wins, sc: @user_same_cost_wins },
          { perf: @performance_losses, n: @stats_losses, label: "敗北時", c_avg: @community_losses_avg, c_min: @community_losses_min, c_max: @community_losses_max, so: @user_overall_losses, sc: @user_same_cost_losses }
        ]
        group_span = 2 + (has_self ? 1 : 0) + (has_same ? 1 : 0)
        comparison_categories = [
          ["基本戦績", [
            { key: :score, label: "スコア", suffix: "", higher: true },
            { key: :kills, label: "撃墜数", suffix: " 機", higher: true },
            { key: :deaths, label: "被撃墜数", suffix: " 機", higher: false }
          ]],
          ["ダメージ", [
            { key: :damage_dealt, label: "与ダメージ", suffix: "", higher: true },
            { key: :damage_received, label: "被ダメージ", suffix: "", higher: false },
            { key: :exburst_damage, label: "EXバーストダメージ", suffix: "", higher: true }
          ]],
          ["EXバースト・オーバーリミット", [
            { key: :exburst_count, label: "EXバースト発動回数", suffix: " 回", higher: true },
            { key: :first_unit_exburst_count, label: "1機体目", suffix: " 回", higher: true, sub: true },
            { key: :later_unit_exburst_count, label: "2機体目以降", suffix: " 回", higher: true, sub: true },
            { key: :exburst_deaths, label: "EXバースト中 被撃墜数", suffix: " 機", higher: false },
            { key: :exburst_death_rate, label: "EXバースト中 被撃墜率", suffix: "%", higher: false, na: true },
            { key: :ol_rate, label: "EXオーバーリミット発動率", suffix: "%", higher: true }
          ]]
        ]
        # 全カードで共通のヘッダ（全体/勝利時/敗北時 × 値＋比較）
        cmp_thead = lambda do
          h = %(<tr><th rowspan="2" class="st-cmpname">項目</th>)
          perf_columns.each { |col| h += %(<th class="st-ghead st-gsep" colspan="#{group_span}">#{col[:label]}</th>) }
          h += %(</tr><tr>)
          perf_columns.each do |col|
            h += %(<th class="st-gsep">値<br><span class="font-normal">#{col[:n] || 0}試合</span></th>)
            h += %(<th data-perf-col="community">コミュニティ</th>)
            h += %(<th data-perf-col="self-overall" class="hidden">自分の全体平均</th>) if has_self
            h += %(<th data-perf-col="same-cost" class="hidden">#{@same_cost_label}</th>) if has_same
          end
          h += %(</tr>)
          h
        end
        # 1メトリクスの行
        metric_tr = lambda do |row|
          cells = %(<td class="st-cmpname#{row[:sub] ? " sub" : ""}">#{row[:sub] ? "└ #{row[:label]}" : row[:label]}</td>)
          perf_columns.each do |col|
            v = col[:perf]&.dig(row[:key])
            val = if col[:perf].nil? || (v.nil? && !row[:na]) then %(<span class="st-cdash">-</span>)
            elsif row[:na] && v.nil? then %(<span class="st-cna">N/A</span>)
            else %(#{fmt.call(v)}#{row[:suffix]}) end
            cells += %(<td class="st-cuser st-gsep">#{val}</td>)
            cells += cmp_variants.call("td", v, col[:c_avg]&.dig(row[:key]), col[:c_min]&.dig(row[:key]), col[:c_max]&.dig(row[:key]), col[:so]&.dig(row[:key]), col[:sc]&.dig(row[:key]), row[:higher], row[:suffix], row[:na])
          end
          %(<tr>#{cells}</tr>)
        end
        surv_by_label = { "全体" => Array(@survival_time_stats), "勝利時" => Array(@survival_time_stats_wins), "敗北時" => Array(@survival_time_stats_losses) }
        max_lives = surv_by_label.values.map(&:size).max.to_i
      %>

      <% if @stats_total.to_i.positive? %>
        <div class="st-cmpintro">
          <h2>パフォーマンス比較</h2>
          <div class="st-cmpleg"><span><i class="d"></i>あなた</span><span><i class="r"></i>比較対象の平均</span><span><i class="b"></i>分布（最小〜最大）</span></div>
        </div>

        <% comparison_categories.each do |title, rows| %>
          <div class="m-panel" style="margin-bottom:18px">
            <div class="m-phead"><h2><%= title %></h2></div>
            <div class="overflow-x-auto">
              <table class="ui-data-table">
                <thead><%= raw cmp_thead.call %></thead>
                <tbody><% rows.each do |row| %><%= raw metric_tr.call(row) %><% end %></tbody>
              </table>
            </div>
          </div>
        <% end %>

        <% if max_lives.positive? %>
          <div class="m-panel" style="margin-bottom:18px">
            <div class="m-phead"><h2>生存時間</h2><span class="m-eyebrow">撃墜されるまでの平均 ・ 長いほど良い</span></div>
            <div class="overflow-x-auto">
              <table class="ui-data-table">
                <thead><%= raw cmp_thead.call %></thead>
                <tbody>
                  <% max_lives.times do |i| %>
                    <tr>
                      <td class="st-cmpname"><%= i + 1 %>機体目</td>
                      <% perf_columns.each do |col| %>
                        <% died = surv_by_label[col[:label]][i]&.dig(:died) %>
                        <td class="st-cuser st-gsep"><%= format_survival_cs(died&.dig(:user_avg_cs)) || "<span class=\"st-cdash\">-</span>".html_safe %></td>
                        <%= raw surv_variants.call(died, i) %>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="m-panel"><div class="m-pbody"><p class="text-sm font-bold text-muted">統計ありの試合がありません</p></div></div>
      <% end %>
    </div>

  <% elsif @active_tab == "events" %>
    <% events_rows = @events_list || [] %>
    <% if events_rows.size > 1 %>
      <div class="m-panel" style="margin-bottom:18px">
        <div class="m-phead"><h2>イベント別 勝率推移</h2><span class="m-eyebrow">古い→新しい ・ 下段＝試合数</span></div>
        <div class="m-pbody"><%= st_line_chart.call(events_rows.reverse.map { |r| [r[:event].held_on.strftime("%-m/%-d"), r[:win_rate], "#{r[:total]}戦"] }) %></div>
      </div>
    <% end %>
    <div class="m-panel">
      <div class="m-phead"><h2>イベント別戦績</h2><span class="m-eyebrow">全<%= events_rows.size %>イベント</span></div>
      <%= render "statistics/stat_rows", rows: events_rows,
            name: ->(r) { r[:event].name },
            sub: ->(r) { ["#{r[:total]}戦 #{r[:wins]}勝#{r[:total] - r[:wins]}敗 ・ #{r[:event].held_on.strftime("%Y/%m/%d")}", "機体: #{list_text.call(r[:top_suits])}"] },
            empty_text: "対象イベントがありません" %>
    </div>

  <% elsif @active_tab == "event_progression" %>
    <% prog_list = @event_progression_list || [] %>
    <% if prog_list.empty? %>
      <div class="m-panel"><div class="m-pbody"><p class="text-sm font-bold text-muted">対象イベントがありません</p></div></div>
    <% else %>
      <div class="grid gap-5">
        <% prog_list.each do |event_row| %>
          <div class="m-panel">
            <div class="m-phead"><h2><%= event_row[:event].name %></h2><span class="m-eyebrow">総合勝率 <%= event_row[:overall_win_rate] %>% ・ <%= event_row[:total_matches] %>試合</span></div>
            <div class="grid gap-2 xl:grid-cols-2" style="padding-bottom:8px">
              <div>
                <div class="st-progsub">ローテーション別 成績<%= render "shared/info_tooltip", text: "イベント当日のローテーション（周回）ごとの勝率です。同じローテーションを複数回プレイした場合は合算します。会場が進むにつれ調子が出る/崩れる傾向を確認できます。" %></div>
                <div class="m-pbody"><%= st_line_chart.call(Array(event_row[:rotation_stats]).map { |r| [r[:rotation_name], r[:win_rate], "#{r[:total]}戦"] }) %></div>
              </div>
              <div>
                <div class="st-progsub">期間別 成績<%= render "shared/info_tooltip", text: "イベントの全試合を時系列で最大8区間（ターム）に均等分割し、序盤から終盤への勝率の推移を表します。8試合未満のときだけ区間数が減ります。" %></div>
                <div class="m-pbody"><%= st_line_chart.call(Array(event_row[:term_stats]).map { |r| [r[:rotation_name], r[:win_rate], "#{r[:total]}戦"] }) %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  <% elsif @active_tab == "mobile_suits" %>
    <%
      dmg = ->(v) { v ? number_with_delimiter(v) : "—" }
      # [key, ピル表示, ソート値, 行に出す表示文字列, 既定方向]
      suit_metrics = [
        ["total", "使用回数", ->(r) { r[:total] }, ->(r) { "使用 #{r[:total]}回" }, "desc"],
        ["winrate", "勝率", ->(r) { r[:win_rate] }, ->(r) { "勝率 #{r[:win_rate]}%" }, "desc"],
        ["dealt", "与ダメ", ->(r) { r[:avg_damage_dealt] || 0 }, ->(r) { "与ダメージ #{dmg.call(r[:avg_damage_dealt])}" }, "desc"],
        ["received", "被ダメ", ->(r) { r[:avg_damage_received] || 0 }, ->(r) { "被ダメージ #{dmg.call(r[:avg_damage_received])}" }, "asc"],
        ["exdmg", "EXダメ", ->(r) { r[:avg_exburst_damage] || 0 }, ->(r) { "EXバーストダメージ #{dmg.call(r[:avg_exburst_damage])}" }, "desc"],
        ["excount", "EX回数", ->(r) { r[:avg_exburst_count] || 0 }, ->(r) { "EXバースト発動 #{r[:avg_exburst_count] || "—"}回" }, "desc"],
        ["ol", "OL率", ->(r) { r[:ol_rate] || 0 }, ->(r) { "OL発動率 #{r[:ol_rate] ? "#{r[:ol_rate]}%" : "—"}" }, "desc"],
        ["life", "1機目生存", ->(r) { r[:first_life_cs] || 0 }, ->(r) { "1機目生存 #{format_survival_cs(r[:first_life_cs]) || "—"}" }, "desc"]
      ]
      suit_rows = @mobile_suits_list || []
    %>
    <div class="m-panel">
      <div class="m-phead"><h2>使用機体別戦績</h2><span class="m-eyebrow">全<%= suit_rows.size %>機体</span></div>
      <% if suit_rows.empty? %>
        <div class="m-pbody"><p class="text-sm font-bold text-muted">使用機体の記録がありません</p></div>
      <% else %>
        <div data-controller="sortable">
          <div class="st-sortbar st-sortbar-scroll">
            <span class="st-sortlab">並び替え</span>
            <% suit_metrics.each_with_index do |(key, label, _, _, dir), i| %>
              <button type="button" class="st-sortbtn <%= "is-active" if i.zero? %>" data-sortable-target="btn" data-key="<%= key %>" data-dir="<%= dir %>" data-action="sortable#sort"><%= label %><span class="st-sortdir"><%= "▼" if i.zero? %></span></button>
            <% end %>
          </div>
          <div data-sortable-target="list">
            <% suit_rows.each do |row| %>
              <% wr = row[:win_rate].to_f %>
              <div class="st-srow"<% suit_metrics.each do |key, _, sp, dp, _| %> data-sort-<%= key %>="<%= sp.call(row) %>" data-disp-<%= key %>="<%= dp.call(row) %>"<% end %>>
                <div class="st-srtop">
                  <span class="suit-thumb suit-thumb-sm"><% if row[:mobile_suit]&.image_filename.present? %><%= image_tag "/mobile_suits/#{row[:mobile_suit].image_filename}", alt: row[:mobile_suit].name, loading: "lazy" %><% end %></span>
                  <div class="st-srmeta">
                    <div class="st-srl1"><span class="st-srnm"><%= row[:mobile_suit]&.name || "-" %></span><span class="st-srwr <%= "neg" if wr < 50 %>"><%= row[:win_rate] %>%</span></div>
                    <div class="st-srsub"><div><%= row[:total] %>戦 <%= row[:wins] %>勝<%= row[:total] - row[:wins] %>敗 ・ 最終使用 <%= compact_date.call(row[:last_used_at]) %></div><div class="st-srmetric">使用 <%= row[:total] %>回</div></div>
                  </div>
                </div>
                <div class="st-winbar"><div class="wfill <%= "neg" if wr < 50 %>" style="width:<%= wr %>%"></div><div class="ref50"></div></div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @active_tab == "opponent_suits" %>
    <div class="m-panel">
      <div class="m-phead"><h2>対戦機体別戦績</h2><span class="m-eyebrow">全<%= (@opponent_suits_list || []).size %>機体 ・ 対戦回数順</span></div>
      <%= render "statistics/stat_rows", rows: @opponent_suits_list || [],
            thumb: ->(r) { r[:mobile_suit] },
            name: ->(r) { r[:mobile_suit]&.name || "-" },
            sub: ->(r) { ["#{r[:total]}戦 #{r[:wins]}勝#{r[:total] - r[:wins]}敗", "最終対戦 #{compact_date.call(r[:last_faced_at])}"] },
            sorts: [["total", "対戦回数", ->(r) { r[:total] }], ["winrate", "勝率", ->(r) { r[:win_rate] }]],
            empty_text: "対戦機体の記録がありません" %>
    </div>

  <% elsif @active_tab == "partners" %>
    <div class="m-panel">
      <div class="m-phead"><h2>パートナー別戦績</h2><span class="m-eyebrow">全<%= (@partners_list || []).size %>人 ・ 勝率順</span></div>
      <%= render "statistics/stat_rows", rows: @partners_list || [],
            name: ->(r) { r[:user].nickname },
            sub: ->(r) { ["#{r[:total]}戦 #{r[:wins]}勝#{r[:total] - r[:wins]}敗", "よく組む: #{list_text.call(r[:top_combinations])}"] },
            sorts: [["winrate", "勝率", ->(r) { r[:win_rate] }], ["total", "対戦回数", ->(r) { r[:total] }]],
            empty_text: "パートナーの記録がありません" %>
    </div>

  <% elsif @active_tab == "opponents" %>
    <div class="m-panel">
      <div class="m-phead"><h2>対戦相手別戦績</h2><span class="m-eyebrow">全<%= (@opponents_list || []).size %>人 ・ 対戦回数順</span></div>
      <%= render "statistics/stat_rows", rows: @opponents_list || [],
            name: ->(r) { r[:user].nickname },
            sub: ->(r) { ["#{r[:total]}戦 #{r[:wins]}勝#{r[:total] - r[:wins]}敗", "使用機体: #{list_text.call(r[:top_suits])}"] },
            sorts: [["total", "対戦回数", ->(r) { r[:total] }], ["winrate", "勝率", ->(r) { r[:win_rate] }]],
            empty_text: "対戦相手の記録がありません" %>
    </div>
  <% end %>
</div>
