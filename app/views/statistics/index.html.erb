<%
  # 論理タブ（モック準拠の7タブ）。members は内部の controller タブ（セグメントで切替）
  tabs = [
    ["overview",    "総合",        "personal",  ["overview"]],
    ["performance", "プレイ分析",   "personal",  ["performance"]],
    ["suits",       "機体別",      "personal",  ["mobile_suits", "opponent_suits"]],
    ["people",      "プレイヤー別",  "personal",  ["partners", "opponents"]],
    ["events",      "イベント別",   "personal",  ["events", "event_progression"]],
    ["highlights",  "ダイジェスト",  "community", ["highlights"]],
    ["c_solo",      "ソロ",        "community", ["overall_solo"]],
    ["c_team",      "チーム",       "community", ["overall_team"]]
  ]
  active_logical = tabs.find { |_, _, _, members| members.include?(@active_tab) } || tabs.first
  tab_path = ->(key) {
    statistics_path(
      tab: key,
      view_user_id: params[:view_user_id],
      events: params[:events],
      mobile_suits: params[:mobile_suits],
      partners: params[:partners],
      costs: params[:costs]
    )
  }
  active_tab_label = active_logical[1]
  base_filters = {
    tab: @active_tab,
    view_user_id: params[:view_user_id],
    events: @filter_events,
    mobile_suits: @filter_mobile_suits,
    partners: @filter_partners,
    costs: @filter_costs
  }
  toggle_filter = ->(key, value) {
    current = Array(base_filters[key])
    next_value = current.include?(value) ? current - [value] : current + [value]
    statistics_path(base_filters.merge(key => next_value))
  }
  compact_date = ->(time) { time ? time.strftime("%Y/%m/%d") : "-" }
  list_text = ->(items) {
    Array(items).first(3).map { |name, count| "#{name} #{count}回" }.join(" / ").presence || "-"
  }
  # CSS 折れ線グラフ（data: [[label, rate, sub], ...]）
  st_line_chart = ->(data) {
    n = data.size
    next %(<div class="m-pbody"><p class="text-sm font-bold text-muted">データがありません</p></div>).html_safe if n.zero?
    xpos = ->(i) { n == 1 ? 50.0 : (i.to_f / (n - 1) * 100) }
    poly = data.each_with_index.map { |(_, rate), i| "#{xpos.call(i).round(2)},#{(100 - rate.to_f).round(2)}" }.join(" ")
    dots = data.each_with_index.map { |(label, rate, sub), i|
      x = xpos.call(i).round(2); r = rate.to_f
      sub_html = sub ? %(<span style="display:block;opacity:.75;font-size:9px">#{sub}</span>) : ""
      %(<span class="st-lp" style="left:#{x}%;bottom:#{r}%"></span>) +
      %(<span class="st-lv" style="left:#{x}%;bottom:calc(#{r}% + 9px)">#{rate}%</span>) +
      %(<span class="st-lx" style="left:#{x}%">#{label}#{sub_html}</span>)
    }.join
    (%(<div class="st-linechart"><div class="st-lplot"><svg viewBox="0 0 100 100" preserveAspectRatio="none"><line class="st-l50" x1="0" y1="50" x2="100" y2="50"/><polyline class="st-lpoly" points="#{poly}"/></svg>#{dots}<span class="st-l50lbl" style="top:50%">50%</span></div></div>)).html_safe
  }
%>

<div class="ui-page">
  <div class="m-pagehead">
    <div>
      <h1>統計</h1>
      <div class="m-sub"><%= viewing_as_user.nickname %> 視点の詳細な戦績データを確認できます。</div>
    </div>
  </div>

  <% unless current_user.is_admin %>
    <div class="st-userbar">
      <span class="lab">ユーザー</span>
      <%= link_to "#{current_user.nickname}（自分）", statistics_path(tab: @active_tab), class: class_names("st-chip", viewing_as_user.id == current_user.id && "on") %>
      <% @regular_users.reject { |u| u.id == current_user.id }.each do |user| %>
        <%= link_to user.nickname, statistics_path(view_user_id: user.id, tab: @active_tab), class: class_names("st-chip", viewing_as_user.id == user.id && "on") %>
      <% end %>
    </div>
  <% end %>

  <%# エリア切替（自分の統計 / 全体コミュニティ）%>
  <% personal_tabs = tabs.select { |_, _, a, _| a == "personal" } %>
  <% community_tabs = tabs.select { |_, _, a, _| a == "community" } %>
  <% area = active_logical[2] %>
  <div class="st-primary">
    <% if viewing_as_user.is_guest %>
      <%= link_to "自分", "#", class: "is-disabled", aria: { disabled: true } %>
    <% else %>
      <%= link_to "自分", tab_path.call(personal_tabs.first[3].first), class: class_names(area == "personal" && "on") %>
    <% end %>
    <%= link_to "全体（コミュニティ）", tab_path.call(community_tabs.first[3].first), class: class_names(area == "community" && "on") %>
  </div>

  <%# エリア内のタブ（横スクロールのピル）%>
  <% shown_tabs = area == "personal" ? personal_tabs : community_tabs %>
  <div class="st-tabs">
    <% shown_tabs.each do |key, label, _, members| %>
      <%= link_to label, tab_path.call(members.first), class: class_names("st-tab", members.include?(@active_tab) && "on") %>
    <% end %>
  </div>

  <% active_filter_count = [@filter_events, @filter_partners, @filter_costs, @filter_mobile_suits].sum(&:size) %>
  <div class="m-panel st-filterpanel" data-controller="filter-toggle" style="margin-bottom:18px">
    <div class="st-filterhead">
      <button type="button" class="st-filtertoggle" data-action="filter-toggle#toggle" aria-label="絞り込みの開閉">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16M7 12h10M10 19h4"/></svg>
        <span>絞り込み</span>
        <% if active_filter_count.positive? %><span class="st-filtercount"><%= active_filter_count %></span><% end %>
        <svg class="chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <% if active_filter_count.positive? %>
        <%= link_to "すべてクリア", statistics_path(tab: @active_tab, view_user_id: params[:view_user_id]), class: "st-filterclear" %>
      <% end %>
    </div>
    <div class="st-filterbody" data-filter-toggle-target="body">
    <% if @active_tab.in?(%w[overall_solo overall_team highlights overview]) %>
      <div class="st-frow">
        <span class="lab">イベント</span>
        <%= link_to "全イベント", statistics_path(tab: @active_tab), class: class_names("st-chip", @filter_events.empty? && "on") %>
        <% @all_events.each do |event| %>
          <%= link_to event.name, statistics_path(tab: @active_tab, events: [event.id]), class: class_names("st-chip", @filter_events == [event.id] && "on") %>
        <% end %>
      </div>
    <% else %>
      <div class="st-filters">
        <div class="st-frow">
          <span class="lab">イベント</span>
          <%= link_to "全イベント", statistics_path(base_filters.merge(events: [])), class: class_names("st-chip", @filter_events.empty? && "on") %>
          <% @all_events.each do |event| %>
            <%= link_to event.name, toggle_filter.call(:events, event.id), class: class_names("st-chip", @filter_events.include?(event.id) && "on") %>
          <% end %>
        </div>

        <div class="st-frow">
          <span class="lab">パートナー</span>
          <%= link_to "全員", statistics_path(base_filters.merge(partners: [])), class: class_names("st-chip", @filter_partners.empty? && "on") %>
          <% @all_partners.each do |partner| %>
            <%= link_to partner.nickname, toggle_filter.call(:partners, partner.id), class: class_names("st-chip", @filter_partners.include?(partner.id) && "on") %>
          <% end %>
        </div>

        <div class="st-frow">
          <span class="lab">機体・コスト</span>
          <div class="ui-segment flex-wrap">
            <%= link_to "全体", statistics_path(base_filters.merge(costs: [], mobile_suits: [])), class: class_names("ui-segment-item", @filter_costs.empty? && @filter_mobile_suits.empty? && "ui-segment-item-active") %>
            <% [3000, 2500, 2000, 1500].each do |cost| %>
              <%= link_to cost.to_s, statistics_path(base_filters.merge(costs: [cost], mobile_suits: [])), class: class_names("cost-badge", "cost-badge-#{cost}", @filter_costs == [cost] && "shadow-card") %>
            <% end %>
          </div>
          <div class="min-w-56 flex-1 sm:max-w-xs">
            <select id="stat-suit-select" class="ui-form-control"
                    data-controller="suit-select"
                    data-has-favorites="<%= viewing_as_user&.user_favorite_suits&.any? %>"
                    data-suit-select-clear-cost-value="true">
              <option value="">機体を検索...</option>
              <% visible_suits = @filter_costs.any? ? @all_mobile_suits.select { |s| @filter_costs.include?(s.cost) } : @all_mobile_suits %>
              <%= mobile_suit_options_with_favorites(visible_suits, viewing_as_user, @filter_mobile_suits) %>
            </select>
          </div>
        </div>
      </div>
    <% end %>
    </div>
  </div>

  <%# 統合タブ（機体別/プレイヤー別/イベント別）のサブ切替 %>
  <% if active_logical[3].size > 1 %>
    <% member_labels = { "mobile_suits" => "使用機体", "opponent_suits" => "対戦機体", "partners" => "パートナー", "opponents" => "対戦相手", "events" => "イベント一覧", "event_progression" => "イベント内推移" } %>
    <div class="ui-segment mb-4">
      <% active_logical[3].each do |member| %>
        <%= link_to member_labels[member], tab_path.call(member), class: class_names("ui-segment-item", @active_tab == member && "ui-segment-item-active") %>
      <% end %>
    </div>
  <% end %>

  <% if @active_tab == "overall_solo" %>
    <%# === ソロ：単体ランキング（指標切替）＋ コスト別勝率 === %>
    <div class="m-panel st-rankcard" data-controller="tab-switch">
      <div class="m-phead"><h2>機体ランキング（ソロ）</h2></div>
      <div class="st-segbar">
        <button type="button" class="st-seg on" data-tab-switch-target="btn" data-key="dominant" data-action="tab-switch#select">環境支配</button>
        <button type="button" class="st-seg" data-tab-switch-target="btn" data-key="popular" data-action="tab-switch#select">人気</button>
        <button type="button" class="st-seg" data-tab-switch-target="btn" data-key="winrate" data-action="tab-switch#select">高勝率</button>
      </div>
      <div data-tab-switch-target="panel" data-key="dominant">
        <div class="st-segcap">環境支配度（勝率 × 使用数）の高い順</div>
        <%= render "statistics/rank_rows", rows: @dominant_suits || [], limit: 10, thumb: ->(r) { r[:mobile_suit] },
              name: ->(r) { r[:mobile_suit]&.name || "-" }, sub: ->(r) { "使用#{number_with_delimiter(r[:total])} ・ 勝率#{r[:win_rate]}%" },
              value: ->(r) { number_with_delimiter(r[:dominance].to_i) }, bar: ->(r) { r[:dominance] } %>
      </div>
      <div data-tab-switch-target="panel" data-key="popular" hidden>
        <div class="st-segcap">使用回数の多い順</div>
        <%= render "statistics/rank_rows", rows: @popular_suits || [], limit: 10, thumb: ->(r) { r[:mobile_suit] },
              name: ->(r) { r[:mobile_suit]&.name || "-" }, sub: ->(r) { "使用率#{r[:usage_rate]}%" },
              value: ->(r) { "#{number_with_delimiter(r[:usage_count])}回" }, bar: ->(r) { r[:usage_count] } %>
      </div>
      <div data-tab-switch-target="panel" data-key="winrate" hidden>
        <div class="st-segcap">勝率の高い順（5戦以上）</div>
        <%= render "statistics/rank_rows", rows: @high_winrate_suits || [], limit: 10, thumb: ->(r) { r[:mobile_suit] },
              name: ->(r) { r[:mobile_suit]&.name || "-" }, sub: ->(r) { "#{number_with_delimiter(r[:wins])}勝#{number_with_delimiter(r[:total] - r[:wins])}敗" },
              value: ->(r) { "#{r[:win_rate]}%" }, bar: ->(r) { r[:win_rate] }, bar_full: 100, neg: ->(r) { r[:win_rate].to_f < 50 } %>
      </div>
    </div>

    <div class="m-panel">
      <div class="m-phead"><h2>コスト別使用率・勝率</h2></div>
      <% if (@cost_stats || []).empty? %>
        <div class="m-pbody"><p class="text-sm font-bold text-muted">データがありません</p></div>
      <% else %>
        <div class="st-costcols">
          <div class="st-costcol">
            <div class="st-segcap">使用率</div>
            <%= render "statistics/cost_donut", rows: @cost_stats %>
          </div>
          <div class="st-costcol">
            <div class="st-segcap">勝率</div>
            <div class="st-cwlist">
              <% @cost_stats.each do |row| %>
                <% neg = row[:win_rate].to_f < 50 %>
                <div class="st-cwrow">
                  <%= cost_badge(row[:cost]) %>
                  <div class="st-cwbar"><span class="ref"></span><div class="fill <%= "neg" if neg %>" style="width:<%= row[:win_rate] %>%"></div></div>
                  <span class="st-cwv <%= "neg" if neg %>"><%= row[:win_rate] %>%</span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @active_tab == "overall_team" %>
    <%# === チーム：ペアランキング（指標切替）＋ コストペア別勝率（三角マトリクス）=== %>
    <div class="m-panel st-rankcard" data-controller="tab-switch">
      <div class="m-phead"><h2>機体ランキング（チーム）</h2><span class="m-eyebrow">同チーム2機</span></div>
      <div class="st-segbar">
        <button type="button" class="st-seg on" data-tab-switch-target="btn" data-key="dominant" data-action="tab-switch#select">環境支配</button>
        <button type="button" class="st-seg" data-tab-switch-target="btn" data-key="popular" data-action="tab-switch#select">人気</button>
        <button type="button" class="st-seg" data-tab-switch-target="btn" data-key="winrate" data-action="tab-switch#select">高勝率</button>
      </div>
      <div data-tab-switch-target="panel" data-key="dominant">
        <div class="st-segcap">環境支配度（勝率 × 使用数）の高い順</div>
        <%= render "statistics/rank_rows", rows: @dominant_pairs || [], limit: 10, thumb: ->(r) { r[:mobile_suits] },
              name: ->(r) { r[:mobile_suits].map { |s| s&.name || "-" }.join(" ＋ ") }, sub: ->(r) { "使用#{number_with_delimiter(r[:total])} ・ 勝率#{r[:win_rate]}%" },
              value: ->(r) { number_with_delimiter(r[:dominance].to_i) }, bar: ->(r) { r[:dominance] } %>
      </div>
      <div data-tab-switch-target="panel" data-key="popular" hidden>
        <div class="st-segcap">使用回数の多い順</div>
        <%= render "statistics/rank_rows", rows: @popular_pairs || [], limit: 10, thumb: ->(r) { r[:mobile_suits] },
              name: ->(r) { r[:mobile_suits].map { |s| s&.name || "-" }.join(" ＋ ") }, sub: ->(r) { "勝率#{r[:win_rate]}%" },
              value: ->(r) { "#{number_with_delimiter(r[:usage_count])}回" }, bar: ->(r) { r[:usage_count] } %>
      </div>
      <div data-tab-switch-target="panel" data-key="winrate" hidden>
        <div class="st-segcap">勝率の高い順（3戦以上）</div>
        <%= render "statistics/rank_rows", rows: @high_winrate_pairs || [], limit: 10, thumb: ->(r) { r[:mobile_suits] },
              name: ->(r) { r[:mobile_suits].map { |s| s&.name || "-" }.join(" ＋ ") }, sub: ->(r) { "#{number_with_delimiter(r[:total])}戦・#{number_with_delimiter(r[:wins])}勝" },
              value: ->(r) { "#{r[:win_rate]}%" }, bar: ->(r) { r[:win_rate] }, bar_full: 100, neg: ->(r) { r[:win_rate].to_f < 50 } %>
      </div>
    </div>

    <div class="m-panel">
      <div class="m-phead"><h2>コストペア別 使用率・勝率</h2><span class="m-eyebrow">同チーム2機のコスト組合せ</span></div>
      <% cp_mtx = {} %>
      <% (@cost_pair_stats || []).each { |r| cp_mtx[r[:costs]] = r } %>
      <% if cp_mtx.values.sum { |r| r[:total] }.zero? %>
        <div class="m-pbody"><p class="text-sm font-bold text-muted">データがありません</p></div>
      <% else %>
        <% costs = [3000, 2500, 2000, 1500] %>
        <div class="st-costcols">
          <div class="st-costcol">
            <div class="st-segcap">使用率</div>
            <%= render "statistics/cost_pair_matrix", cp_mtx: cp_mtx, costs: costs, metric: :usage %>
          </div>
          <div class="st-costcol">
            <div class="st-segcap">勝率</div>
            <%= render "statistics/cost_pair_matrix", cp_mtx: cp_mtx, costs: costs, metric: :winrate %>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @active_tab == "highlights" %>
    <%
      hl_icons = {
        bolt: %(<svg viewBox="0 0 24 24"><path d="M13 3L4 14h6l-1 7 9-11h-6z"/></svg>),
        star: %(<svg viewBox="0 0 24 24"><path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z"/></svg>),
        shield: %(<svg viewBox="0 0 24 24"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/></svg>),
        clock: %(<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2"/></svg>)
      }
      esc = ->(s) { ERB::Util.html_escape(s) }
      # 対戦カード（team1 vs team2、勝利側を強調）
      vs_html = ->(match) {
        t1 = match.match_players.select { |p| p.team_number == 1 }.sort_by(&:position)
        t2 = match.match_players.select { |p| p.team_number == 2 }.sort_by(&:position)
        names = ->(team) { team.map { |p| "#{p.user.nickname}（#{p.mobile_suit.name}）" }.join(" & ") }
        c1 = match.winning_team == 1 ? "win" : ""
        c2 = match.winning_team == 2 ? "win" : ""
        %(<div class="st-hlvs"><span class="#{c1}">#{esc.call(names.call(t1))}</span><span class="vs">vs</span><span class="#{c2}">#{esc.call(names.call(t2))}</span></div>)
      }
      hl_card = ->(label, icon, value, mp, match) {
        head = %(<div class="st-hlhead"><div class="ic">#{hl_icons[icon]}</div><div class="t">#{esc.call(label)}</div></div>)
        next %(<div class="st-hlcard">#{head}<div class="st-hlempty">データがありません</div></div>).html_safe if value.nil? || match.nil?
        player = mp ? %(<div class="st-hlplayer"><span>#{esc.call(mp.user.nickname)}</span><span class="dot">・</span>#{link_to(esc.call(mp.mobile_suit.name), mobile_suit_path(mp.mobile_suit), class: "st-hlsuit")}#{cost_badge(mp.mobile_suit.cost)}</div>) : ""
        video = match.video_url ? render("shared/broadcast_link", url: match.video_url, link_class: "st-hlvideo") : ""
        foot = %(<div class="st-hlfoot">) +
          link_to("試合詳細 →", match_path(match), class: "st-hllink") +
          %(<span class="st-hlev">#{esc.call(match.event.name)} ・ #{match.played_at.strftime("%-m/%-d")}</span>) +
          video.to_s + %(</div>)
        %(<div class="st-hlcard">#{head}<div class="v">#{value}</div>#{player}#{vs_html.call(match)}#{foot}</div>).html_safe
      }
    %>
    <div class="st-secdiv"><span>ハイライト</span></div>

    <div class="st-hlgrid">
      <%= hl_card.call("最多与ダメージ", :bolt, @highlight_most_damage && number_with_delimiter(@highlight_most_damage.damage_dealt), @highlight_most_damage, @highlight_most_damage&.match) %>
      <%= hl_card.call("最多EXバーストダメージ", :bolt, @highlight_most_exburst_damage && number_with_delimiter(@highlight_most_exburst_damage.exburst_damage), @highlight_most_exburst_damage, @highlight_most_exburst_damage&.match) %>
      <%= hl_card.call("最も激しい試合", :bolt, @highlight_most_intense_total && number_with_delimiter(@highlight_most_intense_total), nil, @highlight_most_intense_match) %>
      <%= hl_card.call("最少被ダメージ（勝利）", :shield, @highlight_min_damage_received && number_with_delimiter(@highlight_min_damage_received.damage_received), @highlight_min_damage_received, @highlight_min_damage_received&.match) %>
      <%= hl_card.call("最長 1機目 生存", :clock, format_survival_cs(@highlight_longest_first_life_cs), @highlight_longest_first_life, @highlight_longest_first_life&.match) %>
      <%= hl_card.call("最短 1機目 生存", :clock, format_survival_cs(@highlight_shortest_first_life_cs), @highlight_shortest_first_life, @highlight_shortest_first_life&.match) %>
      <%= hl_card.call("最高スコア", :star, @highlight_top_score && number_with_delimiter(@highlight_top_score.score), @highlight_top_score, @highlight_top_score&.match) %>
      <%= hl_card.call("最長試合時間", :clock, format_survival_cs(@highlight_longest_match_cs), nil, @highlight_longest_match) %>
      <%= hl_card.call("最短試合時間", :clock, format_survival_cs(@highlight_shortest_match_cs), nil, @highlight_shortest_match) %>
    </div>

    <%# === コミュニティ開催実績（旧イベントタブを統合）=== %>
    <div class="st-secdiv"><span>コミュニティ開催実績</span></div>

    <div class="st-statgrid">
      <div class="st-statcard">
        <div class="st-staticon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 17.5 3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="m16 16 4 4"/><path d="M19 21l2-2"/><path d="M14.5 6.5 18 3h3v3l-3.5 3.5"/><path d="m5 14 6 6"/><path d="M3 21l2-2"/></svg></div>
        <div class="st-statbody"><div class="st-statv"><%= number_with_delimiter(@overall_total_matches || 0) %></div><div class="st-statk">総試合数</div></div>
      </div>
      <div class="st-statcard">
