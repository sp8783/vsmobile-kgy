<div class="ui-page mx-auto max-w-4xl">
  <div class="ui-page-header">
    <div>
      <%= link_to "対戦詳細に戻る", match_path(@match), class: "ui-btn ui-btn-ghost mb-4" %>
      <p class="ui-eyebrow">Match Stats</p>
      <h1 class="ui-title">対戦統計 編集</h1>
      <p class="ui-subtitle"><%= @match.event.name %> ・ <%= @match.played_at.strftime("%Y年%m月%d日") %></p>
    </div>
  </div>

  <%= form_with url: match_stats_path(@match), method: :patch, class: "space-y-5" do |form| %>
    <% if flash[:alert] %>
      <div class="ui-alert ui-alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <section class="ui-card p-5" data-controller="match-timeline-editor">
      <h2 class="text-lg font-black text-ink">ワークフロー JSON</h2>
      <p class="mt-2 text-sm font-bold text-muted">
        ワークフロー JSON をそのまま貼り付けて保存してください。プレイヤー統計・チームフラグ・タイムラインが自動投入されます。空にすると全データが削除されます。
      </p>

      <%= text_area_tag "match_timeline[timeline_raw_text]",
          (@match_timeline.persisted? ? JSON.pretty_generate(@match_timeline.timeline_raw) : ""),
          rows: 16,
          placeholder: '{"team_a": {...}, "team_b": {...}, "timeline_raw": {...}, ...}',
          class: "ui-form-control mt-4 font-mono text-xs",
          data: { "match-timeline-editor-target": "input", action: "input->match-timeline-editor#preview" } %>

      <div class="mt-3 hidden text-xs font-bold text-neg" data-match-timeline-editor-target="error"></div>

      <div class="mt-4 hidden" data-match-timeline-editor-target="preview">
        <p class="mb-2 text-xs font-black text-subtle">プレビュー</p>
        <div data-controller="match-timeline"
             data-match-timeline-json-value=""
             data-match-timeline-editor-target="chart"
             class="overflow-x-auto rounded-lg bg-ink">
        </div>
      </div>
    </section>

    <div class="flex flex-wrap items-center justify-between gap-3">
      <%= link_to "統計データを全削除",
          match_stats_path(@match),
          data: { turbo_method: :delete, turbo_confirm: "この試合の統計データをすべて削除してもよろしいですか？" },
          class: "ui-btn ui-btn-danger" %>

      <div class="flex flex-wrap gap-3">
        <%= link_to "キャンセル", match_path(@match), class: "ui-btn ui-btn-secondary" %>
        <%= submit_tag "保存", class: "ui-btn ui-btn-primary cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
