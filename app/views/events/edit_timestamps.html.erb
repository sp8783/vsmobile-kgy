<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <%= link_to "イベントに戻る", event_path(@event), class: "ui-btn ui-btn-ghost mb-4" %>
      <p class="ui-eyebrow">Timestamp</p>
      <h1 class="ui-title"><%= @event.name %></h1>
      <p class="ui-subtitle">タイムスタンプ一括設定</p>
    </div>
  </div>

  <% if flash[:alert] %>
    <div class="ui-alert ui-alert-danger mb-5">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: update_timestamps_event_path(@event), method: :patch, local: true do |f| %>
    <div class="grid gap-5 md:grid-cols-2">
      <section class="ui-card p-5">
        <label for="timestamps" class="ui-label">タイムスタンプ（1行1試合）</label>
        <textarea
          name="timestamps"
          id="timestamps"
          class="ui-form-control h-96 resize-none font-mono text-sm"
          placeholder="0:03:20&#10;0:07:45&#10;0:12:10"
        ><%= @timestamps_text %></textarea>
        <p class="mt-2 text-sm font-bold text-subtle">
          配信開始からの経過時間を1行1試合で入力してください（例: 0:03:20）。
        </p>
      </section>

      <section class="ui-card p-5">
        <h2 class="mb-3 text-sm font-black text-ink">試合一覧（<%= @matches.size %>試合）</h2>
        <div class="h-96 space-y-2 overflow-y-auto text-sm">
          <% @matches.each_with_index do |match, i| %>
            <% team1 = match.match_players.select { |p| p.team_number == 1 }.sort_by(&:position) %>
            <% team2 = match.match_players.select { |p| p.team_number == 2 }.sort_by(&:position) %>
            <div class="flex items-start gap-3 rounded-lg bg-bg px-3 py-2 shadow-inner-soft">
              <span class="w-7 shrink-0 text-right font-mono text-subtle"><%= i + 1 %>.</span>
              <div class="min-w-0 flex-1">
                <span class="<%= match.winning_team == 1 ? 'font-black text-accent' : 'font-bold text-muted' %>">
                  <%= team1.map { |p| p.user.nickname }.join(" & ") %>
                </span>
                <span class="mx-2 text-subtle">VS</span>
                <span class="<%= match.winning_team == 2 ? 'font-black text-accent' : 'font-bold text-muted' %>">
                  <%= team2.map { |p| p.user.nickname }.join(" & ") %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    </div>

    <div class="mt-5 flex flex-wrap gap-3">
      <%= f.submit "保存", class: "ui-btn ui-btn-primary cursor-pointer" %>
      <%= link_to "キャンセル", event_path(@event), class: "ui-btn ui-btn-secondary" %>
    </div>
  <% end %>
</div>
