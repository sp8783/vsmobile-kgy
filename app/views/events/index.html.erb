<div class="m-pagehead">
  <div>
    <h1>イベント一覧</h1>
    <div class="m-sub">イベントの管理と試合記録の閲覧ができます。</div>
  </div>
  <% if current_user.is_admin? %>
    <%= link_to "新規作成", new_event_path, class: "m-btn m-btn-primary" %>
  <% end %>
</div>

<% if @events.any? %>
  <div class="dtbl-card">
    <div class="dtbl-bar">
      <div class="cnt">全 <b><%= @events.size %></b> 件</div>
    </div>
    <div class="dtbl-scroll">
      <table class="dtbl">
        <thead>
          <tr>
            <th>イベント名</th>
            <th>配信</th>
            <th>開催日</th>
            <th>説明</th>
            <th>試合数</th>
            <th class="right">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr data-controller="card-link"
                data-card-link-url-value="<%= event_path(event) %>"
                data-action="click->card-link#navigate">
              <td class="name" data-l="イベント名"><span class="lnk"><%= event.name %></span></td>
              <td data-l="配信">
                <% if event.broadcast_url.present? %>
                  <%= render "shared/broadcast_link", url: event.broadcast_url, link_class: "ev-chip-yt" %>
                <% else %>
                  <span class="text-subtle">-</span>
                <% end %>
              </td>
              <td data-l="開催日"><span class="m-num"><%= event.held_on.strftime("%Y/%m/%d") %></span></td>
              <td class="muted" data-l="説明"><%= event.description.presence || "-" %></td>
              <td class="muted" data-l="試合数"><span class="m-num"><%= event.matches.count %></span> 件</td>
              <td class="actions" data-l="操作">
                <div class="rowact">
                  <% if current_user.is_admin? %>
                    <%= link_to "編集", edit_event_path(event), class: "m-btn-ghost" %>
                    <%= button_to "削除", event, method: :delete, class: "m-btn-ghost", style: "color:var(--color-neg)", data: { turbo_confirm: "イベント「#{event.name}」を削除してもよろしいですか？関連する試合やローテーションもすべて削除されます。" } %>
                  <% else %>
                    <%= link_to "詳細", event_path(event), class: "m-btn-ghost" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="m-panel m-pbody">
    <h2 class="text-lg font-black text-ink">イベントがありません</h2>
    <% if current_user.is_admin? %>
      <p class="mt-2 text-sm font-bold text-muted">新規作成ボタンからイベントを作成してください。</p>
      <div class="mt-4"><%= link_to "最初のイベントを作成", new_event_path, class: "m-btn m-btn-primary" %></div>
    <% else %>
      <p class="mt-2 text-sm font-bold text-muted">管理者によってイベントが作成されるとここに表示されます。</p>
    <% end %>
  </div>
<% end %>
