<%= link_to "← イベント一覧に戻る", events_path, class: "md-backlink" %>

<%# ===== hero ===== %>
<div class="ev-hero">
  <div class="ev-title">
    <h1><%= @event.name %></h1>
    <% if @event.broadcast_url.present? %>
      <%= render "shared/broadcast_link", url: @event.broadcast_url, link_class: "ev-chip-yt" %>
      <% if current_user.is_admin? %>
        <%= button_to post_broadcast_to_discord_event_path(@event), method: :post, class: "ev-chip-dc", data: { turbo_confirm: "「#{@event.name}」の配信URLをDiscordへ投稿しますか？" } do %>
          <%= image_tag "/discord_logo_blurple.png", alt: "Discord" %>Discordへ共有
        <% end %>
      <% end %>
    <% end %>
  </div>
  <div class="ev-date"><%= @event.held_on.strftime("%Y年%m月%d日") %></div>
  <% if @event.description.present? %>
    <div class="ev-desc"><%= @event.description %></div>
  <% end %>

  <% if current_user.is_admin? %>
    <div class="ev-acts">
      <%= link_to "試合を登録", new_event_match_path(@event), class: "m-btn m-btn-primary" %>
      <%= link_to "ローテーション作成", new_event_rotation_path(@event), class: "m-btn m-btn-primary" %>
      <% if @event.broadcast_url.present? %>
        <%= link_to "タイムスタンプ一括設定", edit_timestamps_event_path(@event), class: "m-btn-ghost" %>
        <%= button_to "タイムスタンプ解析開始", trigger_analysis_event_path(@event), method: :post, class: "m-btn-ghost", data: { turbo_confirm: "GitHub Actions で動画解析を開始しますか？完了後にタイムスタンプが自動登録されます。" } %>
      <% end %>
      <%= button_to "統計取得開始", trigger_scraping_event_path(@event), method: :post, class: "m-btn-ghost", data: { turbo_confirm: "GitHub Actions で統計スクレイピングを開始しますか？完了後に統計データが自動登録されます。" } %>
      <%= link_to "編集", edit_event_path(@event), class: "m-btn-ghost" %>
      <%= button_to "削除", event_path(@event), method: :delete, class: "m-btn-ghost", style: "color:var(--color-neg)", data: { turbo_confirm: "イベント「#{@event.name}」を削除してもよろしいですか？関連する試合やローテーションもすべて削除されます。" } %>
    </div>
  <% end %>
</div>

<%# ===== ローテーション ===== %>
<div class="m-panel" style="margin-bottom:18px">
  <div class="m-phead"><h2>ローテーション</h2><span class="m-num" style="color:var(--color-muted);font-size:12px">全 <%= @rotations.count %> 個</span></div>
  <% if @rotations.any? %>
    <div class="ev-rotlist">
      <% @rotations.each do |rotation| %>
        <% completed = rotation.rotation_matches.count { |rm| rm.match.present? } %>
        <% total = rotation.rotation_matches.count %>
        <% pct = total.positive? ? (completed.to_f / total * 100).round : 0 %>
        <%= link_to rotation_path(rotation), class: "ev-rotrow" do %>
          <div class="ev-rot-l">
            <div class="nm"><%= rotation.display_name %></div>
            <div class="pills">
              <span class="ev-rpill"><%= rotation.round_number %>周目</span>
              <% if rotation.is_active %><span class="ev-rpill live"><span class="ev-livedot"></span>アクティブ</span><% end %>
            </div>
          </div>
          <div class="ev-rot-r">
            <div class="c"><%= completed %> / <%= total %> 試合</div>
            <div class="ptrack"><div class="pfill" style="width:<%= pct %>%"></div></div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="m-pbody">
      <p class="text-sm font-bold text-muted">まだローテーションがありません。</p>
      <% if current_user.is_admin? %>
        <div class="mt-3"><%= link_to "作成する", new_event_rotation_path(@event), class: "m-btn m-btn-primary" %></div>
      <% end %>
    </div>
  <% end %>
</div>

<%# ===== 対戦記録 ===== %>
<div class="m-panel">
  <div class="m-phead">
    <h2>対戦記録</h2>
    <span class="m-num" style="color:var(--color-muted);font-size:12px">全 <%= @matches.total_count %> 試合</span>
  </div>
  <div class="m-pbody">
    <div class="mh-toolbar" style="margin-bottom:14px">
      <div class="right">
        <span class="text-sm font-bold text-muted">ソート</span>
        <div class="mh-seg">
          <% [["oldest", "試合順"], ["reactions", "リアクション順"]].each do |value, label| %>
            <%= link_to label, event_path(@event, sort: value, per: @per_page), class: class_names(value == @sort && "on") %>
          <% end %>
        </div>
      </div>
      <%= render "shared/per_page_selector", per_page: @per_page, url_builder: ->(n) { event_path(@event, sort: @sort, per: n) } %>
    </div>

    <% if @matches.any? %>
      <div class="mh-list">
        <% @matches.each do |match| %>
          <% team1 = match.match_players.to_a.select { |p| p.team_number == 1 }.sort_by(&:position) %>
          <% team2 = match.match_players.to_a.select { |p| p.team_number == 2 }.sort_by(&:position) %>
          <% streaming_id = team1.first&.id %>
          <%= turbo_stream_from "match_#{match.id}_reactions_compact" %>
          <div class="mh-card">
            <%= link_to "", match_path(match), class: "mh-cardlink", "aria-label": "試合詳細を見る" %>
            <div class="mh-meta">
              <span class="no">第<%= @match_numbers[match.id] %>試合</span>
              <% if match.rotation_match&.started_at %>
                <span class="date"><%= match.rotation_match.started_at.strftime("%H:%M") %> 開始</span>
              <% elsif match.played_at %>
                <span class="date"><%= match.played_at.strftime("%H:%M") %> 終了</span>
              <% end %>
              <% if match.video_url %>
                <%= render "shared/broadcast_link", url: match.video_url, link_class: "vid" %>
              <% end %>
              <span class="favslot">
                <%= render "favorite_matches/favorite_button", match: match, is_favorited: @my_favorite_match_ids.include?(match.id) %>
              </span>
            </div>

            <%= render "matches/mh_teams",
                  left_players: team1, right_players: team2,
                  left_wins: match.winning_team == 1,
                  left_label: "勝利", right_label: "敗北",
                  streaming_player_id: streaming_id %>

            <div class="mh-rbar">
              <%= render "reactions/reaction_bar", match: match, compact: true, emojis: @emojis %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @matches.respond_to?(:total_pages) && @matches.total_pages > 1 %>
        <div class="mt-5 flex flex-col items-center gap-4">
          <%= paginate @matches, params: { per: @per_page, sort: @sort } %>
          <%= render "shared/per_page_selector", per_page: @per_page, url_builder: ->(n) { event_path(@event, sort: @sort, per: n) } %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm font-bold text-muted">まだ対戦記録がありません。</p>
    <% end %>
  </div>
</div>
