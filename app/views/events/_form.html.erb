<%= form_with(model: event, class: "space-y-5") do |form| %>
  <% if event.errors.any? %>
    <div class="ui-alert ui-alert-danger">
      <p class="font-black"><%= pluralize(event.errors.count, "個のエラー") %>があります</p>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "イベント名", class: "ui-label" %>
    <%= form.text_field :name, placeholder: "例: 第1回オフライン貸切会@新宿スポラン", class: "ui-form-control" %>
  </div>

  <div>
    <%= form.label :held_on, "開催日", class: "ui-label" %>
    <%= form.date_field :held_on, class: "ui-form-control" %>
  </div>

  <div>
    <%= form.label :description, "説明（任意）", class: "ui-label" %>
    <%= form.text_area :description, rows: 4, placeholder: "イベントの詳細や特記事項など", class: "ui-form-control" %>
  </div>

  <div>
    <%= form.label :broadcast_url, "配信URL（任意）", class: "ui-label" %>
    <%= form.url_field :broadcast_url, placeholder: "https://www.youtube.com/watch?v=...", class: "ui-form-control" %>
    <p class="mt-2 text-sm font-bold text-subtle">配信アーカイブ URL を入力すると、詳細画面にリンクが表示されます。</p>
  </div>

  <div>
    <%= form.label :discord_thread_url, "DiscordフォーラムスレッドURL（任意）", class: "ui-label" %>
    <%= form.url_field :discord_thread_url, placeholder: "https://discord.com/channels/...", class: "ui-form-control" %>
    <p class="mt-2 text-sm font-bold text-subtle">設定すると Discord リマインドメッセージにスレッドリンクが含まれます。</p>
  </div>

  <div class="flex flex-wrap justify-end gap-3 pt-2">
    <%= link_to "キャンセル", events_path, class: "ui-btn ui-btn-secondary" %>
    <%= form.submit event.new_record? ? "作成" : "更新", class: "ui-btn ui-btn-primary cursor-pointer" %>
  </div>
<% end %>
