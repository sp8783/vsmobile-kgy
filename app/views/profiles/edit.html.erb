<div class="ui-page mx-auto max-w-2xl">
  <div class="ui-page-header">
    <div>
      <p class="ui-eyebrow">Settings</p>
      <h1 class="ui-title">設定</h1>
      <p class="ui-subtitle">アカウント設定を変更できます。</p>
    </div>
  </div>

  <div class="ui-card p-5 sm:p-6">
    <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |form| %>
      <% if @user.errors.any? %>
        <div class="ui-alert ui-alert-danger">
          <p class="font-black"><%= pluralize(@user.errors.count, "個のエラー") %>があります</p>
          <ul class="mt-2 list-disc pl-5 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section>
        <h2 class="mb-4 text-lg font-black text-ink">プロフィール設定</h2>
        <div class="space-y-4">
          <div>
            <label class="ui-label">ユーザー名</label>
            <div class="rounded-lg bg-bg px-4 py-3 text-sm font-bold text-muted shadow-inner-soft">
              <%= @user.username %>
            </div>
            <p class="mt-2 text-sm font-bold text-subtle">ユーザー名は変更できません。</p>
          </div>

          <div>
            <%= form.label :nickname, "ニックネーム", class: "ui-label" %>
            <%= form.text_field :nickname, class: "ui-form-control" %>
            <p class="mt-2 text-sm font-bold text-subtle">画面上に表示される名前です。</p>
          </div>
        </div>
      </section>

      <section class="rounded-lg bg-bg p-4 shadow-inner-soft" data-controller="push-subscription">
        <h2 class="mb-2 text-lg font-black text-ink">通知設定</h2>
        <p class="mb-4 text-sm font-bold text-muted">ローテーションでの順番通知などをプッシュ通知で受け取れます。</p>

        <p data-push-subscription-target="status" class="text-sm font-bold text-muted">
          確認中...
        </p>

        <p data-push-subscription-target="unsupportedMessage" class="mt-3 hidden text-sm font-bold text-neg">
          このブラウザはプッシュ通知に対応していません。Chrome、Edge、Safari などの最新ブラウザをご利用ください。
        </p>

        <div class="mt-4 flex flex-wrap gap-2">
          <button type="button"
                  data-push-subscription-target="subscribeButton"
                  data-action="click->push-subscription#subscribe"
                  class="ui-btn ui-btn-primary hidden">
            プッシュ通知を有効にする
          </button>

          <button type="button"
                  data-push-subscription-target="unsubscribeButton"
                  data-action="click->push-subscription#unsubscribe"
                  class="ui-btn ui-btn-secondary hidden">
            プッシュ通知を無効にする
          </button>
        </div>

        <p class="mt-4 text-xs font-bold text-subtle">
          プッシュ通知はデバイスごとに設定が必要です。複数のデバイスで通知を受け取るには、それぞれで有効化してください。
        </p>
      </section>

      <section>
        <h2 class="mb-4 text-lg font-black text-ink">パスワード変更</h2>
        <div class="space-y-4">
          <div>
            <%= form.label :password, "新しいパスワード", class: "ui-label" %>
            <%= form.password_field :password, autocomplete: "new-password", class: "ui-form-control" %>
            <p class="mt-2 text-sm font-bold text-subtle">変更しない場合は空欄のままにしてください。</p>
          </div>

          <div>
            <%= form.label :password_confirmation, "新しいパスワード（確認）", class: "ui-label" %>
            <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "ui-form-control" %>
          </div>
        </div>
      </section>

      <div class="flex justify-end">
        <%= form.submit "保存", class: "ui-btn ui-btn-primary cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
