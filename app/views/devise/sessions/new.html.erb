<div class="login-viewport flex items-center justify-center py-8">
  <div class="w-full max-w-md">
    <div class="mb-8 text-center">
      <img src="/logo-login.png" alt="VS.Mobile for KGY" class="mx-auto h-auto w-auto max-h-56 max-sm:max-w-72">
    </div>

    <div class="ui-card p-5 sm:p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :username, "ユーザー名", class: "ui-label" %>
          <%= f.text_field :username, autofocus: true, autocomplete: "username", placeholder: "ユーザー名", class: "ui-form-control" %>
        </div>

        <div>
          <%= f.label :password, "パスワード", class: "ui-label" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "パスワード", class: "ui-form-control" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex cursor-pointer items-center gap-3 rounded-lg bg-bg p-3 shadow-inner-soft">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded text-accent focus:ring-accent" %>
            <span class="text-sm font-bold text-ink">ログイン状態を保持</span>
          </label>
        <% end %>

        <%= f.submit "ログイン", class: "ui-btn ui-btn-primary w-full cursor-pointer" %>
      <% end %>

      <div class="mt-5 rounded-lg bg-bg p-3 text-center shadow-inner-soft">
        <p class="mb-3 text-xs font-bold text-subtle">または</p>
        <%= button_to "ゲストとしてログイン", guest_login_path, method: :post, data: { turbo: false }, class: "ui-btn ui-btn-secondary w-full" %>
      </div>
    </div>
  </div>
</div>
