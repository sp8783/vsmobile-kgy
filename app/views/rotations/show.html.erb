<% completed_count = @rotation_matches.count { |rm| rm.match.present? } %>
<% total_count = @rotation_matches.count %>
<% progress_pct = total_count.positive? ? (completed_count.to_f / total_count * 100).round : 0 %>
<% current_recorded_players = @current_match&.match&.match_players&.to_a || [] %>
<% suit_for_position = ->(position) { current_recorded_players.find { |mp| mp.position == position }&.mobile_suit_id } %>

<% if @show_completion_modal %>
  <div id="completion-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 modal-backdrop" data-controller="dismiss">
    <div class="ui-card ui-card-pad animate-fade-in w-full max-w-md">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent text-on-accent">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h2 class="ui-section-title text-center">全試合完了しました</h2>
      <p class="mt-2 text-center text-sm ui-muted">
        <%= @rotation.display_name %>の全試合が記録されました。<br>
        同じローテーション設定で<%= @rotation.round_number + 1 %>周目を作成しますか？
      </p>
      <div class="mt-6 grid gap-3">
        <%= button_to "#{@rotation.round_number + 1}周目を作成する", copy_for_next_round_rotation_path(@rotation), method: :post, class: "ui-btn ui-btn-primary w-full", form: { data: { turbo: false } } %>
        <button type="button" class="ui-btn ui-btn-muted w-full" data-action="dismiss#close">後で作成する</button>
      </div>
    </div>
  </div>
<% end %>

<div data-controller="rotation-record"
     data-rotation-record-update-url-value="<%= update_match_record_rotation_path(@rotation) %>">

  <%# ===== header ===== %>
  <div class="r-head">
    <div>
      <h1><%= @rotation.display_name %></h1>
      <div class="meta">イベント: <%= link_to @rotation.event.name, @rotation.event %>（<%= @rotation.event.held_on.strftime("%Y/%m/%d") %>）</div>
      <div class="pills">
        <span class="r-rpill"><%= @rotation.round_number %>周目</span>
        <% if @rotation.is_active %>
          <span class="r-rpill live"><span class="r-livedot"></span>アクティブ</span>
        <% else %>
          <span class="r-rpill">非アクティブ</span>
        <% end %>
      </div>
    </div>
    <div class="acts">
      <% if current_user.is_admin? %>
        <% if @rotation.is_active %>
          <%= button_to "非アクティブにする", deactivate_rotation_path(@rotation), method: :post, class: "m-btn-ghost" %>
        <% else %>
          <%= button_to "アクティブにする", activate_rotation_path(@rotation), method: :post, class: "m-btn m-btn-primary" %>
        <% end %>
        <div class="relative" data-controller="dropdown">
          <button type="button" class="m-btn-ghost" data-action="dropdown#toggle">その他 ▾</button>
          <div class="absolute right-0 z-20 mt-2 hidden w-56 overflow-hidden rounded-lg bg-surface shadow-card" data-dropdown-target="menu">
            <%= button_to "周回をコピー", copy_for_next_round_rotation_path(@rotation), method: :post, class: "block w-full px-4 py-3 text-left text-sm font-bold text-ink hover:bg-hover", form: { data: { turbo: false } } %>
            <%= button_to "削除", rotation_path(@rotation), method: :delete, data: { turbo_confirm: "ローテーション「#{@rotation.display_name}」を削除してもよろしいですか？関連する試合データは削除されません。" }, class: "block w-full px-4 py-3 text-left text-sm font-bold text-neg hover:bg-hover" %>
          </div>
        </div>
      <% end %>
      <%= link_to "一覧に戻る", rotations_path, class: "m-btn-ghost" %>
    </div>
  </div>

  <%# ===== progress ===== %>
  <div class="r-prog">
    <div class="top"><h3>進捗状況</h3><div class="c"><b><%= completed_count %></b> / <%= total_count %> 試合</div></div>
    <div class="r-ptrack"><div class="r-pfill" style="width:<%= progress_pct %>%"></div></div>
  </div>

  <%# ===== current match + record form ===== %>
  <div class="r-livecard">
    <div class="r-lv-head">
      <h2><span class="r-livedot"></span>現在の試合<%= "（第#{@rotation.current_match_index + 1}試合）" if @current_match %></h2>
      <% if @current_match %>
        <span class="r-stbadge <%= @current_match.match.present? ? "rec" : "un" %>"><%= @current_match.match.present? ? "記録済み" : "未記録" %></span>
      <% end %>
    </div>

    <% if @current_match %>
      <div class="r-lvmatch">
        <div class="r-lvteam">
          <div class="tl">チーム1</div>
          <div class="r-lvp stream"><%= @current_match.team1_player1.nickname %><span class="sm">配信台</span></div>
          <div class="r-lvp"><%= @current_match.team1_player2.nickname %></div>
        </div>
        <div class="r-lvvs">VS</div>
        <div class="r-lvteam">
          <div class="tl">チーム2</div>
          <div class="r-lvp"><%= @current_match.team2_player1.nickname %></div>
          <div class="r-lvp"><%= @current_match.team2_player2.nickname %></div>
        </div>
      </div>

      <% if current_user.is_admin? %>
        <% form_url = @current_match.match.present? ? update_match_record_rotation_path(@rotation) : record_match_rotation_path(@rotation) %>
        <section id="match-record-container" class="r-recform">
          <div class="r-rf-h" data-rotation-record-target="title"><%= @current_match.match.present? ? "試合結果を編集" : "試合結果を記録" %></div>

          <%# スキップ/次へボタンは formaction で next_match に飛ばすため、per-form CSRF ではなく
              どのアクションでも有効なグローバルトークンを使う %>
          <%= form_with url: form_url, method: :post, authenticity_token: form_authenticity_token, data: { turbo: false, rotation_record_target: "form", action: "submit->rotation-record#validate" } do %>
            <%= hidden_field_tag :match_index, @rotation.current_match_index, data: { rotation_record_target: "matchIndex" } %>
            <div class="r-rf-grid">
              <div class="r-rf-col">
                <div class="lbl">チーム1 使用機体</div>
                <%= render "rotations/suit_field", field_name: "team1_player1_suit", player: @current_match.team1_player1, selected: suit_for_position.call(1), all_mobile_suits: @all_mobile_suits %>
                <%= render "rotations/suit_field", field_name: "team1_player2_suit", player: @current_match.team1_player2, selected: suit_for_position.call(2), all_mobile_suits: @all_mobile_suits %>
              </div>
              <div class="r-rf-col">
                <div class="lbl">チーム2 使用機体</div>
                <%= render "rotations/suit_field", field_name: "team2_player1_suit", player: @current_match.team2_player1, selected: suit_for_position.call(3), all_mobile_suits: @all_mobile_suits %>
                <%= render "rotations/suit_field", field_name: "team2_player2_suit", player: @current_match.team2_player2, selected: suit_for_position.call(4), all_mobile_suits: @all_mobile_suits %>
              </div>
            </div>

            <div class="r-rf-win">
              <div class="lbl">勝利チーム <span class="req">*</span></div>
              <div class="r-wseg">
                <% [[1, "チーム1"], [2, "チーム2"]].each do |team, label| %>
                  <label>
                    <%= radio_button_tag :winning_team, team, @current_match.match&.winning_team == team, class: "sr-only" %>
                    <span class="seg-item"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div class="r-rf-foot">
              <div class="note"><b>必須:</b> 各プレイヤーの機体 ＋ 勝利チーム</div>
              <div class="acts">
                <button type="button" class="m-btn-ghost hidden" data-rotation-record-target="cancelButton" data-action="rotation-record#cancel">キャンセル</button>
                <% unless @current_match.match.present? %>
                  <%= button_tag "試合をスキップ", type: "submit", formaction: next_match_rotation_path(@rotation), formmethod: "post", class: "m-btn-ghost", data: { turbo_confirm: "この試合をスキップしますか？", skip_validation: true, rotation_record_target: "skipButton" } %>
                <% end %>
                <% if @current_match.match.present? && @rotation.current_match_index < @rotation_matches.count - 1 %>
                  <%= button_tag "次の試合へ", type: "submit", formaction: next_match_rotation_path(@rotation), formmethod: "post", class: "m-btn-ghost", data: { skip_validation: true, rotation_record_target: "nextButton" } %>
                <% end %>
                <button type="submit" class="m-btn m-btn-primary">
                  <span data-rotation-record-target="submitText"><%= @current_match.match.present? ? "更新" : "記録して次へ" %></span>
                </button>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    <% else %>
      <p class="text-sm font-bold text-muted">現在の試合はありません。</p>
    <% end %>
  </div>

  <%# ===== 全試合一覧（テーブル） ===== %>
  <div class="r-rmcard">
    <div class="r-rm-h">
      <h2>全試合一覧</h2>
      <div class="r-legend">
        <span><span class="r-lg-dot rec"></span>記録済</span>
        <span><span class="r-lg-dot cur"></span>現在</span>
        <span><span class="r-lg-dot skip"></span>スキップ</span>
      </div>
    </div>
    <div class="r-mtwrap">
      <table class="r-mt">
        <thead>
          <tr>
            <th>試合</th><th>チーム1</th><th class="c">VS</th><th>チーム2</th><th class="c">状態</th>
            <% if current_user.is_admin? %><th class="c">操作</th><% end %>
          </tr>
        </thead>
        <tbody>
          <% mps = @rotation.matches_per_set %>
          <% @rotation_matches.each_with_index do |rm, index| %>
            <% is_current = index == @rotation.current_match_index %>
            <% match = rm.match %>
            <% mps_by_position = (match&.match_players || []).index_by(&:position) %>
            <% if index % mps == 0 %>
              <tr class="setrow"><td colspan="<%= current_user.is_admin? ? 6 : 5 %>">第<%= index / mps + 1 %>セット</td></tr>
            <% end %>
            <tr class="<%= class_names(is_current && "curtr", match && "linked") %>"
                <% if match %>data-controller="card-link" data-card-link-url-value="<%= match_path(match) %>" data-action="click->card-link#navigate"<% end %>>
              <td class="r-mt-no" data-l="試合">第<%= index + 1 %>試合<% if is_current %> <span class="r-cur-tag">現在</span><% end %></td>
              <td class="r-tcell <%= match ? (match.winning_team == 1 ? "win" : "lose") : "" %>" data-l="チーム1">
                <div class="r-tcellwrap">
                  <div class="r-tps">
                    <div class="r-tp"><span class="r-tpn"><%= rm.team1_player1.nickname %><% if mps_by_position[1]&.mobile_suit %><span class="tsu"><%= mps_by_position[1].mobile_suit.name %></span><% end %></span><span class="sm">配信台</span></div>
                    <div class="r-tp"><span class="r-tpn"><%= rm.team1_player2.nickname %><% if mps_by_position[2]&.mobile_suit %><span class="tsu"><%= mps_by_position[2].mobile_suit.name %></span><% end %></span></div>
                  </div>
                  <% if match %><span class="r-bx-tag <%= match.winning_team == 1 ? "win" : "lose" %>"><%= match.winning_team == 1 ? "WIN" : "LOSE" %></span><% end %>
                </div>
              </td>
              <td class="c vshide r-mt-vs" data-l="">VS</td>
              <td class="r-tcell <%= match ? (match.winning_team == 2 ? "win" : "lose") : "" %>" data-l="チーム2">
                <div class="r-tcellwrap">
                  <div class="r-tps">
                    <div class="r-tp"><span class="r-tpn"><%= rm.team2_player1.nickname %><% if mps_by_position[3]&.mobile_suit %><span class="tsu"><%= mps_by_position[3].mobile_suit.name %></span><% end %></span></div>
                    <div class="r-tp"><span class="r-tpn"><%= rm.team2_player2.nickname %><% if mps_by_position[4]&.mobile_suit %><span class="tsu"><%= mps_by_position[4].mobile_suit.name %></span><% end %></span></div>
                  </div>
                  <% if match %><span class="r-bx-tag <%= match.winning_team == 2 ? "win" : "lose" %>"><%= match.winning_team == 2 ? "WIN" : "LOSE" %></span><% end %>
                </div>
              </td>
              <td class="c" data-l="状態">
                <% if is_current %><span class="r-status st-cur">現在</span>
                <% elsif match %><span class="r-status st-rec">記録済</span>
                <% elsif index < @rotation.current_match_index %><span class="r-status st-skip">スキップ</span>
                <% else %><span class="r-status st-un">未記録</span><% end %>
              </td>
              <% if current_user.is_admin? %>
                <td class="c" data-l="操作">
                  <div class="r-rowact">
                    <% if match %>
                      <%= link_to "詳細", match_path(match), class: "m-btn-ghost" %>
                      <% mp1 = mps_by_position[1]; mp2 = mps_by_position[2]; mp3 = mps_by_position[3]; mp4 = mps_by_position[4] %>
                      <a href="#match-record-container" class="m-btn-ghost"
                         data-action="rotation-record#edit"
                         data-match-index="<%= index %>" data-winning-team="<%= match.winning_team %>"
                         data-suit1="<%= mp1&.mobile_suit_id %>" data-suit2="<%= mp2&.mobile_suit_id %>"
                         data-suit3="<%= mp3&.mobile_suit_id %>" data-suit4="<%= mp4&.mobile_suit_id %>">編集</a>
                      <%= button_to "削除", match_path(match), method: :delete, data: { turbo_confirm: "この試合記録を削除してもよろしいですか？" }, class: "m-btn-ghost", style: "color:var(--color-neg)" %>
                    <% elsif index < @rotation.current_match_index %>
                      <%= button_to "ここに戻る", go_to_match_rotation_path(@rotation, match_index: index), method: :post, class: "m-btn-ghost", form: { data: { turbo: false } } %>
                    <% else %>
                      <span class="text-subtle">—</span>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ===== 平等性チェック ===== %>
  <div class="r-fair">
    <div class="r-f-h">
      <h2>平等性チェック</h2>
      <p>記録済 / 計画、配信台回数、ペア・対戦相手の偏りを確認します。</p>
    </div>
    <div class="r-fwrap">
      <table class="r-ft">
        <thead>
          <tr><th>プレイヤー</th><th class="c">試合数<br>(済/計画)</th><th class="c">配信台<br>(済/計画)</th><th>よく組む相手</th><th>よく対戦した相手</th></tr>
        </thead>
        <tbody>
          <% @player_statistics.each_value do |stats| %>
            <tr>
              <td class="name" data-l="プレイヤー"><%= stats[:user].nickname %><% if stats[:user].id == current_user.id %><span class="r-youtag">あなた</span><% end %></td>
              <td class="c" data-l="試合数(済/計画)"><span class="r-frac"><b><%= stats[:registered_match_count] %></b><s> / <%= stats[:match_count] %></s></span></td>
              <td class="c" data-l="配信台(済/計画)"><span class="r-frac"><b><%= stats[:registered_streaming_count] %></b><s> / <%= stats[:streaming_count] %></s></span></td>
              <td data-l="よく組む相手">
                <% if stats[:pair_counts].any? %>
                  <div class="r-reltop">
                    <% stats[:pair_counts].sort_by { |_, count| -count }.first(3).each do |partner_id, count| %>
                      <div><b><%= User.find(partner_id).nickname %></b> <%= count %>回</div>
                    <% end %>
                  </div>
                <% else %><span class="text-subtle">-</span><% end %>
              </td>
              <td data-l="よく対戦した相手">
                <% if stats[:opponent_counts].any? %>
                  <div class="r-reltop">
                    <% stats[:opponent_counts].sort_by { |_, count| -count }.first(3).each do |opponent_id, count| %>
                      <div><b><%= User.find(opponent_id).nickname %></b> <%= count %>回</div>
                    <% end %>
                  </div>
                <% else %><span class="text-subtle">-</span><% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
