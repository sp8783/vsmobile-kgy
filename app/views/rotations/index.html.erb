<div class="m-pagehead">
  <div>
    <h1>ローテーション一覧</h1>
    <div class="m-sub">イベントごとのローテーション表を管理できます。</div>
  </div>
</div>

<% if @rotations.any? %>
  <div class="dtbl-card">
    <div class="dtbl-bar">
      <div class="cnt">全 <b><%= @rotations.size %></b> 個</div>
    </div>
    <div class="dtbl-scroll">
      <table class="dtbl">
        <thead>
          <tr>
            <th>イベント</th><th>周回</th><th>進捗</th><th>状態</th><th>作成日</th><th class="right">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @rotations.each do |rotation| %>
            <% completed_count = rotation.rotation_matches.count { |rm| rm.match.present? } %>
            <% total_count = rotation.rotation_matches.count %>
            <% pct = total_count.positive? ? (completed_count.to_f / total_count * 100).round : 0 %>
            <tr data-controller="card-link" data-card-link-url-value="<%= rotation_path(rotation) %>" data-action="click->card-link#navigate">
              <td class="name" data-l="イベント"><span class="lnk"><%= rotation.event.name %></span><div class="muted" style="font-weight:600;margin-top:2px"><span class="m-num"><%= rotation.event.held_on.strftime("%Y/%m/%d") %></span></div></td>
              <td data-l="周回"><span class="r-rpill"><%= rotation.round_number %>周目</span></td>
              <td data-l="進捗">
                <div style="min-width:120px">
                  <div class="muted" style="font-size:11px;margin-bottom:4px"><span class="m-num"><%= completed_count %> / <%= total_count %></span> 試合</div>
                  <div class="ev-rot-r"><div class="ptrack" style="width:120px;margin:0"><div class="pfill" style="width:<%= pct %>%"></div></div></div>
                </div>
              </td>
              <td data-l="状態">
                <% if rotation.is_active %>
                  <span class="r-rpill live"><span class="r-livedot"></span>アクティブ</span>
                <% else %>
                  <span class="r-rpill">非アクティブ</span>
                <% end %>
              </td>
              <td class="muted" data-l="作成日"><span class="m-num"><%= rotation.created_at.strftime("%Y/%m/%d") %></span></td>
              <td class="actions" data-l="操作">
                <div class="rowact">
                  <% if current_user.is_admin? %>
                    <%= button_to "削除", rotation, method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "m-btn-ghost", style: "color:var(--color-neg)" %>
                  <% else %>
                    <%= link_to "詳細", rotation_path(rotation), class: "m-btn-ghost" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="m-panel m-pbody">
    <h2 class="text-lg font-black text-ink">ローテーションがありません</h2>
    <% if current_user.is_admin? %>
      <p class="mt-2 text-sm font-bold text-muted">まずはイベントページからローテーションを作成してください。</p>
    <% else %>
      <p class="mt-2 text-sm font-bold text-muted">管理者によってローテーションが作成されるとここに表示されます。</p>
    <% end %>
  </div>
<% end %>
