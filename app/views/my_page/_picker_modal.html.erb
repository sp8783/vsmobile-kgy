<%#
  locals:
    suits: MobileSuit collection
    costs: Array of cost integers
    counts_by_cost: Hash { cost => count }
%>
<% cost_tabs = [ [ "", "すべて", counts_by_cost.values.sum ] ] + costs.map { |c| [ c.to_s, c.to_s, counts_by_cost[c] || 0 ] } %>

<div class="pk-overlay hidden" data-favorite-picker-target="modal">
  <div class="pk-backdrop" data-action="click->favorite-picker#close"></div>

  <div class="pk-panel">
    <div class="pk-head">
      <div class="l">
        <h2>お気に入り機体を選択</h2>
        <span class="pk-count" data-favorite-picker-target="countBadge">0 / 12</span>
      </div>
      <button type="button" class="pk-close" aria-label="閉じる" data-action="click->favorite-picker#close">
        <svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <div class="pk-tray">
      <div class="pk-tray-row">
        <div class="pk-traygrid" data-favorite-picker-target="tray">
          <div class="pk-trayempty">機体をクリックして追加…</div>
        </div>
        <button type="button" class="pk-clear" data-action="click->favorite-picker#clearAll">クリア</button>
      </div>
      <div class="pk-trayhint">
        <svg viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
        ドラッグで順番変更　・　× で削除
      </div>
    </div>

    <div class="pk-filter">
      <div class="pk-costtabs">
        <% cost_tabs.each do |val, label, count| %>
          <% is_all = val.empty? %>
          <button type="button"
                  class="pk-costtab <%= "c#{val}" unless is_all %> <%= "on" if is_all %>"
                  data-cost-btn
                  data-cost="<%= val %>"
                  data-active="<%= is_all ? 'true' : 'false' %>"
                  data-action="click->favorite-picker#filterCost">
            <%= label %><span class="ct-n"><%= count %></span>
          </button>
        <% end %>
      </div>
      <div class="pk-search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <input type="text" placeholder="機体名で検索"
               data-favorite-picker-target="searchInput"
               data-action="input->favorite-picker#search">
      </div>
    </div>

    <div class="pk-body">
      <div class="pk-grid">
        <% suits.each do |suit| %>
          <div data-suit-wrapper data-suit-name="<%= suit.name %>" data-suit-cost="<%= suit.cost %>">
            <div class="pk-cell"
                 data-suit-id="<%= suit.id %>"
                 data-suit-name="<%= suit.name %>"
                 data-suit-image="<%= suit.image_filename.to_s %>"
                 data-action="click->favorite-picker#toggleSuit">
              <span class="sc-chk"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>
              <div class="sc-th">
                <% if suit.image_filename.present? %>
                  <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name, loading: "lazy" %>
                <% else %>
                  <span class="ph">No Image</span>
                <% end %>
              </div>
              <div class="sc-n"><%= suit.name %></div>
              <div class="sc-c"><%= cost_badge(suit.cost) %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="pk-foot">
      <button type="button" class="m-btn m-btn-ghost" data-action="click->favorite-picker#close">キャンセル</button>
      <button type="button" class="m-btn m-btn-primary" data-favorite-picker-target="saveBtn" data-action="click->favorite-picker#save">保存</button>
    </div>

    <%= form_with url: bulk_update_user_favorite_suits_path, method: :post,
                  data: { favorite_picker_target: "form" } do |f| %>
    <% end %>
  </div>
</div>
