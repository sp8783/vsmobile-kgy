<% content_for :title, "マイページ" %>

<div class="ui-page"
     data-controller="favorite-picker"
     data-favorite-picker-initial-value="<%= @selected_suit_ids.to_json %>">
  <% if viewing_as_someone_else? %>
    <div class="ui-card bg-cost-2500-bg p-4 mb-5">
      <p class="text-sm font-bold text-cost-2500">
        管理者として <%= viewing_as_user.nickname %> さんのマイページを編集中
      </p>
    </div>
  <% end %>

  <div class="ui-page-header">
    <div class="flex items-center gap-4">
      <div class="flex h-16 w-16 select-none items-center justify-center rounded-lg bg-accent text-2xl font-black text-on-accent shadow-card">
        <%= viewing_as_user.nickname[0] %>
      </div>
      <div>
        <p class="text-sm font-bold text-subtle">@<%= viewing_as_user.username %></p>
        <h1 class="text-3xl font-black text-ink"><%= viewing_as_user.nickname %></h1>
      </div>
    </div>
  </div>

  <section class="fav-card mb-5">
    <div class="fav-head">
      <div>
        <h2>お気に入り機体</h2>
        <div class="sub"><%= @favorites_by_slot.size %> / 12</div>
      </div>
      <% unless current_user.is_guest? %>
        <button type="button" class="m-btn m-btn-primary" data-action="click->favorite-picker#open">
          <svg viewBox="0 0 24 24" aria-hidden="true" style="width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2"><path d="M12 5v14M5 12h14"/></svg>
          <%= @favorites_by_slot.empty? ? "機体を選ぶ" : "編集する" %>
        </button>
      <% end %>
    </div>

    <div class="fav-grid">
      <% (0..11).each do |slot| %>
        <% fav = @favorites_by_slot[slot] %>
        <% if fav %>
          <div class="fav-slot">
            <span class="slot-badge <%= slot.zero? ? 'slot-badge-main' : 'slot-badge-sub' %>"><%= slot.zero? ? "M" : "S#{slot}" %></span>
            <%= link_to mobile_suit_path(fav.mobile_suit), class: "fav-link", data: { turbo_frame: "_top" } do %>
              <div class="fav-thumb">
                <% if fav.mobile_suit.image_filename.present? %>
                  <%= image_tag "/mobile_suits/#{fav.mobile_suit.image_filename}", alt: fav.mobile_suit.name, loading: "lazy" %>
                <% else %>
                  <span class="text-xs font-bold text-subtle">No Image</span>
                <% end %>
              </div>
              <div class="fav-name"><%= fav.mobile_suit.name %></div>
              <div class="fav-series"><%= fav.mobile_suit.series %></div>
              <div class="fav-meta"><%= cost_badge(fav.mobile_suit.cost) %></div>
            <% end %>
            <% if fav.mobile_suit.wiki_url.present? %>
              <%= link_to safe_external_url(fav.mobile_suit.wiki_url), target: "_blank", rel: "noopener noreferrer", class: "fav-wiki", data: { turbo_frame: "_top" } do %>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6.3v13M12 6.3C10.8 5.5 9.2 5 7.5 5S4.2 5.5 3 6.3v13C4.2 18.5 5.8 18 7.5 18s3.3.5 4.5 1.3m0-13C13.2 5.5 14.8 5 16.5 5S19.8 5.5 21 6.3v13C19.8 18.5 18.2 18 16.5 18s-3.3.5-4.5 1.3"/></svg>
                Wiki
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="fav-slot empty">
            <span class="slot-badge <%= slot.zero? ? 'slot-badge-main' : 'slot-badge-sub' %>"><%= slot.zero? ? "M" : "S#{slot}" %></span>
            未設定
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="ui-card p-0">
    <div class="flex flex-wrap items-center justify-between gap-3 px-5 py-4">
      <div>
        <h2 class="text-lg font-black text-ink">お気に入り試合</h2>
        <p class="mt-1 text-sm font-bold text-subtle tabular-nums"><%= @favorite_matches.total_count %> 件</p>
      </div>
      <% if @favorite_matches.total_count.positive? %>
        <%= link_to "一覧で見る", matches_path(only_favorites: "1"),
            class: "ui-btn ui-btn-secondary",
            data: { turbo_frame: "_top" } %>
      <% end %>
    </div>

    <% if @favorite_matches.any? %>
      <div class="space-y-3 px-4 pb-5 sm:px-5">
        <% @favorite_matches.each do |match| %>
          <%
            all_mp = match.match_players.sort_by { |mp| [mp.team_number, mp.position] }
            team1 = all_mp.select { |mp| mp.team_number == 1 }
            team2 = all_mp.select { |mp| mp.team_number == 2 }
          %>
          <article class="rounded-lg bg-bg p-4 shadow-inner-soft transition hover:shadow-card"
                   data-controller="card-link"
                   data-card-link-url-value="<%= match_path(match) %>"
                   data-action="click->card-link#navigate">
            <div class="mb-3 flex flex-wrap items-center gap-2">
              <span class="text-sm font-bold text-subtle"><%= match.played_at.strftime("%Y年%m月%d日") %></span>
              <span class="ui-chip"><%= match.event.name %></span>
              <% if match.video_url %>
                <%= render "shared/broadcast_link", url: match.video_url,
                      link_class: "ui-btn ui-btn-small ui-btn-danger", img_class: "h-3.5" %>
              <% end %>
            </div>

            <%= render "matches/match_teams",
                  left_players: team1,
                  right_players: team2,
                  left_wins: match.winning_team == 1 %>
          </article>
        <% end %>
      </div>

      <% if @favorite_matches.total_pages > 1 %>
        <div class="px-5 pb-5">
          <%= paginate @favorite_matches, param_name: :fav_page %>
        </div>
      <% end %>
    <% else %>
      <div class="px-5 pb-10 pt-4 text-center">
        <p class="text-sm font-bold text-muted">お気に入りに登録した試合はありません</p>
      </div>
    <% end %>
  </section>

  <%= render "my_page/picker_modal",
             suits: @all_suits,
             costs: @costs,
             counts_by_cost: @counts_by_cost %>
</div>
