<%
  _streaming_player_id = local_assigns[:streaming_player_id]
  _left_label = local_assigns.fetch(:left_label, "チーム1")
  _right_label = local_assigns.fetch(:right_label, "チーム2")
  _compact = local_assigns.fetch(:compact, false)
  _thumb_size = _compact ? :sm : :md
  _grid_classes = _compact ? "grid gap-3" : "grid gap-3 lg:grid-cols-[1fr_3rem_1fr] lg:items-stretch"
%>

<div class="<%= _grid_classes %> min-w-0">
  <div class="min-w-0 rounded-lg <%= left_wins ? 'bg-accent/10' : 'bg-neg/10' %> p-4 shadow-inner-soft">
    <div class="mb-3 flex items-center justify-between gap-3">
      <span class="text-xs font-black uppercase tracking-wide text-subtle"><%= _left_label %></span>
      <span class="ui-chip <%= left_wins ? 'ui-chip-active' : 'bg-neg text-on-accent' %>">
        <%= left_wins ? "WIN" : "LOSE" %>
      </span>
    </div>

    <div class="space-y-3">
      <% left_players.each do |player| %>
        <div class="flex min-w-0 items-center gap-3">
          <%= render Suit::ThumbComponent.new(suit: player.mobile_suit, size: _thumb_size) %>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-black <%= player.id == _streaming_player_id ? 'text-neg' : 'text-ink' %>">
              <%= player_name(player.user) %>
              <% if player.id == _streaming_player_id %>
                <span class="ml-1 rounded bg-neg px-1.5 py-0.5 text-xs font-black text-on-accent">配信台</span>
              <% end %>
            </p>
            <div class="mt-1 flex flex-wrap items-center gap-1.5">
              <%= mobile_suit_link(player.mobile_suit,
                  class: "block max-w-full truncate text-xs font-bold text-muted transition hover:text-accent") %>
              <%= cost_badge(player.mobile_suit.cost) %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-center text-xs font-black uppercase tracking-wide text-subtle">
    VS
  </div>

  <div class="min-w-0 rounded-lg <%= left_wins ? 'bg-neg/10' : 'bg-accent/10' %> p-4 shadow-inner-soft">
    <div class="mb-3 flex items-center justify-between gap-3">
      <span class="text-xs font-black uppercase tracking-wide text-subtle"><%= _right_label %></span>
      <span class="ui-chip <%= left_wins ? 'bg-neg text-on-accent' : 'ui-chip-active' %>">
        <%= left_wins ? "LOSE" : "WIN" %>
      </span>
    </div>

    <div class="space-y-3">
      <% right_players.each do |player| %>
        <div class="flex min-w-0 items-center gap-3">
          <%= render Suit::ThumbComponent.new(suit: player.mobile_suit, size: _thumb_size) %>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-black <%= player.id == _streaming_player_id ? 'text-neg' : 'text-ink' %>">
              <%= player_name(player.user) %>
              <% if player.id == _streaming_player_id %>
                <span class="ml-1 rounded bg-neg px-1.5 py-0.5 text-xs font-black text-on-accent">配信台</span>
              <% end %>
            </p>
            <div class="mt-1 flex flex-wrap items-center gap-1.5">
              <%= mobile_suit_link(player.mobile_suit,
                  class: "block max-w-full truncate text-xs font-bold text-muted transition hover:text-accent") %>
              <%= cost_badge(player.mobile_suit.cost) %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
