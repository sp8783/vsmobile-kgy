<div class="ui-page mx-auto max-w-4xl">
  <div class="ui-page-header">
    <div>
      <%= link_to "イベントに戻る", event_path(@event), class: "ui-btn ui-btn-ghost mb-4" %>
      <p class="ui-eyebrow">Match</p>
      <h1 class="ui-title">対戦記録入力</h1>
      <p class="ui-subtitle"><%= @event.name %></p>
    </div>
  </div>

  <%= form_with(model: [@event, @match], class: "space-y-5") do |form| %>
    <% if @match.errors.any? %>
      <div class="ui-alert ui-alert-danger">
        <p class="font-black"><%= pluralize(@match.errors.count, "個のエラー") %>があります</p>
        <ul class="mt-2 list-disc pl-5 text-sm">
          <% @match.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <section class="ui-card p-5">
      <h2 class="mb-4 text-lg font-black text-ink">チーム1</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <%= form.fields_for :match_players, @match.match_players[0] do |player_form| %>
          <%= player_form.hidden_field :team_number, value: 1 %>
          <%= player_form.hidden_field :position, value: 1 %>
          <div>
            <label class="ui-label">プレイヤー1</label>
            <%= player_form.collection_select :user_id, @users, :id, :nickname, { prompt: "選択してください" }, class: "ui-form-control" %>
            <%= player_form.collection_select :mobile_suit_id, @mobile_suits, :id, :name, { prompt: "機体を選択" }, { class: "ui-form-control mt-2", data: { controller: "select2", placeholder: "機体を検索..." } } %>
          </div>
        <% end %>

        <%= form.fields_for :match_players, @match.match_players[1] do |player_form| %>
          <%= player_form.hidden_field :team_number, value: 1 %>
          <%= player_form.hidden_field :position, value: 2 %>
          <div>
            <label class="ui-label">プレイヤー2</label>
            <%= player_form.collection_select :user_id, @users, :id, :nickname, { prompt: "選択してください" }, class: "ui-form-control" %>
            <%= player_form.collection_select :mobile_suit_id, @mobile_suits, :id, :name, { prompt: "機体を選択" }, { class: "ui-form-control mt-2", data: { controller: "select2", placeholder: "機体を検索..." } } %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="ui-card p-5">
      <h2 class="mb-4 text-lg font-black text-ink">チーム2</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <%= form.fields_for :match_players, @match.match_players[2] do |player_form| %>
          <%= player_form.hidden_field :team_number, value: 2 %>
          <%= player_form.hidden_field :position, value: 3 %>
          <div>
            <label class="ui-label">プレイヤー3</label>
            <%= player_form.collection_select :user_id, @users, :id, :nickname, { prompt: "選択してください" }, class: "ui-form-control" %>
            <%= player_form.collection_select :mobile_suit_id, @mobile_suits, :id, :name, { prompt: "機体を選択" }, { class: "ui-form-control mt-2", data: { controller: "select2", placeholder: "機体を検索..." } } %>
          </div>
        <% end %>

        <%= form.fields_for :match_players, @match.match_players[3] do |player_form| %>
          <%= player_form.hidden_field :team_number, value: 2 %>
          <%= player_form.hidden_field :position, value: 4 %>
          <div>
            <label class="ui-label">プレイヤー4</label>
            <%= player_form.collection_select :user_id, @users, :id, :nickname, { prompt: "選択してください" }, class: "ui-form-control" %>
            <%= player_form.collection_select :mobile_suit_id, @mobile_suits, :id, :name, { prompt: "機体を選択" }, { class: "ui-form-control mt-2", data: { controller: "select2", placeholder: "機体を検索..." } } %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="ui-card p-5">
      <h2 class="mb-4 text-lg font-black text-ink">勝利チーム</h2>
      <div class="flex flex-wrap gap-3">
        <label class="flex cursor-pointer items-center gap-2 rounded-lg bg-bg px-4 py-3 font-bold text-ink shadow-inner-soft">
          <%= form.radio_button :winning_team, 1, class: "h-4 w-4 text-accent focus:ring-accent" %>
          チーム1
        </label>
        <label class="flex cursor-pointer items-center gap-2 rounded-lg bg-bg px-4 py-3 font-bold text-ink shadow-inner-soft">
          <%= form.radio_button :winning_team, 2, class: "h-4 w-4 text-accent focus:ring-accent" %>
          チーム2
        </label>
      </div>
    </section>

    <div class="flex flex-wrap justify-end gap-3">
      <%= link_to "キャンセル", event_path(@event), class: "ui-btn ui-btn-secondary" %>
      <%= form.submit "記録", class: "ui-btn ui-btn-primary cursor-pointer" %>
    </div>
  <% end %>
</div>
