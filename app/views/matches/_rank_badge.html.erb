<%# locals: (rank: nil) %>
<% if rank %>
  <% badge_class = case rank
    when 1 then "bg-accent text-on-accent"
    else        "bg-surface-2 text-muted"
    end %>
  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold <%= badge_class %>">
    <%= rank %>
  </span>
<% end %>
