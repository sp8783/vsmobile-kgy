<%= turbo_stream_from "match_#{@match.id}_reactions" %>

<%
  team1_players = @match.match_players.select { |p| p.team_number == 1 }.sort_by(&:position)
  team2_players = @match.match_players.select { |p| p.team_number == 2 }.sort_by(&:position)
  all_players = team1_players + team2_players
  has_stats = all_players.any?(&:has_stats?) || !@match.team1_ex_overlimit_before_end.nil? || !@match.team2_ex_overlimit_before_end.nil?
  survival_col_count = all_players.map { |p| (p.survival_times || []).size }.max.to_i
  streaming_id = team1_players.first&.id
%>

<%= link_to matches_path, class: "md-backlink",
    data: { controller: "back-link", back_link_storage_key_value: "matchesReturnUrl" } do %>
  ← 対戦履歴に戻る
<% end %>

<%# ===== hero ===== %>
<div class="md-dhero">
  <div class="md-dh-top">
    <div>
      <h1>対戦詳細</h1>
      <div class="md-dh-meta">
        <span class="date"><%= @match.played_at.strftime("%Y年%m月%d日") %></span>
        <% if @match.video_url.present? %>
          <%= render "shared/broadcast_link", url: @match.video_url, link_class: "vid" %>
        <% end %>
        <%= render "favorite_matches/favorite_button", match: @match, is_favorited: @is_favorited %>
      </div>
    </div>
    <% if current_user.is_admin? %>
      <div class="md-dh-act">
        <%= link_to "編集", edit_match_path(@match), class: "m-btn-ghost" %>
        <%= link_to "統計を編集", edit_match_stats_path(@match), class: "m-btn m-btn-primary" %>
        <%= button_to "削除", match_path(@match), method: :delete,
            data: { turbo_confirm: "この対戦記録を削除してもよろしいですか？" },
            form: { class: "contents" },
            class: "m-btn-ghost", style: "color:var(--color-neg)" %>
      </div>
    <% end %>
  </div>

  <div class="md-dh-event">
    <span class="k">イベント</span>
    <%= link_to @match.event.name, event_path(@match.event), class: "epill" %>
  </div>

  <div class="md-roster">
    <% [["チーム1", team1_players, @match.winning_team == 1], ["チーム2", team2_players, @match.winning_team == 2]].each do |label, players, win| %>
      <div class="md-rteam <%= win ? "win" : "lose" %>">
        <div class="md-rteam-head">
          <span class="tn"><%= label %></span>
          <span class="md-tag <%= win ? "win" : "lose" %>"><%= win ? "WIN" : "LOSE" %></span>
        </div>
        <% players.each do |p| %>
          <% streaming = p.id == streaming_id %>
          <div class="md-rplayer">
            <div class="md-rp-top">
              <span class="md-rankb <%= "r1" if p.match_rank == 1 %>"><%= p.match_rank %></span>
              <span class="md-rp-name <%= "streaming" if streaming %>"><%= p.user.nickname %></span>
              <% if streaming %><span class="md-stream">配信台</span><% end %>
            </div>
            <div class="md-rp-suit">
              <span class="suit-thumb suit-thumb-lg">
                <% if p.mobile_suit&.image_filename.present? %>
                  <%= image_tag "/mobile_suits/#{p.mobile_suit.image_filename}", alt: p.mobile_suit.name, loading: "lazy" %>
                <% else %>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 16l4.6-4.6a2 2 0 0 1 2.8 0L16 16M14 14l1.6-1.6a2 2 0 0 1 2.8 0L20 14M14 8h.01M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z"/></svg>
                <% end %>
              </span>
              <div>
                <div class="lab">使用機体</div>
                <div class="sn">
                  <% if p.mobile_suit %>
                    <%= mobile_suit_link(p.mobile_suit, class: "hover:text-accent") %>
                    <span class="md-cb md-cb-<%= p.mobile_suit.cost %>"><%= p.mobile_suit.cost %></span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ===== 対戦統計（カード ⇔ テーブル 切替） ===== %>
<% if has_stats %>
  <div class="md-sec" data-controller="stat-view">
    <div class="md-stat-toolbar">
      <h2>対戦統計</h2>
      <div class="md-segview">
        <button type="button" title="カード表示" class="on" data-view="cards" data-stat-view-target="cardsBtn" data-action="stat-view#show">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/></svg>
        </button>
        <button type="button" title="テーブル表示" data-view="table" data-stat-view-target="tableBtn" data-action="stat-view#show">
          <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3 10h18M11 10v9"/></svg>
        </button>
      </div>
    </div>

    <%# --- カード表示 --- %>
    <div data-stat-view-target="cards">
      <div class="md-pcgrid">
        <% [["チーム1", team1_players, @match.winning_team == 1], ["チーム2", team2_players, @match.winning_team == 2]].each do |label, players, win| %>
          <div class="md-teamcol">
            <div class="th"><%= label %><span class="md-tag <%= win ? "win" : "lose" %>"><%= win ? "WIN" : "LOSE" %></span></div>
            <% players.each do |player| %>
              <%= render "matches/md_pcard", player: player, is_winner: win, streaming: player.id == streaming_id %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# --- テーブル表示 --- %>
    <div data-stat-view-target="table" class="hidden">
      <% [[team1_players, 1], [team2_players, 2]].each do |players, team_num| %>
        <% is_winner = @match.winning_team == team_num %>
        <div style="margin-bottom:18px">
          <div class="md-teamtag-row">チーム<%= team_num %><span class="md-tag <%= is_winner ? "win" : "lose" %>"><%= is_winner ? "WIN" : "LOSE" %></span></div>
          <div class="md-sttable-wrap">
            <table class="md-st">
              <thead>
                <tr>
                  <% row_span = survival_col_count > 0 ? 2 : 1 %>
                  <th class="l" rowspan="<%= row_span %>">プレイヤー</th>
                  <th rowspan="<%= row_span %>">スコア</th>
                  <th rowspan="<%= row_span %>">撃墜</th>
                  <th rowspan="<%= row_span %>">被撃墜</th>
                  <th rowspan="<%= row_span %>">与ダメージ</th>
                  <th rowspan="<%= row_span %>">被ダメージ</th>
                  <th rowspan="<%= row_span %>">EXダメージ</th>
                  <th rowspan="<%= row_span %>">EX回数</th>
                  <th rowspan="<%= row_span %>">EX中被撃墜</th>
                  <th rowspan="<%= row_span %>">EX残し</th>
                  <% if survival_col_count > 0 %><th colspan="<%= survival_col_count %>" style="text-align:center">生存時間</th><% end %>
                </tr>
                <% if survival_col_count > 0 %>
                  <tr><% survival_col_count.times do |n| %><th style="text-align:center"><%= n + 1 %>機目</th><% end %></tr>
                <% end %>
              </thead>
              <tbody>
                <% players.each do |player| %>
                  <% st = player.survival_times || [] %>
                  <tr>
                    <td class="l"><span class="md-rankb <%= "r1" if player.match_rank == 1 %>"><%= player.match_rank %></span> <%= player.user.nickname %></td>
                    <td><%= number_with_delimiter(player.score) if player.score %></td>
                    <td><%= player.kills %></td>
                    <td><%= player.deaths %></td>
                    <td><%= number_with_delimiter(player.damage_dealt) if player.damage_dealt %></td>
                    <td><%= number_with_delimiter(player.damage_received) if player.damage_received %></td>
                    <td><%= number_with_delimiter(player.exburst_damage) if player.exburst_damage %></td>
                    <td><%= player.exburst_count %></td>
                    <td><%= player.exburst_deaths %></td>
                    <td>
                      <% if is_winner %>―
                      <% elsif player.last_death_ex_available || player.survive_loss_ex_available %><span class="md-tdmark dead">あり</span>
                      <% elsif player.last_death_ex_available == false || player.survive_loss_ex_available == false %>なし
                      <% else %>―<% end %>
                    </td>
                    <% survival_col_count.times do |n| %>
                      <td>
                        <% if n >= st.size %>―
                        <% else %>
                          <% alive = (n == st.size - 1 && st.size > player.deaths.to_i) %>
                          <span class="md-tdmark <%= alive ? "alive" : "dead" %>"><%= alive ? "生存" : "被撃破" %></span><%= format_survival_cs(st[n]) %>
                        <% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <% unless is_winner %><div class="md-stnote">※ EX残し: 敗北チームのみ・EXバーストを持ったまま敗戦</div><% end %>
          <% ol_flag = team_num == 1 ? @match.team1_ex_overlimit_before_end : @match.team2_ex_overlimit_before_end %>
          <% unless ol_flag.nil? %>
            <div class="md-pc-foot" style="margin-top:8px">
              <span class="md-chiplab">EXオーバーリミット
                <% if ol_flag %><b><%= is_winner ? "OL未発動で勝利" : "OL未発動で敗北" %></b><% else %><b>OL発動あり</b><% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== タイムライン（既存 match-timeline コントローラを内包） ===== %>
<% if @match.match_timeline %>
  <%
    _raw = @match.match_timeline.timeline_raw
    _player_order = _raw["_player_order"]
    if _player_order
      _name_to_mp = @match.match_players.each_with_object({}) { |mp, h| h[mp.user.nickname] = mp }
      _key_to_mp = {}
      (_player_order["team1"] || []).each_with_index { |name, i| mp = _name_to_mp[name]; _key_to_mp["team1-#{i + 1}"] = mp if mp }
      (_player_order["team2"] || []).each_with_index { |name, i| mp = _name_to_mp[name]; _key_to_mp["team2-#{i + 1}"] = mp if mp }
      _group_order = _key_to_mp.keys.sort_by { |k| mp = _key_to_mp[k]; mp ? [mp.team_number, mp.position] : [99, 99] }
      _team_info = _key_to_mp.transform_values(&:team_number)
      _winner_keys = _group_order.select { |k| _team_info[k] == @match.winning_team }
      _timeline_data = _raw.merge("group_order" => _group_order, "team_info" => _team_info, "winner_keys" => _winner_keys)
    else
      _group_order = (team1_players.each_with_index.map { |_, i| "team1-#{i + 1}" } + team2_players.each_with_index.map { |_, i| "team2-#{i + 1}" })
      _winner_prefix = "team#{@match.winning_team}-"
      _winner_keys = _group_order.select { |k| k.start_with?(_winner_prefix) }
      _timeline_data = _raw.merge("group_order" => _group_order, "winner_keys" => _winner_keys)
    end
  %>
  <div class="md-sec">
    <h2>タイムライン</h2>
    <div class="md-tlpanel">
      <div class="overflow-x-auto" data-controller="match-timeline" data-match-timeline-json-value="<%= _timeline_data.to_json %>"></div>
      <div class="mt-4 space-y-3 text-xs font-semibold text-muted">
        <div>
          <span class="font-black text-subtle">上段 / EXバースト系</span>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2">
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-ex"></span>EXバースト発動可能域</span>
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-f"></span>ファイティングバースト</span>
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-s"></span>シューティングバースト</span>
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-e"></span>エクステンドバースト</span>
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-legend-swatch-wide timeline-xb"></span>EXバーストクロス</span>
          </div>
        </div>
        <div>
          <span class="font-black text-subtle">下段 / EXオーバーリミット系</span>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2">
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-ov"></span>EXオーバーリミット発動可能域</span>
            <span class="flex items-center gap-1.5"><span class="timeline-legend-swatch timeline-ov-active"></span>EXオーバーリミット発動中</span>
          </div>
        </div>
        <div>
          <span class="font-black text-subtle">マーカー</span>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2">
            <span class="flex items-center gap-1.5"><span class="timeline-marker">x</span>被撃墜</span>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="md-rbar">
  <%= render "reactions/reaction_bar", match: @match %>
</div>
