<turbo-frame id="matches-content" data-turbo-action="advance">
  <div <%= 'data-controller="bulk-select"'.html_safe if current_user.is_admin? %>>
    <div class="m-pagehead">
      <div>
        <h1>対戦履歴</h1>
        <div class="m-sub">試合の一覧を表示・フィルタリングできます。</div>
      </div>
      <% if current_user.is_admin? %>
        <div style="display:flex;flex-wrap:wrap;gap:8px">
          <% if @latest_event %>
            <%= link_to "新規登録", new_event_match_path(@latest_event), class: "m-btn m-btn-primary", data: { turbo_frame: "_top" } %>
          <% end %>
          <%= link_to "CSVインポート", new_admin_import_path, class: "m-btn-ghost", data: { turbo_frame: "_top" } %>
        </div>
      <% end %>
    </div>

    <%
      bp = {
        sort: @sort,
        per: @per_page,
        flip_team: @flip_team ? "1" : nil,
        only_favorites: @filter_only_favorites ? "1" : nil,
        stat_player_id: @filter_stat_player_id,
        ol_filter: @filter_ol_filter,
        stat_filters: @filter_stat_filters,
        damage_dealt_val: @filter_damage_dealt_val,
        damage_dealt_dir: @filter_damage_dealt_dir,
        damage_received_val: @filter_damage_received_val,
        damage_received_dir: @filter_damage_received_dir
      }
      cur = {
        events: @filter_events,
        users: @filter_users,
        users_mode: @filter_users_mode,
        streaming_users: @filter_streaming_users,
        mobile_suits: @filter_mobile_suits,
        costs: @filter_costs,
        suit_scope: @filter_suit_scope == "mine" ? "mine" : nil,
        team_player_ids: @filter_team_player_ids
      }
      all_params = bp.merge(cur)
      chip_on = "mh-ch on"
      chip_off = "mh-ch"
      toggle = ->(key, val, extra = {}) {
        arr = cur[key]
        new_arr = arr.include?(val) ? arr - [val] : arr + [val]
        matches_path(all_params.merge(key => new_arr).merge(extra))
      }
    %>

    <%
      stat_active = @filter_ol_filter.present? || @filter_stat_filters.any? || @filter_stat_player_id.present? || @filter_damage_dealt_val.present? || @filter_damage_received_val.present?
      active_count = [
        @filter_events.any?, @filter_users.any?, @filter_team_player_ids.any?,
        @filter_streaming_users.any?, (@filter_costs.any? || @filter_mobile_suits.any?),
        @filter_only_favorites, stat_active
      ].count(true)
    %>
    <details class="mh-filterbox" <%= "open" if active_count.positive? %>>
      <summary>
        <span class="mh-filterbar-l">
          <svg viewBox="0 0 24 24"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
          フィルター
          <% if active_count.positive? %>
            <span class="badge"><%= active_count %></span>
          <% else %>
            <span class="muted">すべて表示</span>
          <% end %>
        </span>
        <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      </summary>

    <div class="mh-fpanel">
      <div class="mh-frow">
        <div class="mh-fk">イベント</div>
        <div class="mh-chips">
          <%= link_to "全イベント", matches_path(all_params.merge(events: [])), class: @filter_events.empty? ? chip_on : chip_off %>
          <% @all_events.each do |event| %>
            <%= link_to event.name, toggle.call(:events, event.id), class: @filter_events.include?(event.id) ? chip_on : chip_off %>
          <% end %>
        </div>
      </div>

      <div class="mh-frow">
        <div class="mh-fk">参加</div>
        <div class="mh-chips">
          <div class="mh-seg">
            <%= link_to "OR", matches_path(all_params.merge(users_mode: "or")), class: class_names(@filter_users_mode == "or" && "on") %>
            <%= link_to "AND", matches_path(all_params.merge(users_mode: "and")), class: class_names(@filter_users_mode == "and" && "on") %>
          </div>
          <%= link_to "全員", matches_path(all_params.merge(users: [])), class: @filter_users.empty? ? chip_on : chip_off %>
          <% @all_users.each do |user| %>
            <%= link_to user.nickname, toggle.call(:users, user.id), class: @filter_users.include?(user.id) ? chip_on : chip_off %>
          <% end %>
        </div>
      </div>

      <%
        team_toggle = ->(user_id) {
          if @filter_team_player_ids.include?(user_id)
            matches_path(all_params.merge(team_player_ids: @filter_team_player_ids - [user_id]))
          elsif @filter_team_player_ids.length < 2
            matches_path(all_params.merge(team_player_ids: @filter_team_player_ids + [user_id]))
          else
            matches_path(all_params.merge(team_player_ids: [@filter_team_player_ids[1], user_id]))
          end
        }
      %>
      <div class="mh-frow">
        <div class="mh-fk">同チーム</div>
        <div class="mh-chips">
          <% @all_users.each do |user| %>
            <%= link_to user.nickname, team_toggle.call(user.id), class: @filter_team_player_ids.include?(user.id) ? chip_on : chip_off %>
          <% end %>
          <% if @filter_team_player_ids.any? %>
            <%= link_to "クリア", matches_path(all_params.merge(team_player_ids: [])), class: "mh-ch danger" %>
          <% end %>
        </div>
      </div>

      <% visible_streaming = @filter_users.any? ? @all_users.select { |u| @filter_users.include?(u.id) } : @all_users %>
      <div class="mh-frow">
        <div class="mh-fk">配信台</div>
        <div class="mh-chips">
          <%= link_to "全員", matches_path(all_params.merge(streaming_users: [])), class: @filter_streaming_users.empty? ? chip_on : chip_off %>
          <% visible_streaming.each do |user| %>
            <%= link_to user.nickname, toggle.call(:streaming_users, user.id), class: @filter_streaming_users.include?(user.id) ? chip_on : chip_off %>
          <% end %>
        </div>
      </div>

      <div class="mh-frow">
        <div class="mh-fk">機体・コスト</div>
        <div class="mh-chips">
          <% if @filter_mobile_suits.any? || @filter_costs.any? %>
            <div class="mh-seg">
              <%= link_to "全員", matches_path(all_params.merge(suit_scope: nil)), class: class_names(@filter_suit_scope != "mine" && "on") %>
              <%= link_to "自分のみ", matches_path(all_params.merge(suit_scope: "mine")), class: class_names(@filter_suit_scope == "mine" && "on") %>
            </div>
          <% end %>

          <div class="mh-cseg">
            <%= link_to "全体", matches_path(all_params.merge(costs: [], mobile_suits: [], suit_scope: nil)),
                class: class_names(@filter_costs.empty? && @filter_mobile_suits.empty? && "on") %>
            <% [3000, 2500, 2000, 1500].each do |cost| %>
              <% active = @filter_costs == [cost] && @filter_mobile_suits.empty? %>
              <% cost_url = active ? matches_path(all_params.merge(costs: [], mobile_suits: [], suit_scope: nil)) : matches_path(all_params.merge(costs: [cost], mobile_suits: [])) %>
              <%= link_to cost.to_s, cost_url, class: class_names("c#{cost}", active && "on") %>
            <% end %>
          </div>

          <% visible_suits = @filter_costs.any? ? @all_mobile_suits.select { |s| @filter_costs.include?(s.cost) } : @all_mobile_suits %>
          <select id="match-suit-select" class="mh-fsearch" data-controller="suit-select" data-has-favorites="<%= viewing_as_user&.user_favorite_suits&.any? %>">
            <option value="">機体を検索...</option>
            <%= mobile_suit_options_with_favorites(visible_suits, viewing_as_user, @filter_mobile_suits) %>
          </select>

          <% unless @filter_costs.empty? && @filter_mobile_suits.empty? %>
            <%= link_to "クリア", matches_path(all_params.merge(costs: [], mobile_suits: [], suit_scope: nil)), class: "mh-ch danger" %>
          <% end %>
        </div>
      </div>

      <%
        fav_suits = viewing_as_user&.user_favorite_suits&.order(:slot)&.includes(:mobile_suit)&.to_a || []
        fav_toggle = ->(suit_id) {
          new_arr = @filter_mobile_suits.include?(suit_id) ? @filter_mobile_suits - [suit_id] : @filter_mobile_suits + [suit_id]
          matches_path(all_params.merge(mobile_suits: new_arr, suit_scope: new_arr.any? ? "mine" : nil))
        }
      %>
      <% if fav_suits.any? %>
        <div class="mh-frow">
          <div class="mh-fk">お気に入り機体</div>
          <div class="mh-chips">
            <% fav_suits.each do |fav| %>
              <%= link_to fav.mobile_suit.name, fav_toggle.call(fav.mobile_suit.id), class: @filter_mobile_suits.include?(fav.mobile_suit.id) ? chip_on : chip_off %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if viewing_as_user&.regular_user? %>
        <div class="mh-frow">
          <div class="mh-fk">お気に入り試合</div>
          <div class="mh-chips">
            <%= link_to "保存済みのみ", matches_path(all_params.merge(only_favorites: @filter_only_favorites ? nil : "1", page: nil)), class: @filter_only_favorites ? chip_on : chip_off %>
          </div>
        </div>
      <% end %>

      <% stat_section_active = @filter_ol_filter.present? || @filter_stat_filters.any? || @filter_stat_player_id.present? || @filter_damage_dealt_val.present? || @filter_damage_received_val.present? %>
      <details class="mh-fmore" <%= "open" if stat_section_active %>>
        <summary>
          <span class="lab">
            <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/></svg>
            詳細条件
            <% if stat_section_active %><span class="badge">設定中</span><% end %>
          </span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8b93a6" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </summary>

        <div class="px-3 pb-3 pt-2">
          <%= form_with url: matches_path, method: :get, local: true, class: "space-y-4" do |form| %>
            <% @filter_events.each do |id| %><input type="hidden" name="events[]" value="<%= id %>"><% end %>
            <% @filter_users.each do |id| %><input type="hidden" name="users[]" value="<%= id %>"><% end %>
            <input type="hidden" name="users_mode" value="<%= @filter_users_mode %>">
            <% @filter_streaming_users.each do |id| %><input type="hidden" name="streaming_users[]" value="<%= id %>"><% end %>
            <% @filter_mobile_suits.each do |id| %><input type="hidden" name="mobile_suits[]" value="<%= id %>"><% end %>
            <% @filter_costs.each do |c| %><input type="hidden" name="costs[]" value="<%= c %>"><% end %>
            <% if @filter_suit_scope == "mine" %><input type="hidden" name="suit_scope" value="mine"><% end %>
            <% if @flip_team %><input type="hidden" name="flip_team" value="1"><% end %>
            <% if @filter_only_favorites %><input type="hidden" name="only_favorites" value="1"><% end %>
            <% @filter_team_player_ids.each do |id| %><input type="hidden" name="team_player_ids[]" value="<%= id %>"><% end %>
            <input type="hidden" name="sort" value="<%= @sort %>">
            <input type="hidden" name="per" value="<%= @per_page %>">

            <div>
              <label class="ui-label">対象プレイヤー</label>
              <select name="stat_player_id" class="ui-form-control max-w-xs">
                <option value="">指定なし</option>
                <% @all_users.each do |user| %>
                  <option value="<%= user.id %>" <%= "selected" if @filter_stat_player_id == user.id %>><%= user.nickname %></option>
                <% end %>
              </select>
            </div>

            <div>
              <label class="ui-label">OL条件</label>
              <div class="ui-segment flex-wrap">
                <% [["", "指定なし"], ["ol_unused_win", "OL未発動勝利"], ["ol_unused_loss", "OL未発動敗北"]].each do |value, label| %>
                  <label class="cursor-pointer">
                    <input type="radio" name="ol_filter" value="<%= value %>" <%= "checked" if @filter_ol_filter.to_s == value %> class="peer sr-only">
                    <span class="ui-segment-item"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div>
              <label class="ui-label">EX条件</label>
              <div class="flex flex-wrap gap-2">
                <% [["ex_leftover_win", "EXバーストを使わせず勝利"], ["ex_leftover_loss", "EXバーストを残して敗北"], ["exburst_death", "EXバースト中被撃墜あり"]].each do |value, label| %>
                  <label class="cursor-pointer select-none">
                    <input type="checkbox" name="stat_filters[]" value="<%= value %>" <%= "checked" if @filter_stat_filters.include?(value) %> class="peer sr-only">
                    <span class="ui-chip peer-checked:bg-accent peer-checked:text-on-accent"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div>
              <label class="ui-label">ダメージ</label>
              <div class="grid gap-3 md:grid-cols-2">
                <div class="rounded-lg bg-bg p-3 shadow-inner-soft">
                  <span class="mb-2 block text-xs font-black text-subtle">与ダメ</span>
                  <input type="number" name="damage_dealt_val" min="0" placeholder="なし" value="<%= @filter_damage_dealt_val %>" class="ui-form-control">
                  <div class="ui-segment mt-2">
                    <% [["gte", "以上"], ["lte", "以下"]].each do |value, label| %>
                      <label class="cursor-pointer">
                        <input type="radio" name="damage_dealt_dir" value="<%= value %>" <%= "checked" if (value == "gte" && @filter_damage_dealt_dir != "lte") || @filter_damage_dealt_dir == value %> class="peer sr-only">
                        <span class="ui-segment-item"><%= label %></span>
                      </label>
                    <% end %>
                  </div>
                </div>

                <div class="rounded-lg bg-bg p-3 shadow-inner-soft">
                  <span class="mb-2 block text-xs font-black text-subtle">被ダメ</span>
                  <input type="number" name="damage_received_val" min="0" placeholder="なし" value="<%= @filter_damage_received_val %>" class="ui-form-control">
                  <div class="ui-segment mt-2">
                    <% [["gte", "以上"], ["lte", "以下"]].each do |value, label| %>
                      <label class="cursor-pointer">
                        <input type="radio" name="damage_received_dir" value="<%= value %>" <%= "checked" if (value == "gte" && @filter_damage_received_dir != "lte") || @filter_damage_received_dir == value %> class="peer sr-only">
                        <span class="ui-segment-item"><%= label %></span>
                      </label>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap justify-end gap-3">
              <%= link_to "クリア", matches_path(all_params.merge(stat_player_id: nil, ol_filter: nil, stat_filters: [], damage_dealt_val: nil, damage_received_val: nil)), class: "m-btn-ghost" %>
              <%= form.submit "適用", class: "m-btn m-btn-primary cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </details>
    </div>
    </details>

    <% if current_user.is_admin? && @matches.any? %>
      <%= form_with url: bulk_destroy_matches_path, method: :delete, id: "bulk-delete-form", class: "mb-0" do |f| %>
        <div class="mh-selbar">
          <button type="button" class="mh-seltoggle" data-bulk-select-target="toggle" data-action="bulk-select#toggleMode">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 11l3 3 8-8M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h9"/></svg>
            <span class="lbl-off">選択</span>
            <span class="lbl-on">選択モードを終了</span>
          </button>
          <div class="mh-selactions" data-bulk-select-target="actions" hidden>
            <label class="mh-selall">
              <input type="checkbox" data-bulk-select-target="all" data-action="bulk-select#toggleAll">
              すべて選択
            </label>
            <span class="mh-selcount" data-bulk-select-target="count">0件選択中</span>
            <%= button_tag "選択した試合を削除", type: "submit", class: "m-btn-ghost", style: "color:var(--color-neg)", data: { turbo_confirm: "選択した試合を削除してもよろしいですか？" } %>
          </div>
        </div>
      <% end %>
    <% end %>

    <div class="mh-toolbar">
      <div class="m-cnt">全 <b><%= @matches.total_count %></b> 試合</div>
      <div class="right">
        <% if viewing_as_user&.regular_user? %>
          <%= link_to "⇆ 自チームを左に", matches_path(all_params.merge(flip_team: @flip_team ? nil : "1", page: nil)),
              title: "自分が参加した試合で、自チームを左側に表示します",
              class: class_names("mh-ch", @flip_team && "on") %>
        <% end %>
        <div class="mh-seg">
          <% [["latest", "新しい順"], ["oldest", "古い順"], ["reactions", "リアクション順"]].each do |value, label| %>
            <%= link_to label, matches_path(all_params.merge(sort: value)), class: class_names(value == @sort && "on") %>
          <% end %>
        </div>
        <%= render "shared/per_page_selector", per_page: @per_page, url_builder: ->(n) { matches_path(all_params.merge(per: n)) } %>
      </div>
    </div>

    <% if @matches.any? %>
      <div class="mh-list">
        <% @matches.each do |match| %>
          <%
            all_mp = match.match_players.sort_by { |mp| [mp.team_number, mp.position] }
            team1 = all_mp.select { |mp| mp.team_number == 1 }
            team2 = all_mp.select { |mp| mp.team_number == 2 }
            streaming_id = team1.first&.id

            if @flip_team && viewing_as_user
              user_team = all_mp.find { |mp| mp.user_id == viewing_as_user.id }&.team_number
              if user_team == 2
                left_players, right_players = team2, team1
                left_wins = match.winning_team == 2
              else
                left_players, right_players = team1, team2
                left_wins = match.winning_team == 1
              end
              left_label = "自チーム"; right_label = "相手チーム"
            else
              left_players, right_players = team1, team2
              left_wins = match.winning_team == 1
              left_label = "チーム1"; right_label = "チーム2"
            end
          %>
          <div class="mh-card <%= "admin" if current_user.is_admin? %>"<%= ' data-bulk-select-target="card" data-action="click->bulk-select#cardClick"'.html_safe if current_user.is_admin? %>>
            <%= link_to "", match_path(match), class: "mh-cardlink", "aria-label": "試合詳細を見る", data: { turbo_frame: "_top" } %>
            <% if current_user.is_admin? %>
              <span class="mh-selmark" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M5 12l5 5 9-9"/></svg>
              </span>
              <input type="checkbox" name="match_ids[]" value="<%= match.id %>" form="bulk-delete-form" class="sr-only" data-bulk-select-target="item" tabindex="-1" aria-hidden="true">
            <% end %>

            <div class="mh-meta">
              <span class="date"><%= match.played_at.strftime("%Y年%m月%d日") %></span>
              <span class="epill"><%= match.event.name %></span>
              <% if match.video_url %>
                <%= render "shared/broadcast_link", url: match.video_url, link_class: "vid" %>
              <% end %>
              <span class="favslot">
                <%= render "favorite_matches/favorite_button", match: match, is_favorited: @my_favorite_match_ids.include?(match.id) %>
              </span>
            </div>

            <%= render "matches/mh_teams",
                  left_players: left_players, right_players: right_players,
                  left_wins: left_wins, left_label: left_label, right_label: right_label,
                  streaming_player_id: streaming_id %>

            <div class="mh-rbar">
              <%= turbo_stream_from "match_#{match.id}_reactions_compact" %>
              <%= render "reactions/reaction_bar", match: match, compact: true, emojis: @emojis %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @matches.respond_to?(:total_pages) && @matches.total_pages > 1 %>
        <div class="flex flex-col items-center gap-4 pt-6">
          <%= paginate @matches, params: { per: @per_page, sort: @sort } %>
          <%= render "shared/per_page_selector", per_page: @per_page, url_builder: ->(n) { matches_path(all_params.merge(per: n)) } %>
        </div>
      <% end %>
    <% else %>
      <div class="m-panel m-pbody text-center">
        <p class="text-sm font-bold text-muted">対戦記録がまだありません</p>
      </div>
    <% end %>
  </div>
</turbo-frame>
