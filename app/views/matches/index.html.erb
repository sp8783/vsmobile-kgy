                <% team2_players = match.match_players.where(team_number: 2).order(:position) %>

                <!-- Team 1 -->
                <div class="<%= match.winning_team == 1 ? 'bg-blue-50 border-2 border-blue-400 rounded p-2' : 'bg-red-50 border-2 border-red-400 rounded p-2' %>">
