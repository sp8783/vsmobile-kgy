                    <img src="/youtube_social_icon_red.png" alt="YouTube" class="h-3.5">
                    配信を見る
                  <% end %>
                <% end %>
              </div>
            </div>

            <%= link_to match_path(match), class: "block" do %>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
