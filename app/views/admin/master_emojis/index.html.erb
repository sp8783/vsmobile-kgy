<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="ui-eyebrow">Reactions</p>
      <h1 class="ui-title">スタンプマスタ</h1>
      <p class="ui-subtitle">リアクションで使用できるスタンプの一覧を管理できます。</p>
    </div>
    <% if current_user.is_admin? %>
      <%= link_to "新規登録", new_admin_master_emoji_path, class: "ui-btn ui-btn-primary" %>
    <% end %>
  </div>

  <div class="mobile-only-view space-y-3">
    <% @master_emojis.each do |master_emoji| %>
      <div class="ui-card p-4">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <span class="text-2xl">
              <% if master_emoji.asset_image? %>
                <%= image_tag "emojis/#{master_emoji.image_key}", class: "h-8 w-8", alt: master_emoji.name %>
              <% else %>
                <%= master_emoji.image_key %>
              <% end %>
            </span>
            <div>
              <p class="text-sm font-black text-ink"><%= master_emoji.name %></p>
              <p class="mt-1 text-xs font-bold text-subtle">
                使用数: <%= master_emoji.reactions.count %>件
                <% if master_emoji.position.present? %>
                  / 表示順: <%= master_emoji.position %>
                <% end %>
              </p>
            </div>
          </div>
          <span class="ui-chip <%= master_emoji.is_active ? 'ui-chip-active' : '' %>"><%= master_emoji.is_active ? "有効" : "無効" %></span>
        </div>
        <% if current_user.is_admin? %>
          <div class="mt-3 flex flex-wrap gap-2">
            <%= link_to "編集", edit_admin_master_emoji_path(master_emoji), class: "ui-btn ui-btn-small ui-btn-secondary" %>
            <%= button_to "削除", admin_master_emoji_path(master_emoji), method: :delete, data: { turbo_confirm: "本当に削除しますか？関連するリアクションもすべて削除されます。" }, class: "ui-btn ui-btn-small ui-btn-danger" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="desktop-only-view ui-card p-3">
    <div class="overflow-x-auto">
      <table class="ui-data-table">
        <thead>
          <tr>
            <th>プレビュー</th>
            <th>名前</th>
            <th>image_key</th>
            <th>表示順</th>
            <th>状態</th>
            <th>使用数</th>
            <% if current_user.is_admin? %>
              <th>操作</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @master_emojis.each do |master_emoji| %>
            <tr>
              <td class="text-2xl">
                <% if master_emoji.asset_image? %>
                  <%= image_tag "emojis/#{master_emoji.image_key}", class: "h-8 w-8", alt: master_emoji.name %>
                <% else %>
                  <%= master_emoji.image_key %>
                <% end %>
              </td>
              <td class="font-black"><%= master_emoji.name %></td>
              <td class="font-bold text-muted"><%= master_emoji.image_key %></td>
              <td class="font-bold text-muted"><%= master_emoji.position || "-" %></td>
              <td><span class="ui-chip <%= master_emoji.is_active ? 'ui-chip-active' : '' %>"><%= master_emoji.is_active ? "有効" : "無効" %></span></td>
              <td class="font-bold text-muted"><%= master_emoji.reactions.count %>件</td>
              <% if current_user.is_admin? %>
                <td>
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "編集", edit_admin_master_emoji_path(master_emoji), class: "ui-btn ui-btn-small ui-btn-secondary" %>
                    <%= button_to "削除", admin_master_emoji_path(master_emoji), method: :delete, data: { turbo_confirm: "本当に削除しますか？関連するリアクションもすべて削除されます。" }, class: "ui-btn ui-btn-small ui-btn-danger" %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @master_emojis.empty? %>
    <div class="ui-card p-8 text-center">
      <p class="text-sm font-bold text-muted">スタンプがまだ登録されていません</p>
      <%= link_to "最初のスタンプを登録する", new_admin_master_emoji_path, class: "ui-btn ui-btn-primary mt-4" %>
    </div>
  <% else %>
    <p class="mt-4 text-sm font-bold text-muted">全 <%= @master_emojis.count %> スタンプ</p>
  <% end %>
</div>
