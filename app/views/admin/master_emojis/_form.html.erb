<%= form_with(model: [:admin, master_emoji], class: "space-y-5") do |form| %>
  <% if master_emoji.errors.any? %>
    <div class="ui-alert ui-alert-danger">
      <p class="font-black"><%= pluralize(master_emoji.errors.count, "個のエラー") %>があります</p>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% master_emoji.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "名前", class: "ui-label" %>
    <%= form.text_field :name, class: "ui-form-control", placeholder: "例: いいね" %>
  </div>

  <div>
    <%= form.label :image_key, "絵文字/画像キー", class: "ui-label" %>
    <%= form.text_field :image_key, class: "ui-form-control", placeholder: "例: 👍 または custom.png" %>
    <p class="mt-2 text-xs font-bold text-subtle">
      絵文字を直接入力するか、アセット画像のファイル名を指定してください。アセット画像は app/assets/images/emojis/ に配置します。
    </p>
  </div>

  <div>
    <%= form.label :position, "表示順", class: "ui-label" %>
    <%= form.number_field :position, class: "ui-form-control", placeholder: "例: 1" %>
    <p class="mt-2 text-xs font-bold text-subtle">小さい数字ほど先に表示されます。空欄の場合は末尾に表示されます。</p>
  </div>

  <label class="flex cursor-pointer items-center gap-3 rounded-lg bg-bg p-3 shadow-inner-soft">
    <%= form.check_box :is_active, class: "h-4 w-4 rounded text-accent focus:ring-accent" %>
    <span class="text-sm font-bold text-ink">有効（ユーザーがリアクションで使用可能）</span>
  </label>

  <% if master_emoji.persisted? && master_emoji.image_key.present? %>
    <div class="rounded-lg bg-bg p-4 shadow-inner-soft">
      <p class="mb-2 text-sm font-black text-ink">プレビュー</p>
      <div class="text-4xl">
        <% if master_emoji.asset_image? %>
          <%= image_tag "emojis/#{master_emoji.image_key}", class: "h-12 w-12", alt: master_emoji.name %>
        <% else %>
          <%= master_emoji.image_key %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="flex flex-wrap justify-end gap-3">
    <%= link_to "キャンセル", admin_master_emojis_path, class: "ui-btn ui-btn-secondary" %>
    <%= form.submit master_emoji.new_record? ? "登録" : "更新", class: "ui-btn ui-btn-primary cursor-pointer" %>
  </div>
<% end %>
