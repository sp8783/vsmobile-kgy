<div class="py-8">
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Discord チャンネル設定</h1>
    <p class="mt-2 text-sm text-gray-600">用途ごとに投稿先の Webhook URL を設定します。未設定のチャンネルへは投稿されません。</p>
  </div>

  <div class="space-y-4">
    <% @channels.each do |channel| %>
      <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6">
          <h2 class="text-base font-semibold text-gray-900"><%= channel.purpose_label %></h2>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
          <%= form_with model: [:admin, channel], url: admin_discord_channel_path(channel.purpose), method: :patch, class: "space-y-4" do |f| %>
            <div>
              <%= f.label :label, "チャンネル名（任意・メモ用）", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :label, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500", placeholder: "例: #vsmobile-通知" %>
            </div>
            <div>
              <%= f.label :webhook_url, "Webhook URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.url_field :webhook_url, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono", placeholder: "https://discord.com/api/webhooks/..." %>
            </div>
            <div class="flex items-center gap-3">
              <%= f.submit "保存", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded text-sm cursor-pointer" %>
              <% if channel.webhook_url.present? %>
                <span class="text-xs text-green-600 font-medium">✓ 設定済み（<%= channel.label.present? ? channel.label : channel.webhook_url.truncate(40) %>）</span>
              <% else %>
                <span class="text-xs text-gray-400">未設定</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
