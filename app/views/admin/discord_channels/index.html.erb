<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="text-xs font-black uppercase tracking-wide text-subtle">Integrations</p>
      <h1 class="font-display text-3xl font-black text-ink">Discord チャンネル設定</h1>
      <p class="mt-2 text-sm font-semibold text-muted">用途ごとに投稿先の Webhook URL を設定します。未設定のチャンネルへは投稿されません。</p>
    </div>
  </div>

  <div class="grid gap-4">
    <% @channels.each do |channel| %>
      <%= render Ui::CardComponent.new(title: channel.purpose_label, padded: true) do %>
        <%= form_with model: [:admin, channel], url: admin_discord_channel_path(channel.purpose), method: :patch, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :label, "チャンネル名（任意・メモ用）", class: "ui-label" %>
            <%= f.text_field :label, class: "ui-form-control", placeholder: "例: #vsmobile-通知" %>
          </div>
          <div>
            <%= f.label :webhook_url, "Webhook URL", class: "ui-label" %>
            <%= f.url_field :webhook_url, class: "ui-form-control font-mono", placeholder: "https://discord.com/api/webhooks/..." %>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <%= f.submit "保存", class: "ui-btn ui-btn-primary ui-btn-small cursor-pointer" %>
            <% if channel.webhook_url.present? %>
              <span class="inline-flex items-center gap-2 text-xs font-black text-accent">
                <span class="pulse-dot"></span>
                設定済み（<%= channel.label.present? ? channel.label : channel.webhook_url.truncate(40) %>）
              </span>
            <% else %>
              <span class="text-xs font-bold text-subtle">未設定</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
