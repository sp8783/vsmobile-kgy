<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="text-xs font-black uppercase tracking-wide text-subtle">Master Data</p>
      <h1 class="font-display text-3xl font-black text-ink">機体マスタ</h1>
      <p class="mt-2 text-sm font-semibold text-muted">使用できる機体の一覧を管理できます</p>
    </div>
    <% if current_user.is_admin? %>
      <div class="flex flex-wrap gap-2">
        <%= link_to "新規登録", new_admin_mobile_suit_path, class: "ui-btn ui-btn-primary" %>
        <%= link_to "CSVインポート", new_mobile_suits_admin_imports_path, class: "ui-btn ui-btn-muted" %>
      </div>
    <% end %>
  </div>

  <div class="mobile-only-view space-y-3">
    <% @mobile_suits.each do |mobile_suit| %>
      <%= render Ui::CardComponent.new(padded: true) do %>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="truncate text-sm font-black text-ink"><%= mobile_suit.name %></p>
            <p class="mt-1 truncate text-xs font-semibold text-muted"><%= mobile_suit.series %></p>
          </div>
          <%= cost_badge(mobile_suit.cost) %>
        </div>
        <% if current_user.is_admin? %>
          <div class="mt-4 flex items-center gap-2">
            <%= link_to "編集", edit_admin_mobile_suit_path(mobile_suit), class: "ui-btn ui-btn-muted ui-btn-small" %>
            <%= button_to "削除",
                admin_mobile_suit_path(mobile_suit),
                method: :delete,
                data: { turbo_confirm: "本当に削除しますか？" },
                form: { class: "contents" },
                class: "ui-btn ui-btn-danger ui-btn-small" %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%= render Ui::CardComponent.new(padded: false, class_name: "desktop-only-view overflow-hidden") do %>
    <div class="overflow-x-auto">
      <table class="ui-data-table table-min-md">
        <thead>
          <tr>
            <th scope="col">機体名</th>
            <th scope="col">シリーズ</th>
            <th scope="col">コスト</th>
            <% if current_user.is_admin? %>
              <th scope="col">操作</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @mobile_suits.each do |mobile_suit| %>
            <tr>
              <td class="font-black text-ink"><%= mobile_suit.name %></td>
              <td class="text-muted"><%= mobile_suit.series %></td>
              <td><%= cost_badge(mobile_suit.cost) %></td>
              <% if current_user.is_admin? %>
                <td>
                  <div class="flex items-center gap-2">
                    <%= link_to "編集", edit_admin_mobile_suit_path(mobile_suit), class: "ui-btn ui-btn-muted ui-btn-small" %>
                    <%= button_to "削除",
                        admin_mobile_suit_path(mobile_suit),
                        method: :delete,
                        data: { turbo_confirm: "本当に削除しますか？" },
                        form: { class: "contents" },
                        class: "ui-btn ui-btn-danger ui-btn-small" %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <p class="text-sm font-semibold text-muted">全 <span class="font-mono tabular-nums text-ink"><%= @mobile_suits.count %></span> 機体</p>
</div>
