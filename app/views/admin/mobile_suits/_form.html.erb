<%= form_with(model: [:admin, mobile_suit]) do |form| %>
  <% if mobile_suit.errors.any? %>
    <div class="mf-err">
      <h2><%= pluralize(mobile_suit.errors.count, "個のエラー") %>があります</h2>
      <ul>
        <% mobile_suit.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mf-field">
    <%= form.label :name, "機体名" %>
    <%= form.text_field :name, class: "mf-control", placeholder: "機体名を入力" %>
  </div>

  <div class="mf-field">
    <%= form.label :series, "シリーズ" %>
    <%= form.text_field :series, class: "mf-control" %>
  </div>

  <div class="mf-field">
    <%= form.label :cost, "コスト" %>
    <%= form.select :cost, [3000, 2500, 2000, 1500], {}, class: "mf-control" %>
  </div>

  <div class="mf-field">
    <%= form.label :wiki_url, "Wiki URL" %>
    <%= form.url_field :wiki_url, class: "mf-control", placeholder: "https://w.atwiki.jp/..." %>
  </div>

  <div class="mf-divider"><span class="lbl">スペック情報</span><span class="ln"></span></div>

  <div class="mf-specgrid">
    <div class="mf-field" style="margin-bottom:0">
      <%= form.label :durability, "耐久値" %>
      <%= form.number_field :durability, class: "mf-control", placeholder: "例: 620" %>
    </div>
    <div class="mf-field" style="margin-bottom:0">
      <%= form.label :bd_count, "BD回数" %>
      <%= form.text_field :bd_count, class: "mf-control", placeholder: "例: 8" %>
    </div>
    <div class="mf-field" style="margin-bottom:0">
      <%= form.label :red_lock_range, "赤ロック距離" %>
      <%= form.text_field :red_lock_range, class: "mf-control", placeholder: "例: A" %>
    </div>
  </div>

  <div class="mf-actions">
    <%= link_to "キャンセル", admin_mobile_suits_path, class: "m-btn m-btn-ghost" %>
    <%= form.submit mobile_suit.new_record? ? "登録" : "更新", class: "m-btn m-btn-primary cursor-pointer" %>
  </div>
<% end %>
