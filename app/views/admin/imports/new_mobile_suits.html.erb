<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <%= link_to "機体マスタに戻る", admin_mobile_suits_path, class: "ui-btn ui-btn-ghost ui-btn-small mb-3" %>
      <p class="text-xs font-black uppercase tracking-wide text-subtle">Import</p>
      <h1 class="font-display text-3xl font-black text-ink">機体マスタCSVインポート</h1>
    </div>
  </div>

  <% if alert %>
    <div class="ui-alert ui-alert-danger">
      <%= alert %>
    </div>
  <% end %>

  <%= render Ui::CardComponent.new(title: "CSVフォーマット", subtitle: "機体名が既に存在する場合は、コストとシリーズを更新します。") do %>
    <div class="rounded-lg bg-surface-2 p-4 font-mono text-xs font-semibold text-ink shadow-inner-soft">
      <p>機体名,コスト,シリーズ</p>
      <p class="mt-2 text-muted">フルアーマーZZガンダム,3000,機動戦士ガンダムZZ</p>
      <p class="mt-1 text-muted">キュベレイ,3000,機動戦士ガンダムZZ</p>
      <p class="mt-1 text-muted">νガンダム,3000,機動戦士ガンダム 逆襲のシャア</p>
    </div>
    <div class="mt-4 grid gap-2 text-sm font-semibold text-muted sm:grid-cols-2">
      <p>1行目はヘッダー行</p>
      <p>機体名は正式名称</p>
      <p>コストは 1500, 2000, 2500, 3000</p>
      <p>シリーズは作品名</p>
      <p>既存の機体名がある場合は更新</p>
      <p>UTF-8 エンコーディング推奨</p>
    </div>
  <% end %>

  <%= form_with url: import_mobile_suits_admin_imports_path, multipart: true, class: "space-y-4" do |form| %>
    <%= render Ui::CardComponent.new(title: "アップロード") do %>
      <label class="ui-label">CSVファイル</label>
      <%= file_field_tag :file, accept: ".csv", class: "ui-form-control" %>
    <% end %>

    <div class="flex justify-end gap-2">
      <%= link_to "キャンセル", admin_mobile_suits_path, class: "ui-btn ui-btn-muted" %>
      <%= submit_tag "インポート", class: "ui-btn ui-btn-primary", data: { turbo_confirm: "CSVファイルをインポートしますか？" } %>
    </div>
  <% end %>
</div>
