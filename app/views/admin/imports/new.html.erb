<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <%= link_to "イベント一覧に戻る", events_path, class: "ui-btn ui-btn-ghost ui-btn-small mb-3" %>
      <p class="text-xs font-black uppercase tracking-wide text-subtle">Import</p>
      <h1 class="font-display text-3xl font-black text-ink">試合データCSVインポート</h1>
    </div>
  </div>

  <% if alert %>
    <div class="ui-alert ui-alert-danger">
      <%= alert %>
    </div>
  <% end %>

  <%= render Ui::CardComponent.new(title: "CSVフォーマット", subtitle: "1行目はヘッダー行、UTF-8 エンコーディング推奨です。") do %>
    <div class="rounded-lg bg-surface-2 p-4 font-mono text-xs font-semibold text-ink shadow-inner-soft">
      <p class="break-words">日付,プレイヤー1,使用機体1,プレイヤー2,使用機体2,プレイヤー3,使用機体3,プレイヤー4,使用機体4,勝敗1,勝敗2,勝敗3,勝敗4</p>
      <p class="mt-2 break-words text-muted">2025/01/15,太郎,νガンダム,次郎,サザビー,三郎,Hi-νガンダム,四郎,ナイチンゲール,1,1,0,0</p>
    </div>
    <div class="mt-4 grid gap-2 text-sm font-semibold text-muted sm:grid-cols-2">
      <p>日付は「YYYY/MM/DD」または「YYYY-MM-DD」形式</p>
      <p>プレイヤー名はユーザー管理画面の表示名と完全一致</p>
      <p>機体名は機体マスタと完全一致</p>
      <p>勝敗は「1」(勝利)または「0」(敗北)</p>
      <p>チーム1: プレイヤー1-2、チーム2: プレイヤー3-4</p>
      <p>勝敗1が「1」の場合、チーム1の勝利</p>
    </div>
  <% end %>

  <%= form_with url: admin_imports_path, multipart: true, class: "space-y-4" do |form| %>
    <%= render Ui::CardComponent.new(title: "アップロード", subtitle: "CSVの日付列からイベントを自動作成します。既存イベントがある日付は、そのイベントに試合を追加します。") do %>
      <div>
        <label class="ui-label">CSVファイル</label>
        <%= file_field_tag :file, accept: ".csv", class: "ui-form-control" %>
      </div>
    <% end %>

    <div class="flex justify-end gap-2">
      <%= link_to "キャンセル", events_path, class: "ui-btn ui-btn-muted" %>
      <%= submit_tag "インポート", class: "ui-btn ui-btn-primary", data: { turbo_confirm: "CSVファイルをインポートしますか？" } %>
    </div>
  <% end %>
</div>
