<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="ui-eyebrow">Readers</p>
      <h1 class="ui-title"><%= @announcement.title %></h1>
      <p class="ui-subtitle">閲覧ユーザー一覧</p>
    </div>
    <%= link_to "一覧に戻る", admin_announcements_path, class: "ui-btn ui-btn-secondary" %>
  </div>

  <div class="ui-card p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <p class="text-sm font-bold text-muted">既読</p>
      <span class="ui-chip ui-chip-active tabular-nums"><%= @readers.count %>人</span>
    </div>

    <% if @readers.any? %>
      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        <% @readers.each do |user| %>
          <div class="rounded-lg bg-bg px-4 py-3 text-sm font-black text-ink shadow-inner-soft"><%= user.nickname %></div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center text-sm font-bold text-muted">まだ誰も閲覧していません</p>
    <% end %>
  </div>
</div>
