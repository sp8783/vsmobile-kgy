<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="ui-eyebrow">Announcements</p>
      <h1 class="ui-title">お知らせ管理</h1>
      <p class="ui-subtitle">アプリ起動時に表示されるお知らせを管理できます。</p>
    </div>
    <%= link_to "新規作成", new_admin_announcement_path, class: "ui-btn ui-btn-primary" %>
  </div>

  <% if @announcements.any? %>
    <div class="ui-card p-3">
      <div class="overflow-x-auto">
        <table class="ui-data-table">
          <thead>
            <tr>
              <th>タイトル</th>
              <th>状態</th>
              <th>公開期間</th>
              <th>既読数</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @announcements.each do |announcement| %>
              <tr>
                <td class="font-black"><%= announcement.title %></td>
                <td>
                  <% if announcement.is_active %>
                    <span class="ui-chip ui-chip-active">有効</span>
                  <% else %>
                    <span class="ui-chip">無効</span>
                  <% end %>
                </td>
                <td class="text-sm font-bold text-muted">
                  <%= announcement.published_at.strftime("%Y/%m/%d %H:%M") %> 〜
                  <%= announcement.expires_at ? announcement.expires_at.strftime("%Y/%m/%d %H:%M") : "期限なし" %>
                </td>
                <td>
                  <%= link_to "#{announcement.user_announcement_reads.count}人", admin_announcement_path(announcement), class: "font-black text-accent hover:text-accent-2" %>
                </td>
                <td>
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "編集", edit_admin_announcement_path(announcement), class: "ui-btn ui-btn-small ui-btn-secondary" %>
                    <%= button_to "削除", admin_announcement_path(announcement),
                        method: :delete,
                        data: { turbo_confirm: "お知らせ「#{announcement.title}」を削除しますか？" },
                        class: "ui-btn ui-btn-small ui-btn-danger" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="ui-card p-8 text-center">
      <p class="text-sm font-bold text-muted">お知らせがまだありません</p>
      <%= link_to "最初のお知らせを作成する", new_admin_announcement_path, class: "ui-btn ui-btn-primary mt-4" %>
    </div>
  <% end %>
</div>
