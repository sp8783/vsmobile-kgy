<%= form_with(model: [:admin, user], class: "space-y-5") do |form| %>
  <% if user.errors.any? %>
    <div class="ui-alert ui-alert-danger">
      <p class="font-black"><%= pluralize(user.errors.count, "個のエラー") %>があります</p>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :username, "ユーザー名", class: "ui-label" %>
    <%= form.text_field :username, class: "ui-form-control" %>
    <p class="mt-2 text-sm font-bold text-subtle">半角英数字と記号（_ -）が使用できます。</p>
  </div>

  <div>
    <%= form.label :nickname, "ニックネーム", class: "ui-label" %>
    <%= form.text_field :nickname, class: "ui-form-control" %>
  </div>

  <div>
    <%= form.label :password, user.persisted? ? "パスワード（変更する場合のみ）" : "パスワード", class: "ui-label" %>
    <%= form.password_field :password, autocomplete: "new-password", class: "ui-form-control" %>
    <% if user.persisted? %>
      <p class="mt-2 text-sm font-bold text-subtle">変更しない場合は空欄のままにしてください。</p>
    <% end %>
  </div>

  <div>
    <%= form.label :password_confirmation, "パスワード（確認）", class: "ui-label" %>
    <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "ui-form-control" %>
  </div>

  <label class="flex cursor-pointer items-center gap-3 rounded-lg bg-bg p-3 shadow-inner-soft">
    <%= form.check_box :is_admin, class: "h-4 w-4 rounded text-accent focus:ring-accent" %>
    <span class="text-sm font-bold text-ink">管理者権限を付与</span>
  </label>

  <div class="flex flex-wrap justify-end gap-3 pt-2">
    <%= link_to "キャンセル", admin_users_path, class: "ui-btn ui-btn-secondary" %>
    <%= form.submit user.new_record? ? "作成" : "更新", class: "ui-btn ui-btn-primary cursor-pointer" %>
  </div>
<% end %>
