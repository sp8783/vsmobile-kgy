<div class="ui-page">
  <div class="ui-page-header">
    <div>
      <p class="ui-eyebrow">Users</p>
      <h1 class="ui-title">ユーザー管理</h1>
      <p class="ui-subtitle">ユーザーの作成・編集・削除ができます。</p>
    </div>
    <%= link_to "新規作成", new_admin_user_path, class: "ui-btn ui-btn-primary" %>
  </div>

  <div class="ui-card p-3">
    <div class="overflow-x-auto">
      <table class="ui-data-table">
        <thead>
          <tr>
            <th>ユーザー名</th>
            <th>ニックネーム</th>
            <th>種別</th>
            <th>通知</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="font-black"><%= user.username %></td>
              <td class="font-bold text-muted"><%= user.nickname %></td>
              <td>
                <% if user.is_admin? %>
                  <span class="ui-chip ui-chip-active">管理者</span>
                <% elsif user.is_guest? %>
                  <span class="ui-chip">ゲスト</span>
                <% else %>
                  <span class="ui-chip">一般</span>
                <% end %>
              </td>
              <td>
                <% if user.push_notifications_enabled? %>
                  <span class="font-black text-accent">ON</span>
                <% else %>
                  <span class="font-black text-subtle">OFF</span>
                <% end %>
              </td>
              <td>
                <div class="flex flex-wrap gap-2">
                  <%= link_to "編集", edit_admin_user_path(user), class: "ui-btn ui-btn-small ui-btn-secondary" %>
                  <% unless user.id == current_user.id %>
                    <%= button_to "削除", admin_user_path(user), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "ui-btn ui-btn-small ui-btn-danger" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-4 text-sm font-bold text-muted">全 <%= @users.count %> ユーザー</p>
</div>
