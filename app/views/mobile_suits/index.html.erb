<div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-4 flex items-baseline gap-3">
    <h1 class="text-xl font-bold text-gray-900">機体一覧</h1>
    <span class="text-sm text-gray-500">全 <%= @total_count %> 機体</span>
  </div>

  <div class="overflow-x-auto">
    <table class="border-collapse text-xs">
      <thead>
        <tr class="border-b-2 border-gray-300">
          <th class="text-left py-1.5 px-2 text-gray-500 font-semibold w-16">カテゴリ</th>
          <th class="text-left py-1.5 px-2 text-gray-500 font-semibold w-36">シリーズ</th>
          <% @costs.each do |cost| %>
            <th class="text-center py-1.5 px-3 w-48">
              <span class="inline-block text-xs font-bold px-2 py-0.5 rounded
                <%= cost == 3000 ? 'bg-red-100 text-red-700' :
                    cost == 2500 ? 'bg-orange-100 text-orange-700' :
                    cost == 2000 ? 'bg-yellow-100 text-yellow-700' :
                                   'bg-green-100 text-green-700' %>">
                <%= cost %>
              </span>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @series_by_category.each do |category, suits_by_series| %>
          <% series_list = suits_by_series.to_a %>
          <% series_list.each_with_index do |(series, suits_by_cost), i| %>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <%# カテゴリセル: 最初の行のみ、rowspanで縦結合 %>
              <% if i == 0 %>
                <td rowspan="<%= series_list.size %>"
                    class="py-2 px-2 align-top text-xs font-semibold text-gray-500 border-r border-gray-200 leading-snug w-16 whitespace-normal">
                  <%= category %>
                </td>
              <% end %>

              <td class="py-2 px-2 align-top text-xs text-gray-700 leading-snug w-36 border-r border-gray-100">
                <%= series %>
              </td>

              <% @costs.each do |cost| %>
                <td class="py-2 px-2 align-top">
                  <div class="flex flex-wrap gap-1 items-start content-start">
                    <% (suits_by_cost[cost] || []).each do |suit| %>
                      <div class="flex flex-col items-center w-16">
                        <% if suit.wiki_url.present? %>
                          <%= link_to suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
                              title: suit.name, class: "block hover:opacity-75 transition-opacity" do %>
                            <% if suit.image_filename.present? %>
                              <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                                  class: "w-16 h-16 object-contain", loading: "lazy" %>
                            <% else %>
                              <div class="w-16 h-16 flex items-center justify-center bg-gray-100 rounded">
                                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                              </div>
                            <% end %>
                          <% end %>
                        <% elsif suit.image_filename.present? %>
                          <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                              class: "w-16 h-16 object-contain", loading: "lazy" %>
                        <% else %>
                          <div class="w-16 h-16 flex items-center justify-center bg-gray-100 rounded">
                            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                          </div>
                        <% end %>
                        <p class="text-xs text-gray-700 leading-tight mt-0.5 line-clamp-2 w-full text-center">
                          <%= suit.name %>
                        </p>
                      </div>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
