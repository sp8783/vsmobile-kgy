<div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <%# ページヘッダー %>
  <div class="mb-5 flex items-baseline gap-3">
    <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">機体一覧</h1>
    <span class="text-sm text-gray-400 font-medium"><%= @total_count %> 機体</span>
  </div>

  <div class="overflow-x-auto rounded-xl shadow-sm border border-gray-200">
    <table class="border-collapse text-xs w-full">
      <%# ヘッダー行 %>
      <thead>
        <tr class="bg-gray-900 text-white">
          <th class="py-2.5 px-3 text-left font-semibold text-gray-300 text-[11px] uppercase tracking-widest w-16 border-r border-gray-700">区分</th>
          <th class="py-2.5 px-3 text-left font-semibold text-gray-300 text-[11px] uppercase tracking-widest w-40 border-r border-gray-700">シリーズ</th>
          <% [
            [3000, "from-red-500 to-rose-600"],
            [2500, "from-orange-400 to-amber-500"],
            [2000, "from-yellow-400 to-yellow-500"],
            [1500, "from-emerald-400 to-green-500"],
          ].each do |cost, gradient| %>
            <th class="py-2.5 px-3 text-center w-1/4">
              <span class="inline-block bg-gradient-to-r <%= gradient %> text-white text-xs font-bold px-3 py-0.5 rounded-full shadow-sm">
                <%= cost %>
              </span>
            </th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% @series_by_category.each_with_index do |(category, suits_by_series), cat_idx| %>
          <% series_list = suits_by_series.to_a %>
          <% series_list.each_with_index do |(series, suits_by_cost), ser_idx| %>
            <% row_bg = cat_idx.even? ? "bg-white" : "bg-slate-50/60" %>
            <tr class="<%= row_bg %> border-b border-gray-100 hover:bg-indigo-50/40 transition-colors duration-100">

              <%# カテゴリ列（先頭行のみ rowspan） %>
              <% if ser_idx == 0 %>
                <td rowspan="<%= series_list.size %>"
                    class="py-2 px-2 align-middle text-center border-r border-gray-200 w-16">
                  <div class="inline-flex items-center justify-center">
                    <span class="text-[10px] font-bold text-indigo-600 leading-snug whitespace-normal text-center">
                      <%= category.gsub("シリーズ ", "シリーズ\n").gsub(" OVA", "\nOVA").gsub(" ゲーム", "・ゲーム") %>
                    </span>
                  </div>
                </td>
              <% end %>

              <%# シリーズ列 %>
              <td class="py-2 px-3 align-top text-[11px] font-medium text-gray-600 leading-snug w-40 border-r border-gray-100">
                <%= series %>
              </td>

              <%# コスト別機体セル %>
              <% @costs.each do |cost| %>
                <td class="py-2 px-2 align-top">
                  <div class="flex flex-wrap gap-2 items-start content-start">
                    <% (suits_by_cost[cost] || []).each do |suit| %>
                      <div class="group flex flex-col items-center w-24 gap-0.5">
                        <%# 画像（Wikiリンク） %>
                        <% if suit.wiki_url.present? %>
                          <%= link_to suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
                              title: suit.name,
                              class: "block rounded-lg overflow-hidden ring-1 ring-transparent group-hover:ring-indigo-400 group-hover:shadow-md transition-all duration-150" do %>
                            <% if suit.image_filename.present? %>
                              <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                                  class: "w-24 h-24 object-contain bg-gray-900/5 group-hover:scale-105 transition-transform duration-150",
                                  loading: "lazy" %>
                            <% else %>
                              <div class="w-24 h-24 flex items-center justify-center bg-gray-100">
                                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                              </div>
                            <% end %>
                          <% end %>
                        <% elsif suit.image_filename.present? %>
                          <div class="rounded-lg overflow-hidden ring-1 ring-gray-200">
                            <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                                class: "w-24 h-24 object-contain bg-gray-900/5",
                                loading: "lazy" %>
                          </div>
                        <% else %>
                          <div class="w-24 h-24 flex items-center justify-center bg-gray-100 rounded-lg ring-1 ring-gray-200">
                            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                          </div>
                        <% end %>

                        <%# 機体名 %>
                        <p class="text-[10px] font-medium text-gray-700 leading-tight line-clamp-2 w-full text-center group-hover:text-indigo-700 transition-colors duration-100">
                          <%= suit.name %>
                        </p>
                      </div>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
