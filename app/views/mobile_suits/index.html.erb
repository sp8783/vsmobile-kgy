<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ページヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">機体一覧</h1>
    <p class="mt-1 text-sm text-gray-400">全 <%= @counts_by_cost.values.sum %> 機体 — コストを選んで絞り込み</p>
  </div>

  <%# コストタブ + 検索ボックス %>
  <%
    tab_styles = {
      3000 => { active: "bg-rose-600 text-white shadow-rose-200",    inactive: "text-rose-600 border border-rose-200 hover:bg-rose-50",    count_cls: "bg-rose-500/20 text-rose-100",    count_inactive: "bg-rose-100 text-rose-500" },
      2500 => { active: "bg-orange-500 text-white shadow-orange-200", inactive: "text-orange-600 border border-orange-200 hover:bg-orange-50", count_cls: "bg-orange-400/20 text-orange-100", count_inactive: "bg-orange-100 text-orange-600" },
      2000 => { active: "bg-amber-400 text-gray-900 shadow-amber-200", inactive: "text-amber-600 border border-amber-200 hover:bg-amber-50",  count_cls: "bg-amber-300/30 text-amber-900",  count_inactive: "bg-amber-100 text-amber-700" },
      1500 => { active: "bg-emerald-500 text-white shadow-emerald-200", inactive: "text-emerald-700 border border-emerald-200 hover:bg-emerald-50", count_cls: "bg-emerald-400/20 text-emerald-100", count_inactive: "bg-emerald-100 text-emerald-700" },
    }
  %>
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <%# コストタブ %>
    <div class="flex gap-2">
      <% MobileSuitsController::COSTS.each do |cost| %>
        <% active = @selected_cost == cost %>
        <% s = tab_styles[cost] %>
        <%= link_to mobile_suits_path(cost: cost),
            class: "flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm transition-all duration-150 shadow-sm #{active ? s[:active] + ' shadow-md' : s[:inactive]}" do %>
          <span><%= cost %></span>
          <span class="text-xs font-semibold px-1.5 py-0.5 rounded-full <%= active ? s[:count_cls] : s[:count_inactive] %>">
            <%= @counts_by_cost[cost] || 0 %>
          </span>
        <% end %>
      <% end %>
    </div>

    <%# 検索ボックス %>
    <div class="relative flex-1 min-w-48 max-w-xs">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
        <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
      </div>
      <input type="text" id="suit-search" placeholder="機体名で検索…"
             class="w-full rounded-xl border border-gray-200 bg-white py-2.5 pl-9 pr-4 text-sm text-gray-800 placeholder-gray-400 shadow-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-200 transition">
    </div>

    <%# 検索結果カウント %>
    <span id="suit-search-count" class="text-sm text-gray-400 hidden">
      <span id="suit-search-num"></span> 件
    </span>
  </div>

  <%# 機体グリッド %>
  <div id="suit-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3">
    <% @suits.each do |suit| %>
      <div class="suit-card group relative flex flex-col rounded-xl overflow-hidden bg-white border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:border-indigo-300 transition-all duration-150"
           data-name="<%= suit.name %>">

        <%# 画像エリア %>
        <div class="bg-gradient-to-b from-gray-50 to-gray-100 flex items-center justify-center p-1">
          <% if suit.wiki_url.present? %>
            <%= link_to suit.wiki_url, target: "_blank", rel: "noopener noreferrer", title: "#{suit.name} — Wiki", class: "block" do %>
              <% if suit.image_filename.present? %>
                <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                    class: "w-[120px] h-[120px] object-contain group-hover:scale-105 transition-transform duration-150",
                    loading: "lazy" %>
              <% else %>
                <div class="w-[120px] h-[120px] flex items-center justify-center text-gray-300">
                  <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </div>
              <% end %>
            <% end %>
          <% elsif suit.image_filename.present? %>
            <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                class: "w-[120px] h-[120px] object-contain",
                loading: "lazy" %>
          <% end %>
        </div>

        <%# テキストエリア %>
        <div class="px-2 py-2 flex-1 flex flex-col gap-0.5">
          <p class="text-xs font-semibold text-gray-800 leading-tight line-clamp-2 group-hover:text-indigo-700 transition-colors">
            <%= suit.name %>
          </p>
          <p class="text-[10px] text-gray-400 leading-tight line-clamp-1">
            <%= suit.series %>
          </p>
        </div>

        <%# Wikiリンクアイコン（右上オーバーレイ） %>
        <% if suit.wiki_url.present? %>
          <%= link_to suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
              class: "absolute top-1.5 right-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-150 bg-white/90 rounded-md p-0.5 shadow-sm" do %>
            <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# 検索結果なし %>
  <div id="suit-no-results" class="hidden py-16 text-center text-gray-400">
    <svg class="mx-auto w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
    </svg>
    <p class="text-sm font-medium">該当する機体が見つかりません</p>
  </div>

</div>

<script>
  (function () {
    const input = document.getElementById('suit-search');
    const cards = document.querySelectorAll('.suit-card');
    const countWrap = document.getElementById('suit-search-count');
    const countNum = document.getElementById('suit-search-num');
    const noResults = document.getElementById('suit-no-results');

    input.addEventListener('input', function () {
      const q = this.value.trim().toLowerCase();
      let visible = 0;

      cards.forEach(function (card) {
        const name = card.dataset.name.toLowerCase();
        const show = !q || name.includes(q);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (q) {
        countNum.textContent = visible;
        countWrap.classList.remove('hidden');
      } else {
        countWrap.classList.add('hidden');
      }
      noResults.classList.toggle('hidden', visible > 0 || !q);
    });
  })();
</script>
