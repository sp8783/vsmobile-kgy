<div class="py-8">

  <%# ページヘッダー %>
  <div class="mb-6">
    <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">機体一覧</h1>
    <p class="mt-1 text-sm text-gray-400">全 <%= @counts_by_cost.values.sum %> 機体</p>
  </div>

  <%# コストタブ + 検索ボックス %>
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <%# コストタブ（統計ページと同じカラー設計） %>
    <%
      cost_styles = {
        3000 => { active: "bg-red-500 text-white shadow-sm",      inactive: "text-red-500 hover:bg-red-100/80" },
        2500 => { active: "bg-orange-500 text-white shadow-sm",   inactive: "text-orange-500 hover:bg-orange-100/80" },
        2000 => { active: "bg-yellow-400 text-gray-900 shadow-sm", inactive: "text-yellow-600 hover:bg-yellow-100/80" },
        1500 => { active: "bg-green-500 text-white shadow-sm",    inactive: "text-green-600 hover:bg-green-100/80" },
      }
    %>
    <div class="flex gap-0.5 flex-wrap p-1 bg-gray-100 rounded-xl">
      <%# 全機体タブ %>
      <% all_active = @selected_cost.nil? %>
      <%= link_to mobile_suits_path(q: @search_query.presence),
          class: "tab-link flex items-center gap-1.5 px-4 py-1.5 rounded-lg font-semibold text-sm transition-all whitespace-nowrap #{all_active ? 'bg-white shadow text-gray-900' : 'text-gray-500 hover:text-gray-700'}",
          data: { base_url: mobile_suits_path } do %>
        <span>すべて</span>
        <span class="text-xs font-medium"><%= @counts_by_cost.values.sum %></span>
      <% end %>

      <% MobileSuitsController::COSTS.each do |cost| %>
        <% active = @selected_cost == cost %>
        <% s = cost_styles[cost] %>
        <%= link_to mobile_suits_path(cost: cost, q: @search_query.presence),
            class: "tab-link flex items-center gap-1.5 px-4 py-1.5 rounded-lg font-semibold text-sm transition-all whitespace-nowrap #{active ? s[:active] : s[:inactive]}",
            data: { base_url: mobile_suits_path(cost: cost) } do %>
          <span><%= cost %></span>
          <span class="text-xs font-medium"><%= @counts_by_cost[cost] || 0 %></span>
        <% end %>
      <% end %>
    </div>

    <%# 検索ボックス %>
    <div class="relative flex-1 min-w-48 max-w-xs">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
        <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
      </div>
      <input type="text" id="suit-search" placeholder="機体名で検索…" value="<%= @search_query %>"
             class="w-full rounded-xl border border-gray-200 bg-white py-2.5 pl-9 pr-4 text-sm text-gray-800 placeholder-gray-400 shadow-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-200 transition">
    </div>

    <%# 検索結果カウント %>
    <span id="suit-search-count" class="text-sm text-gray-400 hidden">
      <span id="suit-search-num"></span> 件
    </span>
  </div>

  <%# 機体グリッド %>
  <div id="suit-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3">
    <% @suits.each do |suit| %>
      <div class="suit-card group flex flex-col rounded-xl overflow-hidden bg-white border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:border-indigo-300 transition-all duration-150"
           data-name="<%= suit.name %>">

        <%# 画像エリア → 機体詳細へ %>
        <%= link_to mobile_suit_path(suit), class: "relative block bg-gradient-to-b from-gray-50 to-gray-100" do %>
          <% if suit.image_filename.present? %>
            <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                class: "w-full h-[100px] object-contain px-2 pt-2 group-hover:scale-105 transition-transform duration-150",
                loading: "lazy" %>
          <% else %>
            <div class="w-full h-[100px] flex items-center justify-center text-gray-300">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
          <% end %>
          <%# ホバーで「詳細を見る」 %>
          <div class="absolute bottom-1.5 inset-x-0 flex justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-150">
            <span class="text-[10px] font-bold text-indigo-700 bg-white/95 rounded-full px-2 py-0.5 shadow-sm border border-indigo-100">詳細を見る</span>
          </div>
        <% end %>

        <%# テキストエリア %>
        <div class="px-2 pt-1.5 pb-1 flex-1 flex flex-col gap-0.5">
          <%= link_to mobile_suit_path(suit), class: "block" do %>
            <p class="text-xs font-semibold text-gray-800 leading-tight line-clamp-2 group-hover:text-indigo-700 transition-colors">
              <%= suit.name %>
            </p>
          <% end %>
          <p class="text-[10px] text-gray-400 leading-tight line-clamp-1">
            <%= suit.series %>
          </p>
        </div>

        <%# Wiki リンク（常時表示） %>
        <% if suit.wiki_url.present? %>
          <div class="border-t border-gray-100 px-2 py-1 flex justify-center">
            <%= link_to suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
                class: "inline-flex items-center gap-0.5 text-[10px] font-semibold text-indigo-500 hover:text-indigo-700 transition-colors" do %>
              <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              Wiki
              <svg class="w-2 h-2 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# 検索結果なし %>
  <div id="suit-no-results" class="hidden py-16 text-center text-gray-400">
    <svg class="mx-auto w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
    </svg>
    <p class="text-sm font-medium">該当する機体が見つかりません</p>
  </div>

</div>

<script>
  (function () {
    const input = document.getElementById('suit-search');
    const cards = document.querySelectorAll('.suit-card');
    const countWrap = document.getElementById('suit-search-count');
    const countNum = document.getElementById('suit-search-num');
    const noResults = document.getElementById('suit-no-results');

    const tabLinks = document.querySelectorAll('.tab-link');

    function updateTabLinks(q) {
      tabLinks.forEach(function (link) {
        const url = new URL(link.dataset.baseUrl, location.origin);
        if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
        link.href = url.pathname + (url.search || '');
      });
    }

    function applyFilter(q) {
      let visible = 0;
      cards.forEach(function (card) {
        const name = card.dataset.name.toLowerCase();
        const show = !q || name.includes(q);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (q) {
        countNum.textContent = visible;
        countWrap.classList.remove('hidden');
      } else {
        countWrap.classList.add('hidden');
      }
      noResults.classList.toggle('hidden', visible > 0 || !q);
    }

    // ページロード時に初期値でフィルタリング
    const initialQ = input.value.trim().toLowerCase();
    applyFilter(initialQ);
    updateTabLinks(input.value.trim());

    input.addEventListener('input', function () {
      const q = this.value.trim();
      applyFilter(q.toLowerCase());
      updateTabLinks(q);
    });
  })();
</script>
