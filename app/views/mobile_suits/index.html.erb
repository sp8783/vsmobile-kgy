<div data-controller="suit-search">
  <div class="m-pagehead">
    <div>
      <h1>機体一覧</h1>
      <div class="m-sub">全 <span class="m-num"><%= @counts_by_cost.values.sum %></span> 機体</div>
    </div>
  </div>

  <div class="s-filterbar">
    <div class="s-costtabs">
      <%= link_to mobile_suits_path(q: @search_query.presence),
          class: class_names("s-costtab", @selected_cost.nil? && "is-on"),
          data: { suit_search_target: "tab", base_url: mobile_suits_path } do %>
        すべて<span class="n"><%= @counts_by_cost.values.sum %></span>
      <% end %>

      <% MobileSuitsController::COSTS.each do |cost| %>
        <%= link_to mobile_suits_path(cost: cost, q: @search_query.presence),
            class: class_names("s-costtab", "c#{cost}", @selected_cost == cost && "is-on"),
            data: { suit_search_target: "tab", base_url: mobile_suits_path(cost: cost) } do %>
          <%= cost %><span class="n"><%= @counts_by_cost[cost] || 0 %></span>
        <% end %>
      <% end %>
    </div>

    <div class="s-search">
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
      <input type="search"
             placeholder="機体名で検索…"
             value="<%= @search_query %>"
             data-suit-search-target="input"
             data-action="input->suit-search#apply">
    </div>

    <span class="ui-chip hidden" data-suit-search-target="count">
      <span data-suit-search-target="countNumber"></span> 件
    </span>
  </div>

  <div class="s-grid">
    <% @suits.each do |suit| %>
      <article class="s-card" data-suit-search-target="card" data-name="<%= suit.name %>">
        <%= link_to "", mobile_suit_path(suit), class: "s-stretch", aria: { label: suit.name } %>
        <div class="s-img">
          <% if suit.image_filename.present? %>
            <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name, loading: "lazy" %>
          <% else %>
            <span class="s-noimg">NO IMAGE</span>
          <% end %>
          <span class="s-cbcorner"><%= cost_badge(suit.cost) %></span>
        </div>
        <div class="s-body">
          <div class="s-nm"><%= suit.name %></div>
          <div class="s-se"><%= suit.series %></div>
        </div>
        <% if suit.wiki_url.present? %>
          <%= link_to safe_external_url(suit.wiki_url), target: "_blank", rel: "noopener noreferrer", class: "s-wiki" do %>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6.3v13M12 6.3C10.8 5.5 9.2 5 7.5 5S4.2 5.5 3 6.3v13C4.2 18.5 5.8 18 7.5 18s3.3.5 4.5 1.3m0-13C13.2 5.5 14.8 5 16.5 5S19.8 5.5 21 6.3v13C19.8 18.5 18.2 18 16.5 18s-3.3.5-4.5 1.3"/></svg>
            Wiki
          <% end %>
        <% end %>
      </article>
    <% end %>
  </div>

  <div class="hidden py-16 text-center" data-suit-search-target="empty">
    <p class="text-sm font-bold text-muted">該当する機体が見つかりません</p>
  </div>
</div>
