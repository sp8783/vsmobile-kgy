<%#
  共有パーシャル: 機体グリッド（縦=シリーズ、横=コスト）
  ローカル変数:
    suits_by_series: { series_name => { cost => [MobileSuit] } }
    costs:           表示するコストの配列（例: [3000, 2500, 2000, 1500]）
    selectable:      true のとき各機体カードをクリック可能にする（お気に入りピッカー用）
    selected_ids:    選択済み機体IDの配列（selectable時にハイライト表示）
%>
<% selectable ||= false %>
<% selected_ids ||= [] %>

<div class="overflow-x-auto">
  <table class="w-full border-collapse">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="text-left text-xs font-semibold text-gray-500 py-2 pr-4 whitespace-nowrap w-44">シリーズ</th>
        <% costs.each do |cost| %>
          <th class="text-center py-2 px-3 w-1/4">
            <span class="inline-block text-xs font-bold px-2 py-1 rounded
              <%= cost == 3000 ? 'bg-red-100 text-red-700' :
                  cost == 2500 ? 'bg-orange-100 text-orange-700' :
                  cost == 2000 ? 'bg-yellow-100 text-yellow-700' :
                                 'bg-green-100 text-green-700' %>">
              <%= cost %>
            </span>
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% suits_by_series.each do |series, suits_by_cost| %>
        <tr class="hover:bg-gray-50">
          <td class="py-3 pr-4 text-xs font-medium text-gray-600 align-top leading-snug w-44">
            <%= series %>
          </td>
          <% costs.each do |cost| %>
            <td class="py-3 px-3 align-top">
              <div class="flex flex-wrap gap-2 items-start content-start">
                <% (suits_by_cost[cost] || []).each do |suit| %>
                  <% is_selected = selected_ids.include?(suit.id) %>
                  <% if selectable %>
                    <% card_cls = "relative flex flex-col items-center rounded-lg border p-2 text-center transition-colors w-32 cursor-pointer " + (is_selected ? "border-indigo-500 bg-indigo-50 ring-2 ring-indigo-400" : "border-gray-200 bg-white hover:border-indigo-300 hover:bg-indigo-50") %>
                    <div class="<%= card_cls %>" data-suit-id="<%= suit.id %>" data-suit-name="<%= suit.name %>">
                  <% else %>
                    <div class="relative flex flex-col items-center rounded-lg border border-gray-200 bg-white p-2 text-center w-32">
                  <% end %>
                    <%# 機体画像 %>
                    <% if suit.image_filename.present? %>
                      <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                          class: "w-28 h-28 object-contain mb-1",
                          loading: "lazy" %>
                    <% else %>
                      <div class="w-28 h-28 flex items-center justify-center bg-gray-100 rounded mb-1">
                        <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                      </div>
                    <% end %>

                    <%# 機体名 %>
                    <p class="text-xs font-medium text-gray-800 leading-tight line-clamp-2 w-full">
                      <%= suit.name %>
                    </p>

                    <%# Wikiリンク（一覧表示時のみ） %>
                    <% unless selectable %>
                      <% if suit.wiki_url.present? %>
                        <%= link_to "Wiki", suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
                            class: "mt-1.5 text-xs text-indigo-600 hover:text-indigo-800 hover:underline" %>
                      <% end %>
                    <% end %>

                    <%# 選択チェックマーク（ピッカー用） %>
                    <% if selectable && is_selected %>
                      <div class="absolute top-1 right-1 w-4 h-4 bg-indigo-500 rounded-full flex items-center justify-center">
                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
