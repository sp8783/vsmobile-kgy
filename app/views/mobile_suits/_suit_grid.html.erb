<%#
  共有パーシャル: 機体グリッド
  ローカル変数:
    suits_by_series: { series_name => { cost => [MobileSuit] } }
    costs:           表示するコストの配列（例: [3000, 2500, 2000, 1500]）
    selectable:      true のとき各機体カードをクリック可能にする（お気に入りピッカー用）
    selected_ids:    選択済み機体IDの配列（selectable時にハイライト表示）
%>
<% selectable ||= false %>
<% selected_ids ||= [] %>

<div class="space-y-8">
  <% suits_by_series.each do |series, suits_by_cost| %>
    <section>
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 px-1 border-b border-gray-200 pb-2">
        <%= series %>
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
        <% costs.each do |cost| %>
          <% (suits_by_cost[cost] || []).each do |suit| %>
            <% is_selected = selected_ids.include?(suit.id) %>
            <% card_classes = "relative flex flex-col items-center rounded-lg border p-2 text-center transition-colors" %>
            <% if selectable %>
              <% card_classes += is_selected ? " border-indigo-500 bg-indigo-50 ring-2 ring-indigo-400 cursor-pointer" : " border-gray-200 bg-white hover:border-indigo-300 hover:bg-indigo-50 cursor-pointer" %>
              <div class="<%= card_classes %>" data-suit-id="<%= suit.id %>" data-suit-name="<%= suit.name %>">
            <% else %>
              <% card_classes += " border-gray-200 bg-white" %>
              <div class="<%= card_classes %>">
            <% end %>
              <%# 機体画像 %>
              <% if suit.image_filename.present? %>
                <%= image_tag "/mobile_suits/#{suit.image_filename}", alt: suit.name,
                    class: "w-16 h-16 object-contain mb-1",
                    loading: "lazy" %>
              <% else %>
                <div class="w-16 h-16 flex items-center justify-center bg-gray-100 rounded mb-1">
                  <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </div>
              <% end %>

              <%# コストバッジ %>
              <span class="inline-block text-xs font-bold px-1.5 py-0.5 rounded mb-1
                <%= cost == 3000 ? 'bg-red-100 text-red-700' :
                    cost == 2500 ? 'bg-orange-100 text-orange-700' :
                    cost == 2000 ? 'bg-yellow-100 text-yellow-700' :
                                  'bg-green-100 text-green-700' %>">
                <%= cost %>
              </span>

              <%# 機体名 %>
              <p class="text-xs font-medium text-gray-800 leading-tight line-clamp-2">
                <%= suit.name %>
              </p>

              <%# Wikiリンク（一覧表示時のみ） %>
              <% unless selectable %>
                <% if suit.wiki_url.present? %>
                  <%= link_to "Wiki", suit.wiki_url, target: "_blank", rel: "noopener noreferrer",
                      class: "mt-1.5 text-xs text-indigo-600 hover:text-indigo-800 hover:underline" %>
                <% end %>
              <% end %>

              <%# 選択チェックマーク（ピッカー用） %>
              <% if selectable && is_selected %>
                <div class="absolute top-1 right-1 w-4 h-4 bg-indigo-500 rounded-full flex items-center justify-center">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
