<div>
  <%= link_to mobile_suits_path, class: "s-back" do %>
    <svg viewBox="0 0 24 24" aria-hidden="true" style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2"><path d="M15 18l-6-6 6-6"/></svg>
    機体一覧に戻る
  <% end %>

  <div class="s-panel s-hero">
    <div class="s-himg">
      <% if @suit.image_filename.present? %>
        <%= image_tag "/mobile_suits/#{@suit.image_filename}", alt: @suit.name %>
      <% else %>
        <span class="s-noimg">No Image</span>
      <% end %>
    </div>

    <div class="s-hmeta">
      <div class="s-badges">
        <%= cost_badge(@suit.cost) %>
        <% if @suit.series.present? %><span class="s-series"><%= @suit.series %></span><% end %>
      </div>
      <h1><%= @suit.name %></h1>

      <% if @suit.wiki_url.present? %>
        <%= link_to safe_external_url(@suit.wiki_url), target: "_blank", rel: "noopener noreferrer", class: "s-wikilink" do %>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6.3v13M12 6.3C10.8 5.5 9.2 5 7.5 5S4.2 5.5 3 6.3v13C4.2 18.5 5.8 18 7.5 18s3.3.5 4.5 1.3m0-13C13.2 5.5 14.8 5 16.5 5S19.8 5.5 21 6.3v13C19.8 18.5 18.2 18 16.5 18s-3.3.5-4.5 1.3"/></svg>
          Wiki を見る
        <% end %>
      <% end %>

      <% if @suit.durability.present? || @suit.bd_count.present? || @suit.red_lock_range.present? %>
        <%
          specs = [
            { label: "耐久値", value: @suit.durability },
            { label: "BD回数", value: @suit.bd_count },
            { label: "赤ロック", value: @suit.red_lock_range }
          ]
        %>
        <div class="s-specpanel">
          <% specs.each do |spec| %>
            <div class="s-spec">
              <div class="l"><%= spec[:label] %></div>
              <% if spec[:value].blank? %>
                <div class="v">—</div>
              <% else %>
                <% parsed = parse_spec_field(spec[:value].to_s) %>
                <% if parsed.size == 1 && parsed[0][:label].nil? %>
                  <div class="v"><%= parsed[0][:value] %></div>
                <% else %>
                  <div class="vrow">
                    <% parsed.each do |item| %>
                      <span class="vi"><span><%= item[:label] %></span> <b><%= item[:value] %></b></span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="s-kpis">
    <div class="s-kpi">
      <div class="l">使用回数</div>
      <div class="v"><%= @total_uses %></div>
      <div class="s"><%= @rank_uses ? "使用回数 ##{@rank_uses} / #{@total_suits}" : "全イベント通算" %></div>
    </div>
    <div class="s-kpi">
      <div class="l">勝率</div>
      <div class="v"><%= @win_rate %>%</div>
      <div class="s"><%= @rank_win_rate ? "勝率 ##{@rank_win_rate} / #{@total_suits_with_uses}" : "使用実績あり機体内" %></div>
    </div>
    <div class="s-kpi">
      <div class="l">環境支配度</div>
      <div class="v"><%= @dominance %></div>
      <div class="s"><%= @rank_dominance ? "支配度 ##{@rank_dominance} / #{@total_suits}" : "勝率 × 使用回数" %></div>
    </div>
  </div>

  <% if @total_uses > 0 %>
    <section class="s-panel">
      <div class="s-phead"><h2>使用プレイヤー TOP5</h2></div>
      <% if @player_ranking.any? %>
        <div class="s-pbody">
          <% @player_ranking.each_with_index do |d, i| %>
            <div class="s-rankrow">
              <span class="s-rk-no <%= "top" if i < 3 %>"><%= i + 1 %></span>
              <div class="s-rk-nm">
                <%= d[:user].nickname %>
                <div class="s-rk-sub"><span class="m-num"><%= d[:uses] %></span>回使用</div>
              </div>
              <span class="s-rk-wr"><%= d[:win_rate] %>%</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="s-empty">データがありません</div>
      <% end %>
    </section>

    <div class="s-grid2">
      <section class="s-panel">
        <div class="s-phead"><h2>相方コスト構成</h2><span class="eyebrow">どのコスト帯と組んだか</span></div>
        <% if @partner_costs.any? %>
          <%
            cost_rows = @partner_costs.sort_by { |d| -d[:cost] }
            partner_total = @partner_costs.sum { |d| d[:total] }
            acc = 0.0
            donut_stops = cost_rows.map do |d|
              from = acc
              acc += (partner_total.positive? ? d[:total].to_f / partner_total * 100 : 0)
              "var(--color-cost-#{d[:cost]}-fill) #{from.round(2)}% #{acc.round(2)}%"
            end
          %>
          <div class="s-cdonut">
            <div class="s-donut" style="background:conic-gradient(<%= donut_stops.join(', ') %>)">
              <span class="s-donut-mid"><b class="m-num"><%= partner_total %></b>戦</span>
            </div>
            <div class="s-dleg">
              <% cost_rows.each do |d| %>
                <div class="s-dleg-row">
                  <span class="dot" style="background:var(--color-cost-<%= d[:cost] %>-fill)"></span>
                  <span class="nm"><%= d[:cost] %></span>
                  <span class="cnt"><span class="m-num"><%= d[:total] %></span>戦</span>
                  <span class="val"><%= d[:ratio] %>%</span>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="s-empty">データがありません</div>
        <% end %>
      </section>

      <section class="s-panel">
        <div class="s-phead"><h2>相方コスト別 勝率</h2><span class="eyebrow">どのコスト帯と組むと勝てるか</span></div>
        <% if @partner_costs.any? %>
          <div class="s-wlist">
            <% @partner_costs.sort_by { |d| -d[:cost] }.each do |d| %>
              <div class="s-wrow">
                <span><%= cost_badge(d[:cost]) %></span>
                <div class="s-wbar">
                  <div class="s-wtrack"></div>
                  <div class="s-wfill <%= "lo" if d[:win_rate] < 50 %>" style="width:<%= d[:win_rate] %>%"></div>
                  <div class="s-wref"></div>
                </div>
                <span class="s-wval <%= d[:win_rate] >= 50 ? "good" : "bad" %>"><%= d[:win_rate] %>%</span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="s-empty">データがありません</div>
        <% end %>
      </section>
    </div>

    <% if @partner_suits.any? %>
      <section class="s-panel">
        <div class="s-phead">
          <h2>相方機体ランキング</h2>
          <span class="eyebrow">使用回数順・上位10件</span>
        </div>
        <div class="s-rlist">
          <% @partner_suits.first(10).each_with_index do |d, i| %>
            <% ms = d[:mobile_suit] %>
            <div class="s-srow">
              <span class="s-rk-no <%= "top" if i < 3 %>"><%= i + 1 %></span>
              <span class="suit-thumb suit-thumb-md">
                <% if ms.image_filename.present? %>
                  <%= image_tag "/mobile_suits/#{ms.image_filename}", alt: ms.name, loading: "lazy" %>
                <% else %>
                  <svg viewBox="0 0 24 24" aria-hidden="true" style="width:20px;height:20px;stroke:var(--color-subtle);fill:none;stroke-width:1.4"><path d="M4 16l4.6-4.6a2 2 0 0 1 2.8 0L16 16M14 8h.01M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z"/></svg>
                <% end %>
              </span>
              <div class="s-srow-nm">
                <%= mobile_suit_link(ms) %>
                <div class="s-srow-sub"><%= ms.cost %> ・ 勝率 <%= d[:win_rate] %>%</div>
              </div>
              <span class="s-srow-val"><span class="m-num"><%= d[:total] %></span><span class="u">戦</span></span>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @matchup_strong.any? || @matchup_weak.any? %>
      <section class="s-panel">
        <div class="s-phead"><h2>得意・不得意な相手機体</h2><span class="eyebrow"><%= MobileSuitStatisticsSnapshot::MIN_MATCHUP_GAMES %>戦以上の対面のみ</span></div>
        <div class="s-mu">
          <div class="s-mu-col">
            <div class="s-mu-h good">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 14l5-5 5 5"/></svg>
              得意（勝率が高い）
            </div>
            <% if @matchup_strong.any? %>
              <% @matchup_strong.each do |d| %>
                <%= render "mobile_suits/matchup_row", data: d, tone: "good" %>
              <% end %>
            <% else %>
              <div class="s-empty">該当なし</div>
            <% end %>
          </div>
          <div class="s-mu-col">
            <div class="s-mu-h bad">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10l5 5 5-5"/></svg>
              苦手（勝率が低い）
            </div>
            <% if @matchup_weak.any? %>
              <% @matchup_weak.each do |d| %>
                <%= render "mobile_suits/matchup_row", data: d, tone: "bad" %>
              <% end %>
            <% else %>
              <div class="s-empty">該当なし</div>
            <% end %>
          </div>
        </div>
      </section>
    <% end %>
  <% else %>
    <div class="s-panel" style="padding:48px 18px;text-align:center">
      <p class="text-sm font-bold text-muted">まだ試合データがありません</p>
    </div>
  <% end %>

  <% if @global_perf %>
    <%
      perf_groups = [
        { label: "基本戦績", rows: [
          { key: :avg_score, label: "スコア" },
          { key: :avg_kills, label: "撃墜数" },
          { key: :avg_deaths, label: "被撃墜数" },
        ] },
        { label: "ダメージ", rows: [
          { key: :avg_damage_dealt, label: "与ダメージ" },
          { key: :avg_damage_recv, label: "被ダメージ" },
          { key: :avg_exburst_damage, label: "EXバーストダメージ" },
        ] },
        { label: "EXバースト", rows: [
          { key: :avg_exburst_count, label: "EXバースト発動回数" },
          { key: :avg_exburst_deaths, label: "EXバースト中被撃墜数" },
          { key: :exburst_death_ratio, label: "EXバースト中被撃墜率", unit: "%" },
        ] },
        { label: "EXオーバーリミット", rows: [
          { key: :ol_rate, label: "EXオーバーリミット発動率", unit: "%" },
        ] },
      ]
      all_players = @player_perf
      col_count = 2 + all_players.size
      global_st = @global_perf[:survival_stats]
      st_max_n = [ global_st.size, all_players.map { |d| d[:survival_stats].size }.max.to_i ].max
    %>

    <section class="s-panel">
      <div class="s-phead">
        <h2>基本パフォーマンス統計</h2>
        <span class="eyebrow">統計あり <%= @global_perf[:stats_count] %> 試合の平均値</span>
      </div>
      <div class="s-ptwrap">
        <table class="s-pt">
          <thead>
            <tr>
              <th class="l sticky">指標</th>
              <th class="ga">全体平均</th>
              <% all_players.each do |d| %>
                <th><%= d[:user].nickname %><span class="pc">(<%= d[:stats_count] %>)</span></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% perf_groups.each do |group| %>
              <tr class="grp"><td class="l sticky" colspan="<%= col_count %>"><%= group[:label] %></td></tr>
              <% group[:rows].each do |row| %>
                <tr>
                  <td class="l sticky"><%= row[:label] %></td>
                  <% val = @global_perf[row[:key]] %>
                  <td class="ga"><%= val ? "#{val}#{row[:unit]}" : "なし" %></td>
                  <% all_players.each do |d| %>
                    <% pval = d[row[:key]] %>
                    <td><%= pval ? "#{pval}#{row[:unit]}" : "なし" %></td>
                  <% end %>
                </tr>
              <% end %>
            <% end %>

            <% if st_max_n.positive? %>
              <tr class="grp"><td class="l sticky" colspan="<%= col_count %>">生存時間</td></tr>
              <% st_max_n.times do |i| %>
                <tr class="sub"><td colspan="<%= col_count %>"><%= i + 1 %>機体目</td></tr>
                <% [
                  { key: :survived_cs, count_key: :survived_count, label: "生存", cls: "" },
                  { key: :died_cs, count_key: :died_count, label: "被撃破", cls: "neg" },
                ].each do |outcome| %>
                  <%
                    g_st = global_st[i]
                    g_cs = g_st&.dig(outcome[:key])
                    g_cnt = g_st&.dig(outcome[:count_key]).to_i
                    next if g_cs.nil? && all_players.all? { |d| d[:survival_stats][i]&.dig(outcome[:key]).nil? }
                  %>
                  <tr>
                    <td class="l sticky <%= outcome[:cls] %>"><%= outcome[:label] %></td>
                    <td class="ga">
                      <% if g_cs %><%= format_survival_cs(g_cs) %><span class="games"><%= g_cnt %>試合</span><% else %>なし<% end %>
                    </td>
                    <% all_players.each do |d| %>
                      <% p_st = d[:survival_stats][i]
                         p_cs = p_st&.dig(outcome[:key])
                         p_cnt = p_st&.dig(outcome[:count_key]).to_i %>
                      <td>
                        <% if p_cs %><%= format_survival_cs(p_cs) %><span class="games"><%= p_cnt %>試合</span><% else %>なし<% end %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <%= link_to "← 機体一覧に戻る", mobile_suits_path, class: "s-back" %>
</div>
